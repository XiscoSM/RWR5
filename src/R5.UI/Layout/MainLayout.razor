@* Barra superior fija con contexto permanente (página, almacén, usuario, conexión)
   y contenido desplazable debajo. Protege las páginas: sin sesión → Login.
   Bloqueo de sesión (canon R3 feat/m17-usabilidad): por inactividad según los
   MinutosBloqueo del menú activo, al perder el foco de la app y manual (candado);
   el desbloqueo con la MISMA identidad continúa donde estaba y con OTRA hace un
   cambio de sesión completo. *@
@inherits LayoutComponentBase
@implements IDisposable
@inject SesionUsuario Sesion
@inject UsuarioService Usuarios
@inject ConfiguracionApp Config
@inject IEstadoRed EstadoRed
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="r5-shell">
    <header class="r5-barra">
        @if (Sesion.Autenticado && !_enInicio)
        {
            <button class="r5-btn r5-btn--fantasma r5-barra__inicio" title="Ir a Inicio" aria-label="Ir a Inicio" @onclick='() => Nav.NavigateTo("/inicio")'>
                <Icono Nombre="inicio" Clase="r5-barra__icono" />
            </button>
        }
        <span class="r5-barra__titulo">@_titulo</span>

        <div class="r5-barra__derecha">
            @if (!_hayInternet)
            {
                <span class="r5-chip" title="Sin conexión">
                    <Icono Nombre="sin-conexion" Clase="r5-barra__icono" />
                </span>
            }
            @if (Sesion.Autenticado)
            {
                <span class="r5-chip" title="Almacén activo">
                    <Icono Nombre="almacen" Clase="r5-barra__icono" />
                    @Sesion.Usuario!.Almacen.CodAlm · @Sesion.Usuario.Almacen.DescAlm
                </span>
                <span class="r5-chip" title="Usuario">
                    <Icono Nombre="usuario" Clase="r5-barra__icono" />
                    @Sesion.Usuario.DescUsuario
                </span>
                @* Bloqueo manual: deja la sesión protegida sin cerrarla (candado de R3). *@
                <button class="r5-btn r5-btn--fantasma r5-barra__salir" title="Bloquear sesión" aria-label="Bloquear sesión" @onclick="() => Bloquear()">
                    <Icono Nombre="candado" Clase="r5-barra__icono" />
                </button>
                @* Cerrar sesión en dos pasos: un toque errado con guantes en mitad de una
                   tarea no debe echar al operario al login. *@
                @if (!_confirmandoSalir)
                {
                    <button class="r5-btn r5-btn--fantasma r5-barra__salir" title="Cerrar sesión" aria-label="Cerrar sesión" @onclick="() => _confirmandoSalir = true">
                        <Icono Nombre="salir" Clase="r5-barra__icono" />
                    </button>
                }
                else
                {
                    <button class="r5-btn r5-btn--peligro r5-btn--sm" @onclick="CerrarSesion">Salir</button>
                    <button class="r5-btn r5-btn--fantasma r5-btn--sm" @onclick="() => _confirmandoSalir = false">Cancelar</button>
                }
            }
        </div>
    </header>

    @if (!_hayInternet)
    {
        <div class="r5-sin-conexion">Sin conexión — comprueba la red. Los datos no se pueden cargar ni guardar.</div>
    }

    <main class="r5-contenido">
        @Body
    </main>

    @* ---- Pantalla de bloqueo: tapa el módulo SIN cerrarlo (desbloqueo instantáneo). ---- *@
    @if (_bloqueada && Sesion.Autenticado)
    {
        <div class="r5-bloqueo">
            <div class="r5-login__tarjeta">
                <div class="r5-login__cabecera">
                    <div class="r5-login__icono"><span>🔒</span></div>
                    <span class="r5-login__env">Sesión bloqueada · @Sesion.Usuario!.DescUsuario</span>
                </div>
                <div class="r5-login__cuerpo">
                    @if (_desbloqueoEmpleado)
                    {
                        <form @onsubmit="DesbloquearEmpleadoAsync">
                            <div class="r5-columna">
                                <div class="r5-campo">
                                    <label for="bloqEmpleado">Nº personal (empleado)</label>
                                    <input id="bloqEmpleado" class="r5-input r5-input--numero" type="text" inputmode="numeric"
                                           @bind="_bloqEmpleado" @bind:event="oninput" autofocus disabled="@_desbloqueando" />
                                </div>
                                <div class="r5-campo">
                                    <label for="bloqPin">PIN secreto (4 dígitos)</label>
                                    <input id="bloqPin" class="r5-input r5-input--numero" type="password" inputmode="numeric" maxlength="4"
                                           @bind="_bloqPin" @bind:event="oninput" disabled="@_desbloqueando" />
                                </div>
                                <Aviso Mensaje="@_errorBloqueo" />
                                <button type="submit" class="r5-btn r5-btn--primario r5-btn--bloque"
                                        disabled="@(_desbloqueando || _bloqEmpleado is null or <= 0 || _bloqPin is null)">
                                    @(_desbloqueando ? "Validando…" : "Continuar (Empleado y PIN)")
                                </button>
                                <button type="button" class="r5-btn r5-btn--fantasma r5-btn--bloque"
                                        @onclick="() => { _desbloqueoEmpleado = false; _errorBloqueo = string.Empty; }" disabled="@_desbloqueando">
                                    Entrar con Usuario Pda
                                </button>
                            </div>
                        </form>
                    }
                    else
                    {
                        <form @onsubmit="DesbloquearUsuarioAsync">
                            <div class="r5-columna">
                                <div class="r5-campo">
                                    <label for="bloqUsuario">Nº de Usuario Pda</label>
                                    <input id="bloqUsuario" class="r5-input r5-input--numero" type="text" inputmode="numeric"
                                           @bind="_bloqUsuario" @bind:event="oninput" autofocus disabled="@_desbloqueando" />
                                </div>
                                <div class="r5-campo">
                                    <label for="bloqPwd">Contraseña</label>
                                    <input id="bloqPwd" class="r5-input r5-input--numero" type="password" inputmode="numeric"
                                           @bind="_bloqPwd" @bind:event="oninput" disabled="@_desbloqueando" />
                                </div>
                                <Aviso Mensaje="@_errorBloqueo" />
                                <button type="submit" class="r5-btn r5-btn--primario r5-btn--bloque"
                                        disabled="@(_desbloqueando || _bloqUsuario is null or <= 0 || _bloqPwd is null)">
                                    @(_desbloqueando ? "Validando…" : "Desbloquear")
                                </button>
                                <button type="button" class="r5-btn r5-btn--fantasma r5-btn--bloque"
                                        @onclick="() => { _desbloqueoEmpleado = true; _errorBloqueo = string.Empty; }" disabled="@_desbloqueando">
                                    Continuar (Empleado y PIN)
                                </button>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _hayInternet = true;
    private string _titulo = "RW R5";
    private bool _enInicio = true;
    private bool _confirmandoSalir;

    // ---- Bloqueo de sesión ----
    private bool _bloqueada;
    private bool _desbloqueoEmpleado = true;
    private bool _desbloqueando;
    private string _errorBloqueo = "";
    private int? _bloqEmpleado;
    private short? _bloqPin;
    private short? _bloqUsuario;
    private int? _bloqPwd;
    private DotNetObjectReference<MainLayout>? _refVigilancia;
    private readonly System.Threading.PeriodicTimer _timerBloqueo = new(TimeSpan.FromSeconds(10));

    protected override void OnInitialized()
    {
        _hayInternet = EstadoRed.HayInternet;
        EstadoRed.CambioConectividad += AlCambiarConectividad;
        Sesion.Cambio += AlCambiarSesion;
        Nav.LocationChanged += AlNavegar;
        ActualizarTitulo();
        ExigirSesion();
        _ = VigilarInactividadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _refVigilancia = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("r5.iniciarVigilancia", _refVigilancia);
    }

    // Minutos de bloqueo del MENÚ activo (0 = la pantalla actual no bloquea): la ruta se
    // traduce a módulo con el catálogo y el valor viene de MenuPermisos por usuario+menú.
    private short MinutosBloqueoActivo
    {
        get
        {
            if (!Sesion.Autenticado) return 0;
            string ruta = Nav.ToBaseRelativePath(Nav.Uri).TrimEnd('/');
            byte codMenu = CatalogoModulos.CodMenuDeRuta(ruta);
            if (codMenu == 0) return 0;
            return Sesion.Usuario!.Menus.FirstOrDefault(m => m.CodMenu == codMenu)?.MinutosBloqueo ?? 0;
        }
    }

    private async Task VigilarInactividadAsync()
    {
        try
        {
            while (await _timerBloqueo.WaitForNextTickAsync())
            {
                if (_bloqueada || !Sesion.Autenticado) continue;
                short minutos = MinutosBloqueoActivo;
                if (minutos <= 0) continue;
                double inactivo = await JS.InvokeAsync<double>("r5.segundosInactivo");
                if (inactivo >= minutos * 60)
                    await InvokeAsync(() => Bloquear());
            }
        }
        catch (OperationCanceledException) { /* cierre de la app */ }
        catch (JSDisconnectedException) { /* WebView cerrándose */ }
    }

    // Perder el foco a favor de otra aplicación (o minimizar) bloquea AL INSTANTE el
    // módulo bloqueable, sin esperar los minutos (canon R3).
    [JSInvokable]
    public async Task AppPerdioFoco()
    {
        if (!_bloqueada && Sesion.Autenticado && MinutosBloqueoActivo > 0)
            await InvokeAsync(() => Bloquear());
    }

    private void Bloquear()
    {
        if (!Sesion.Autenticado) return;
        _bloqueada = true;
        _confirmandoSalir = false;
        _desbloqueoEmpleado = Config.LoginPorEmpleado;
        _bloqEmpleado = Sesion.Usuario!.Empleado > 0 ? Sesion.Usuario.Empleado : null;
        _bloqPin = null;
        _bloqUsuario = Sesion.Usuario.CodUsuario;
        _bloqPwd = null;
        _errorBloqueo = "";
        StateHasChanged();
    }

    // Desbloqueo con Empleado/PIN: la misma identidad continúa donde estaba; otro
    // empleado = cambio de sesión completo (Iniciar de R3).
    private async Task DesbloquearEmpleadoAsync()
    {
        if (_desbloqueando || _bloqEmpleado is null or <= 0 || _bloqPin is null) return;
        _desbloqueando = true;
        _errorBloqueo = "";
        try
        {
            var r = await Usuarios.LoginEmpleadoAsync(_bloqEmpleado.Value, _bloqPin.Value);
            if (!r.Ok || r.Datos is null || r.Datos.CodUsuario <= 0)
            { _errorBloqueo = r.Error.Length > 0 ? r.Error : "Revise usuario y PIN."; _bloqPin = null; return; }
            if (r.Datos.Empleado == 0) r.Datos.Empleado = _bloqEmpleado.Value;
            AplicarDesbloqueo(r.Datos, mismaIdentidad: _bloqEmpleado.Value == Sesion.Usuario!.Empleado);
        }
        finally
        {
            _desbloqueando = false;
        }
    }

    private async Task DesbloquearUsuarioAsync()
    {
        if (_desbloqueando || _bloqUsuario is null or <= 0 || _bloqPwd is null) return;
        _desbloqueando = true;
        _errorBloqueo = "";
        try
        {
            var r = await Usuarios.LoginAsync(_bloqUsuario.Value, _bloqPwd.Value);
            if (!r.Ok || r.Datos is null || r.Datos.CodUsuario <= 0)
            { _errorBloqueo = r.Error.Length > 0 ? r.Error : "Usuario o contraseña incorrectos."; _bloqPwd = null; return; }
            AplicarDesbloqueo(r.Datos, mismaIdentidad: _bloqUsuario.Value == Sesion.Usuario!.CodUsuario);
        }
        finally
        {
            _desbloqueando = false;
        }
    }

    private void AplicarDesbloqueo(Usuario usuario, bool mismaIdentidad)
    {
        _bloqueada = false;
        if (mismaIdentidad) return;   // continúa exactamente donde estaba

        // Otra identidad: cambio de sesión completo y vuelta al inicio.
        usuario.NumTerminal = Config.NumTerminal;
        Sesion.CerrarSesion();
        Sesion.IniciarSesion(usuario);
        Nav.NavigateTo("/inicio", replace: true);
    }

    protected override void OnParametersSet() => ExigirSesion();

    private void ExigirSesion()
    {
        // Ajustes queda accesible sin sesión: es donde se configura URL y enrolamiento.
        string ruta = Nav.ToBaseRelativePath(Nav.Uri).TrimEnd('/').ToLowerInvariant();
        bool publica = ruta is "login" or "ajustes";
        if (!Sesion.Autenticado && !publica)
        {
            Nav.NavigateTo("/login", replace: true);
        }
    }

    private void ActualizarTitulo()
    {
        string ruta = Nav.ToBaseRelativePath(Nav.Uri).TrimEnd('/').ToLowerInvariant();
        _enInicio = ruta is "" or "inicio" or "login";
        _titulo = ruta switch
        {
            "" or "inicio" => "Inicio",
            "ajustes" => "Ajustes",
            "fichaproducto" => "Ficha producto",
            "cambioalmacen" => "Cambio de almacén",
            _ when ruta.StartsWith("pedidocentral") => "Pedido central",
            _ when ruta.StartsWith("traspasos") => "Traspasos",
            _ when ruta.StartsWith("recepcionalb") => "Recepción de albaranes",
            _ when ruta.StartsWith("pedidocompra") => "Pedido a proveedor",
            _ when ruta.StartsWith("inventarios") => "Inventarios",
            _ when ruta.StartsWith("ajustesstock") => "Ajustes de stock",
            _ when ruta.StartsWith("preparacion") => "Preparación",
            _ when ruta.StartsWith("informes") => "Informes",
            _ when ruta.StartsWith("etiquetas") => "Etiquetas",
            _ when ruta.StartsWith("gestiones") => "Gestiones",
            _ when ruta.StartsWith("horarios") => "Horarios",
            _ when ruta.StartsWith("envasado") => "Pesar y etiquetar",
            _ when ruta.StartsWith("despiece") => "Despiece y etiquetas",
            _ when ruta.StartsWith("elaboracion") => "Elaboración",
            _ when ruta.StartsWith("ifa") => "IFA Central de Compras",
            _ when ruta.StartsWith("trazabilidad") => "Trazabilidad de lote",
            _ when ruta.StartsWith("pedidocliente") => "Pedido de cliente",
            _ when ruta.StartsWith("facturatpv") => "Factura TPV",
            _ => "RW R5"
        };
        // Las páginas de módulo fijan su propio título vía CascadingValue en el futuro;
        // de momento el catálogo es corto y el switch basta.
    }

    private void AlNavegar(object? s, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _confirmandoSalir = false; // no arrastrar la confirmación de salida entre pantallas
        // Con la pantalla bloqueada no se puede navegar a otros menús (canon R3): se
        // permanece bloqueado hasta identificarse.
        ActualizarTitulo();
        ExigirSesion();
        InvokeAsync(StateHasChanged);
    }

    private void AlCambiarConectividad(object? s, bool hayInternet)
    {
        _hayInternet = hayInternet;
        InvokeAsync(StateHasChanged);
    }

    private void AlCambiarSesion() => InvokeAsync(StateHasChanged);

    private void CerrarSesion()
    {
        Sesion.CerrarSesion();
        Nav.NavigateTo("/login", replace: true);
    }

    public void Dispose()
    {
        EstadoRed.CambioConectividad -= AlCambiarConectividad;
        Sesion.Cambio -= AlCambiarSesion;
        Nav.LocationChanged -= AlNavegar;
        _timerBloqueo.Dispose();
        _refVigilancia?.Dispose();
    }
}
