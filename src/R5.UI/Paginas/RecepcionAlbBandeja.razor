@* Recepción de albaranes: bandeja de albaranes de proveedor pendientes de registrar
   y registrados. La fila da lo que el encargado necesita para localizarlo: número
   (interno y del proveedor), fecha, proveedor y tamaño/importe. *@
@page "/recepcionAlb"
@inject AlbaranService Albaranes
@inject SesionUsuario Sesion
@inject NavigationManager Nav

<GuardiaModulo CodMenu="9">
<div class="r5-columna">

    <div class="r5-fila">
        <div class="r5-segmento">
            <button class="@(!_registrados ? "activo" : "")" aria-pressed="@(!_registrados)" @onclick="() => CambiarFiltroAsync(false)" disabled="@_cargando">Pendientes</button>
            <button class="@(_registrados ? "activo" : "")" aria-pressed="@_registrados" @onclick="() => CambiarFiltroAsync(true)" disabled="@_cargando">Registrados</button>
        </div>
        @* Solo arriba cuando hay lista: si está vacía, la acción vive en el estado vacío
           (si no, saldrían dos botones idénticos en la misma pantalla). *@
        @if (_albaranes.Count > 0 || !string.IsNullOrEmpty(_error))
        {
            <button class="r5-btn r5-btn--primario" style="margin-left:auto"
                    @onclick="@(() => Nav.NavigateTo("/recepcionAlb/alta"))">
                + Nueva recepción
            </button>
        }
    </div>

    @if (!_cargando && string.IsNullOrEmpty(_error) && _albaranes.Count > 0)
    {
        @* Filtro por proveedor en memoria (nombre, código o nº de albarán de proveedor). *@
        <input class="r5-input" type="text" placeholder="Filtrar por proveedor o nº de albarán…"
               @bind="_filtroProv" @bind:event="oninput" />
    }

    @if (_cargando)
    {
        <Cargando Texto="Cargando albaranes…" />
    }
    else if (!string.IsNullOrEmpty(_error))
    {
        <Aviso Mensaje="@_error" />
    }
    else if (_albaranes.Count == 0)
    {
        <div class="r5-cargando">
            <Icono Nombre="recepcion" Clase="r5-modulo__icono" />
            <span>No tienes albaranes @(_registrados ? "registrados" : "pendientes") en este almacén.</span>
            <button class="r5-btn r5-btn--primario" @onclick='() => Nav.NavigateTo("/recepcionAlb/alta")'>+ Nueva recepción</button>
        </div>
    }
    else if (AlbaranesFiltrados.Count == 0)
    {
        <p class="r5-texto-suave">Ningún albarán coincide con «@_filtroProv».</p>
    }
    else
    {
        <ListaPaginada Items="AlbaranesFiltrados" Context="albaran">
            <Fila>
                <button @key="@($"{albaran.Fecha:yyyyMMdd}-{albaran.NumAlbaran}")" class="r5-doc"
                        @onclick="() => AbrirDetalle(albaran)">
                    <Icono Nombre="recepcion" Clase="r5-modulo__icono" />
                    <span class="r5-doc__principal">
                        <span class="r5-doc__titulo">
                            Albarán @albaran.NumAlbaran
                            @if (!string.IsNullOrWhiteSpace(albaran.NumAlbProv))
                            {
                                <text> · Prov: @albaran.NumAlbProv</text>
                            }
                        </span>
                        <span class="r5-doc__detalle">
                            @Fecha(albaran.Fecha) · @albaran.Prov.DescProv
                            @if (albaran.NumPedido > 0)
                            {
                                <text> · Pedido @albaran.NumPedido</text>
                            }
                        </span>
                    </span>
                    <span class="r5-doc__derecha">
                        <span class="r5-doc__detalle">@albaran.Prods prods · @Moneda(albaran.ImpNetoComercial)</span>
                        <span class="r5-badge @(albaran.Reg ? "r5-badge--cerrado" : "r5-badge--abierto")">
                            @(albaran.Reg ? "Registrado" : "Pendiente")
                        </span>
                    </span>
                </button>
            </Fila>
        </ListaPaginada>
        @if (_albaranes.Count >= Tope)
        {
            <p class="r5-texto-suave r5-texto-sm">Mostrando los @Tope más recientes; puede haber más. Afina con el filtro Pendientes/Registrados.</p>
        }
    }
</div>
</GuardiaModulo>

@code {
    private const short Tope = 300;
    private bool _registrados;
    private bool _cargando = true;
    private string _filtroProv = "";
    private string _error = "";

    // Filtro en cliente por proveedor (nombre/código) o nº de albarán del proveedor.
    private IReadOnlyList<Albaran> AlbaranesFiltrados
    {
        get
        {
            var f = _filtroProv.Trim();
            if (f.Length == 0) return _albaranes;
            return _albaranes.Where(a =>
                (a.Prov.DescProv ?? "").Contains(f, StringComparison.OrdinalIgnoreCase)
                || a.Prov.CodProv.ToString().Contains(f)
                || (a.NumAlbProv ?? "").Contains(f, StringComparison.OrdinalIgnoreCase)).ToList();
        }
    }
    private List<Albaran> _albaranes = new();

    protected override Task OnInitializedAsync() => CargarAsync();

    private Task CambiarFiltroAsync(bool registrados)
    {
        if (_registrados == registrados) return Task.CompletedTask;
        _registrados = registrados;
        return CargarAsync();
    }

    private async Task CargarAsync()
    {
        if (!Sesion.Autenticado) return;

        _cargando = true;
        _error = "";
        try
        {
            var respuesta = await Albaranes.GetAlbaranesAsync(
                Sesion.Usuario!.Almacen.CodAlm, Sesion.Usuario.CodUsuario, _registrados, Tope);
            if (!respuesta.Ok)
            {
                _error = respuesta.Error;
                _albaranes = new();
                return;
            }
            _albaranes = respuesta.Datos ?? new();
        }
        finally
        {
            _cargando = false;
        }
    }

    private void AbrirDetalle(Albaran albaran)
        => Nav.NavigateTo($"/recepcionAlb/{albaran.Fecha:yyyy-MM-dd}/{albaran.NumAlbaran}?reg={(albaran.Reg ? 1 : 0)}");
}
