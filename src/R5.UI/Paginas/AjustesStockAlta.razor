@* Alta de ajuste de stock: primero el TIPO (define el destino contable) y, si el
   tipo lo permite, el programa o el almacén de destino; después escaneo encadenado
   con el coste a la vista (el importe del ajuste sale de cant × coste). *@
@page "/ajustesStock/alta"
@inject AjusteService Ajustes
@inject AlmacenService Almacenes
@inject ComentarioService Comentarios
@inject SesionUsuario Sesion
@inject NavigationManager Nav
@inject IJSRuntime JS

<GuardiaModulo CodMenu="5">
<div class="r5-columna">

    <div class="r5-fila">
        <button class="r5-btn r5-btn--secundario" @onclick="Volver">← Ajustes</button>
        <h2>Nuevo ajuste</h2>
        @if (_numAjuste > 0)
        {
            <div class="r5-fila" style="margin-left:auto">
                <span class="r5-chip" style="background: var(--c-primario-claro); color: var(--c-primario-osc);">
                    Ajuste @_numAjuste · @_lineasAnadidas líneas
                </span>
                <button class="r5-btn r5-btn--primario" @onclick="AbrirRegistrarAsync" disabled="@_registrando">
                    Registrar ajuste
                </button>
            </div>
        }
    </div>

    @if (_verificandoRegistro)
    {
        @* Control de R3: para registrar hay que teclear el importe aproximado del ajuste
           y debe coincidir (en euros enteros) con el importe real del documento. *@
        <form class="r5-tarjeta r5-columna r5-ancho-form" @onsubmit="RegistrarVerificadoAsync">
            <h3>Registrar ajuste @_numAjuste</h3>
            <p class="r5-texto-suave r5-texto-sm">
                Verificación anti-error: teclea el importe aproximado del ajuste (en euros, sin decimales).
                Mueve stock y coste; no se puede deshacer.
            </p>
            <div class="r5-campo" style="max-width: 240px;">
                <label for="importeVerif">Importe aproximado €</label>
                <input id="importeVerif" class="r5-input r5-input--numero" type="number" inputmode="numeric" step="1"
                       @bind="_importeTecleado" disabled="@_registrando" />
            </div>
            <div class="r5-fila">
                <button type="submit" class="r5-btn r5-btn--primario" disabled="@(_registrando || _importeTecleado is null)">
                    @(_registrando ? "Registrando…" : "Confirmar registro")
                </button>
                <button type="button" class="r5-btn r5-btn--fantasma" @onclick="() => _verificandoRegistro = false">Cancelar</button>
            </div>
        </form>
    }

    @if (_tipoElegido is null)
    {
        <div class="r5-tarjeta r5-columna">
            <h3>Tipo de ajuste</h3>
            @if (_cargandoInicial)
            {
                <Cargando Texto="Cargando tipos…" />
            }
            else if (_tipos.Count == 0)
            {
                <Aviso Mensaje="@(_aviso.Length > 0 ? _aviso : "No hay tipos de ajuste disponibles.")"
                       OnReintentar="CargarInicialAsync" Reintentando="_cargandoInicial" />
            }
            else
            {
                <div class="r5-docs">
                    @foreach (var tipo in _tipos)
                    {
                        <button @key="tipo.Tipo" class="r5-doc" @onclick="() => ElegirTipo(tipo)">
                            <Icono Nombre="ajustes-stock" Clase="r5-modulo__icono" />
                            <span class="r5-doc__principal">
                                <span class="r5-doc__titulo">@tipo.DescTipo</span>
                                <span class="r5-doc__detalle">Tipo @tipo.Tipo · Cuenta @tipo.Cuenta</span>
                            </span>
                        </button>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="r5-tarjeta r5-columna">
            <div class="r5-fila" style="flex-wrap: wrap;">
                <span class="r5-texto-suave">Tipo:</span>
                <strong>@_tipoElegido.DescTipo</strong>
                @if (_numAjuste == 0)
                {
                    <button class="r5-btn r5-btn--fantasma" @onclick="CambiarTipo">Cambiar</button>
                }

                @if (_programas.Count > 0)
                {
                    @* El proc exige siempre un programa válido (FK); si el tipo no permite
                       cambiarlo queda fijado al primero. *@
                    <div class="r5-campo" style="min-width: 260px;">
                        <label for="progDest">Programa destino</label>
                        <select id="progDest" class="r5-select" @bind="_progDest"
                                disabled="@(_numAjuste > 0 || !_tipoElegido.PermiteCambioProgDestino)">
                            @foreach (var programa in _programas)
                            {
                                <option value="@programa.Prog">@programa.DescProg</option>
                            }
                        </select>
                    </div>
                }
                @if (_tipoElegido.PermiteCambioAlmDestino)
                {
                    @* Cambiarlo exige además permiso del usuario y del almacén (R3:
                       RW_CambAlmDestAjustes + AjustesContraOtroAlm); si no, queda fijado al propio. *@
                    <div class="r5-campo" style="min-width: 180px;">
                        <label for="almDestAjuste">Almacén destino</label>
                        <input id="almDestAjuste" class="r5-input r5-input--numero" type="text" inputmode="numeric"
                               min="1" max="999" @bind="_codAlmDest"
                               disabled="@(_numAjuste > 0 || !Sesion.Usuario!.CambAlmDestAjustes || !Sesion.Usuario.Almacen.AjustesContraOtroAlm)" />
                    </div>
                }
            </div>

            <form @onsubmit="BuscarAsync" class="r5-buscador">
                <input id="busquedaAjuste" class="r5-input" type="text" inputmode="numeric"
                       placeholder="Escanea un EAN o teclea el código de producto"
                       @bind="_codigo" @bind:event="oninput" disabled="@_ocupado" />
                <button type="submit" class="r5-btn r5-btn--secundario" disabled="@(_ocupado || string.IsNullOrWhiteSpace(_codigo))">
                    Buscar
                </button>
            </form>
        </div>

        <Aviso Tipo="@_tipoAviso" Mensaje="@_aviso" />

        @if (_ocupado)
        {
            <Cargando />
        }
        else if (_linea is not null)
        {
            <div class="r5-tarjeta r5-columna">
                <div class="r5-ficha__identidad">
                    <span class="r5-ficha__codigo">@_linea.Prod.CodProd</span>
                    <span class="r5-ficha__nombre">@_linea.Prod.DescProd</span>
                </div>

                <dl class="r5-datos">
                    <div><dt>Precio coste</dt><dd>@Moneda(_linea.PrecioCoste)</dd></div>
                    @if (_linea.TotalCantEnAjuste > 0)
                    {
                        <div><dt>Ya en este ajuste</dt><dd>@Cantidad(_linea.TotalCantEnAjuste, _linea.Prod.DecimalesEnCant)</dd></div>
                    }
                    <div><dt>Importe de la línea</dt><dd>@Moneda(Importe)</dd></div>
                </dl>

                <div class="r5-campo">
                    <label for="cantAjuste">Cantidad a ajustar</label>
                    <input id="cantAjuste" class="r5-input r5-input--numero" type="number" inputmode="decimal"
                           step="@(_linea.Prod.DecimalesEnCant ? "0.001" : "1")" min="0"
                           @bind="_cantidad" @bind:event="oninput" />
                </div>

                @* Comentario de línea (predefinidos tipo 7, como el Bcoment de R3):
                   se adjunta y se graba con la línea al añadirla. *@
                <SelectorComentario @ref="_selectorComentLinea" TipoDoc="7" Etiqueta="Comentario línea"
                                    OnComentarioListo="t => _comentarioLinea = t" />

                <button class="r5-btn r5-btn--primario r5-btn--bloque" @onclick="AnadirAsync"
                        disabled="@(_anadiendo || _cantidad <= 0)">
                    @(_anadiendo ? "Añadiendo…" : $"Añadir {Cantidad(_cantidad, _linea.Prod.DecimalesEnCant)} al ajuste")
                </button>
            </div>
        }

        <PanelLineas Items="_lineasDoc" Cargando="_cargandoLineas" Titulo="Líneas del ajuste">
            <Cabecera>
                <th>Cód.</th><th>Producto</th><th class="num">Cant.</th>
            </Cabecera>
            <Fila Context="l">
                <tr @key="l.Linea">
                    <td>@l.Prod.CodProd</td>
                    <td>@l.Prod.DescProd</td>
                    <td class="num">@Cantidad(l.Cant, l.Prod.DecimalesEnCant)</td>
                </tr>
            </Fila>
        </PanelLineas>
    }
</div>
</GuardiaModulo>

@code {
    private List<TipoAjuste> _tipos = new();
    private List<Programa> _programas = new();
    private TipoAjuste? _tipoElegido;
    private short _progDest = -1;
    private short _codAlmDest;

    private string _codigo = "";
    private bool _ocupado;
    private bool _anadiendo;
    private bool _registrando;
    private bool _cargandoInicial = true;
    private bool _enfocarBuscador;

    // Foco al buscador en cuanto aparece (tras elegir el tipo de ajuste).
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_enfocarBuscador)
        {
            _enfocarBuscador = false;
            await JS.InvokeVoidAsync("r5.seleccionar", "busquedaAjuste");
        }
    }
    private string _aviso = "";
    private string _tipoAviso = "error";

    private AjusteLin? _linea;
    private long _eanEscaneado;
    private decimal _cantidad;
    private int _numAjuste;

    // Comentario de línea diferido: se graba justo después de insertar la línea.
    private string _comentarioLinea = "";
    private SelectorComentario? _selectorComentLinea;
    private int _lineasAnadidas;
    private List<AjusteLin> _lineasDoc = new();
    private bool _cargandoLineas;
    private readonly DateTime _fecha = DateTime.Today;

    private decimal Importe => _linea is null ? 0 : Math.Round(_cantidad * _linea.PrecioCoste, 2);

    protected override Task OnInitializedAsync() => CargarInicialAsync();

    // Tipos y programas: si falla cualquiera, no se puede dar de alta (el proc exige un
    // programa válido por FK), así que se bloquea con aviso y opción de reintentar en vez
    // de dejar un spinner eterno o reventar al añadir la primera línea.
    private async Task CargarInicialAsync()
    {
        _codAlmDest = Sesion.Usuario?.Almacen.CodAlm ?? 0;
        _cargandoInicial = true;
        _aviso = "";
        try
        {
            var tareaTipos = Ajustes.GetTiposAsync();
            var tareaProgramas = Ajustes.GetProgramasAsync();
            await Task.WhenAll(tareaTipos, tareaProgramas);

            if (!tareaTipos.Result.Ok) { MostrarError(tareaTipos.Result.Error); return; }
            if (!tareaProgramas.Result.Ok) { MostrarError("No se pudieron cargar los programas: " + tareaProgramas.Result.Error); return; }

            _tipos = tareaTipos.Result.Datos ?? new();
            _programas = tareaProgramas.Result.Datos ?? new();
            if (_programas.Count > 0) _progDest = _programas[0].Prog;
        }
        finally
        {
            _cargandoInicial = false;
        }
    }

    private void ElegirTipo(TipoAjuste tipo)
    {
        _tipoElegido = tipo;
        _aviso = "";
        _enfocarBuscador = true;
    }

    private void CambiarTipo()
    {
        _tipoElegido = null;
        _linea = null;
        _aviso = "";
    }

    private async Task BuscarAsync()
    {
        string codigo = _codigo.Trim();
        if (_ocupado || codigo.Length == 0 || _tipoElegido is null || !Sesion.Autenticado) return;

        _ocupado = true;
        _aviso = "";
        _linea = null;
        _eanEscaneado = 0;
        try
        {
            short origen = Sesion.Usuario!.Almacen.CodAlm;

            // Códigos compuestos de balanza/trazabilidad (EanProdLote de R3): 16 díg =
            // prod+lote, 19 = prod+peso+importe, 28 = +lote. Los de 19/28 no caben en un
            // long: hay que descomponer ANTES de decidir la ruta, como hacía R3.
            int codProd = 0;
            long codEan = 0;
            int lote = 0;
            var parseado = CodigoBarras.TryParse(codigo);
            if (parseado is { Prod: > 0 })
            {
                codProd = parseado.Prod;
                lote = parseado.Lote;
            }
            else if (codigo.Length >= 8 && long.TryParse(codigo, out long ean)) codEan = ean;
            else if (int.TryParse(codigo, out int cod) && cod > 0)
            {
                // Teclear el código de producto exige permiso (RW_CodProdEnConsultas de R3).
                if (!Sesion.Usuario.CodProdEnConsultas) { MostrarError("Escanea el código de barras: no tienes permiso para buscar por código de producto."); return; }
                codProd = cod;
            }
            else { MostrarError("Introduce un código numérico (producto o EAN)."); return; }

            var respuesta = await Ajustes.GetLineaProductoAsync(_numAjuste, _fecha, origen, _codAlmDest, codProd, codEan, lote);
            if (!respuesta.Ok || respuesta.Datos is null) { MostrarError(respuesta.Error); return; }
            if (respuesta.Datos.Prod.CodProd <= 0) { MostrarError($"El código {codigo} no corresponde a ningún producto."); return; }

            _linea = respuesta.Datos;
            _eanEscaneado = codEan;
            // EAN de balanza: cantidad embebida en el código (EanProdLote de R3).
            _cantidad = parseado is { TraeCantidad: true } ? parseado.Cant : 1;
        }
        finally
        {
            _ocupado = false;
            StateHasChanged();
            await JS.InvokeVoidAsync("r5.seleccionar", "busquedaAjuste");
        }
    }

    private async Task AnadirAsync()
    {
        if (_anadiendo || _linea is null || _tipoElegido is null || _cantidad <= 0) return;

        // Tope de sanidad: una lectura del escaner caida en el campo cantidad (>=10.000)
        // no puede acabar grabada como unidades.
        if (_cantidad >= 10000) { MostrarError($"Cantidad {_cantidad} no valida: ¿has escaneado un codigo en el campo de cantidad?"); return; }

        // Almacén destino tecleado a mano: se valida su existencia ANTES de crear el
        // ajuste (misma guarda que R3: 'Almacén no Valido'). Solo en la primera línea.
        if (_numAjuste == 0 && _tipoElegido.PermiteCambioAlmDestino
            && _codAlmDest != Sesion.Usuario!.Almacen.CodAlm)
        {
            if (_codAlmDest <= 0) { MostrarError("Introduce un almacén de destino válido."); return; }
            var alm = await Almacenes.GetAsync(_codAlmDest);
            if (!alm.Ok || alm.Datos is null || alm.Datos.CodAlm <= 0)
            {
                MostrarError($"El almacén {_codAlmDest} no existe.");
                return;
            }
        }

        // Trazabilidad del lote (misma regla que R3): con destino distinto del propio
        // almacén o sección, el lote caducado o sin curación completa no se puede ajustar.
        bool destinoDistinto = _codAlmDest != Sesion.Usuario!.Almacen.CodAlm || _progDest > 0;
        if (destinoDistinto && _linea.Prod.FechaCaducidad is not null
            && _linea.Prod.DiasCaducidad > 0 && _linea.Prod.FechaCaducidad.Value.Date < DateTime.Today)
        {
            MostrarError($"Lote caducado ({_linea.Prod.FechaCaducidad:dd/MM/yy}): no se permite con destino a otra sección o almacén.");
            return;
        }
        if (destinoDistinto && _linea.Prod.FechaCuracion is not null
            && _linea.Prod.FechaCuracion.Value.Date > DateTime.Today)
        {
            MostrarError($"El lote no ha alcanzado la fecha de curación ({_linea.Prod.FechaCuracion:dd/MM/yy}).");
            return;
        }

        _anadiendo = true;
        _aviso = "";
        try
        {
            var alta = new AjusteLinInsertDTO
            {
                Fecha = _fecha,
                NumAjuste = _numAjuste,
                Tipo = _tipoElegido.Tipo,
                CodAlmOrigen = Sesion.Usuario!.Almacen.CodAlm,
                CodAlmDest = _codAlmDest,
                ProgDest = _progDest, // siempre un programa válido: el proc lo exige por FK

                CodUsuario = Sesion.Usuario.CodUsuario,
                CodProd = _linea.Prod.CodProd,
                Cant = _cantidad,
                ImporteCoste = Importe,
                Lote = _linea.Lote,
                CodEan = _eanEscaneado,
                Registrado = false,
                Linea = 0
            };
            var respuesta = await Ajustes.PostLineaAsync(alta);
            if (!respuesta.Ok || respuesta.Datos is null) { MostrarError(respuesta.Error); return; }

            _numAjuste = respuesta.Datos.NumDoc;

            // Comentario de línea adjuntado: se graba contra la línea recién creada
            // (mismo orden que R3). Mejor esfuerzo, no bloquea el escaneo siguiente.
            if (_comentarioLinea.Length > 0)
            {
                await Comentarios.PostAsync(7, _fecha, _numAjuste, respuesta.Datos.LineaDoc,
                    Sesion.Usuario.CodUsuario, _comentarioLinea);
                _comentarioLinea = "";
                _selectorComentLinea?.Reset();
            }

            _lineasAnadidas++;
            _tipoAviso = "exito";
            _aviso = $"{_linea.Prod.DescProd}: {Cantidad(_cantidad, _linea.Prod.DecimalesEnCant)} añadido al ajuste {_numAjuste}.";
            _linea = null;
            _codigo = "";
            _ = RefrescarLineasAsync();
        }
        finally
        {
            _anadiendo = false;
            StateHasChanged();
            await JS.InvokeVoidAsync("r5.seleccionar", "busquedaAjuste");
        }
    }

    // Refresca el panel de líneas sin bloquear el siguiente escaneo (ApiWeb no lanza).
    private async Task RefrescarLineasAsync()
    {
        if (_numAjuste <= 0) return;
        _cargandoLineas = true;
        var r = await Ajustes.GetLineasAsync(_numAjuste, _fecha);
        if (r.Ok && r.Datos is not null) _lineasDoc = r.Datos;
        _cargandoLineas = false;
        StateHasChanged();
    }

    // --- Registro con cotejo de importe (paridad R3: BAjusteReg_Click) ---
    private bool _verificandoRegistro;
    private int? _importeTecleado;
    private decimal _importeDoc;

    // Abre la verificación con el importe REAL del documento leído del servidor.
    private async Task AbrirRegistrarAsync()
    {
        if (_registrando || _numAjuste <= 0) return;
        _registrando = true;
        _aviso = "";
        try
        {
            var cab = await Ajustes.GetCabeceraAsync(_numAjuste, _fecha);
            if (!cab.Ok || cab.Datos is null) { MostrarError(cab.Error); return; }
            _importeDoc = cab.Datos.ImporteCoste;
            _importeTecleado = null;
            _verificandoRegistro = true;
        }
        finally
        {
            _registrando = false;
        }
    }

    // Registrar el ajuste: irreversible desde la app (mueve stock/coste en RW). El importe
    // tecleado debe coincidir con el del documento en euros enteros (mismo control que R3).
    private async Task RegistrarVerificadoAsync()
    {
        if (_registrando || _numAjuste <= 0 || _importeTecleado is null) return;

        if (_importeTecleado.Value != (int)Math.Round(_importeDoc, MidpointRounding.AwayFromZero))
        {
            MostrarError($"El importe no coincide (has tecleado {_importeTecleado} €). Revisa las líneas del ajuste antes de registrar.");
            return;
        }

        _registrando = true;
        _aviso = "";
        try
        {
            var respuesta = await Ajustes.RegistrarAsync(_numAjuste, _fecha, Sesion.Usuario!.CodUsuario);
            if (!respuesta.Ok) { MostrarError(respuesta.Error); return; }

            Nav.NavigateTo($"/ajustesStock/{_fecha:yyyy-MM-dd}/{_numAjuste}");
        }
        finally
        {
            _registrando = false;
        }
    }

    private void MostrarError(string mensaje)
    {
        _tipoAviso = "error";
        _aviso = mensaje;
    }

    private void Volver() => Nav.NavigateTo("/ajustesStock");
}
