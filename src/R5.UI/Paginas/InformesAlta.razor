@* Alta de informe manual: el TIPO define qué campos se piden por línea (cajas,
   cantidad, hasta 3 precios y 3 valores, con su etiqueta y obligatoriedad) —
   la pantalla se adapta igual que hace R3. Escaneo encadenado; el tipo con
   RellenarCampos precarga los valores desde la BD. *@
@page "/informes/alta"
@page "/informes/alta/{NumRuta:int}"
@inject InformeService Informes
@inject SesionUsuario Sesion
@inject NavigationManager Nav
@inject IJSRuntime JS

<GuardiaModulo CodMenu="22">
<div class="r5-columna">

    <div class="r5-fila">
        <button class="r5-btn r5-btn--secundario" @onclick="Volver">← Informes</button>
        <h2>Nuevo informe</h2>
        @if (_numInforme > 0)
        {
            <div class="r5-fila" style="margin-left:auto">
                <span class="r5-chip" style="background: var(--c-primario-claro); color: var(--c-primario-osc);">
                    Informe @_numInforme · @_lineasAnadidas líneas
                </span>
                <BotonConfirmar Texto="Registrar informe"
                                Pregunta="@($"¿Registrar el informe {_numInforme} con {_lineasAnadidas} líneas?")"
                                TextoOcupado="Registrando…" Ocupado="@_registrando"
                                OnConfirmar="RegistrarAsync" />
            </div>
        }
    </div>

    @if (_tipoElegido is null)
    {
        <div class="r5-tarjeta r5-columna">
            <h3>Tipo de informe</h3>
            @if (_cargandoInicial)
            {
                <Cargando Texto="Cargando tipos…" />
            }
            else if (_tipos.Count == 0)
            {
                <Aviso Mensaje="@(_aviso.Length > 0 ? _aviso : "No hay tipos de informe disponibles.")"
                       OnReintentar="CargarTiposAsync" Reintentando="_cargandoInicial" />
            }
            else
            {
                <div class="r5-docs">
                    @foreach (var tipo in _tipos)
                    {
                        <button @key="tipo.Tipo" class="r5-doc" @onclick="() => ElegirTipo(tipo)">
                            <Icono Nombre="informes" Clase="r5-modulo__icono" />
                            <span class="r5-doc__principal">
                                <span class="r5-doc__titulo">@tipo.DescTipo</span>
                                <span class="r5-doc__detalle">Tipo @tipo.Tipo</span>
                            </span>
                        </button>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="r5-tarjeta r5-columna">
            <div class="r5-fila" style="flex-wrap: wrap;">
                <span class="r5-texto-suave">Tipo:</span>
                <strong>@_tipoElegido.DescTipo</strong>
                @if (_numInforme == 0)
                {
                    <button class="r5-btn r5-btn--fantasma" @onclick="CambiarTipo">Cambiar</button>
                }
                @if (_tipoElegido.AlmDest > 0)
                {
                    <div class="r5-campo" style="min-width: 180px;">
                        <label for="almDestInf">Almacén destino@(_tipoElegido.AlmDest == 2 ? " *" : "")</label>
                        <input id="almDestInf" class="r5-input r5-input--numero" type="text" inputmode="numeric"
                               min="0" max="999" @bind="_codAlmDest" disabled="@(_numInforme > 0)" />
                    </div>
                }
            </div>

            <form @onsubmit="BuscarAsync" class="r5-buscador">
                <input id="busquedaInforme" class="r5-input" type="text" inputmode="numeric"
                       placeholder="Escanea un EAN o teclea el código de producto"
                       @bind="_codigo" @bind:event="oninput" disabled="@_ocupado" />
                <button type="submit" class="r5-btn r5-btn--secundario" disabled="@(_ocupado || string.IsNullOrWhiteSpace(_codigo))">
                    Buscar
                </button>
            </form>
        </div>

        <Aviso Tipo="@_tipoAviso" Mensaje="@_aviso" />

        @if (_ocupado)
        {
            <Cargando />
        }
        else if (_linea is not null)
        {
            <div class="r5-tarjeta r5-columna">
                <div class="r5-ficha__identidad">
                    <span class="r5-ficha__codigo">@_linea.Prod.CodProd</span>
                    <span class="r5-ficha__nombre">@_linea.Prod.DescProd</span>
                </div>

                <div class="r5-fila" style="flex-wrap: wrap; align-items: flex-end;">
                    @if (_tipoElegido.Cajas > 0)
                    {
                        <div class="r5-campo" style="min-width: 130px; flex: 1;">
                            <label>Cajas@(Oblig(_tipoElegido.Cajas))@(_linea?.Prod.UnidsCaja > 0 ? $" (U/C {_linea.Prod.UnidsCaja})" : "")</label>
                            @* Cajas × U/C rellena la cantidad si el producto no admite decimales (R3 1309). *@
                            <input class="r5-input r5-input--numero" type="text" inputmode="numeric" min="0"
                                   @bind="_cajas" @bind:after="CajasCambiadas" />
                        </div>
                    }
                    @if (_tipoElegido.Cant > 0)
                    {
                        <div class="r5-campo" style="min-width: 130px; flex: 1;">
                            <label>Cantidad@(Oblig(_tipoElegido.Cant))</label>
                            <input class="r5-input r5-input--numero" type="number" inputmode="decimal"
                                   step="@(_linea.Prod.DecimalesEnCant ? "0.001" : "1")" min="0" @bind="_cant" />
                        </div>
                    }
                    @if (_tipoElegido.PrecioA > 0)
                    {
                        <div class="r5-campo" style="min-width: 140px; flex: 1;">
                            <label>@Etiqueta(_tipoElegido.PrecioA_Desc, "Precio A")@(Oblig(_tipoElegido.PrecioA))</label>
                            <input class="r5-input r5-input--numero" type="number" inputmode="decimal" step="0.01" min="0" @bind="_precioA" />
                        </div>
                    }
                    @if (_tipoElegido.PrecioB > 0)
                    {
                        <div class="r5-campo" style="min-width: 140px; flex: 1;">
                            <label>@Etiqueta(_tipoElegido.PrecioB_Desc, "Precio B")@(Oblig(_tipoElegido.PrecioB))</label>
                            <input class="r5-input r5-input--numero" type="number" inputmode="decimal" step="0.01" min="0" @bind="_precioB" />
                        </div>
                    }
                    @if (_tipoElegido.PrecioC > 0)
                    {
                        <div class="r5-campo" style="min-width: 140px; flex: 1;">
                            <label>@Etiqueta(_tipoElegido.PrecioC_Desc, "Precio C")@(Oblig(_tipoElegido.PrecioC))</label>
                            <input class="r5-input r5-input--numero" type="number" inputmode="decimal" step="0.01" min="0" @bind="_precioC" />
                        </div>
                    }
                    @if (_tipoElegido.ValorA > 0)
                    {
                        <div class="r5-campo" style="min-width: 160px; flex: 1;">
                            <label>@Etiqueta(_tipoElegido.ValorA_Desc, "Valor A")@(Oblig(_tipoElegido.ValorA))</label>
                            <input class="r5-input" type="text" @bind="_valorA" />
                        </div>
                    }
                    @if (_tipoElegido.ValorB > 0)
                    {
                        <div class="r5-campo" style="min-width: 160px; flex: 1;">
                            <label>@Etiqueta(_tipoElegido.ValorB_Desc, "Valor B")@(Oblig(_tipoElegido.ValorB))</label>
                            <input class="r5-input" type="text" @bind="_valorB" />
                        </div>
                    }
                    @if (_tipoElegido.ValorC > 0)
                    {
                        <div class="r5-campo" style="min-width: 160px; flex: 1;">
                            <label>@Etiqueta(_tipoElegido.ValorC_Desc, "Valor C")@(Oblig(_tipoElegido.ValorC))</label>
                            <input class="r5-input" type="text" @bind="_valorC" />
                        </div>
                    }
                </div>

                <button class="r5-btn r5-btn--primario r5-btn--bloque" @onclick="AnadirAsync" disabled="@_anadiendo">
                    @(_anadiendo ? "Añadiendo…" : "Añadir al informe")
                </button>
            </div>
        }

        <PanelLineas Items="_lineasDoc" Cargando="_cargandoLineas" Titulo="Líneas del informe">
            <Cabecera>
                <th>Cód.</th><th>Producto</th><th class="num">Cajas</th><th class="num">Cant.</th>
            </Cabecera>
            <Fila Context="l">
                <tr @key="l.Linea">
                    <td>@l.Prod.CodProd</td>
                    <td>@l.Prod.DescProd</td>
                    <td class="num">@(l.Cajas?.ToString() ?? "—")</td>
                    <td class="num">@(l.Cant is null ? "—" : Cantidad(l.Cant.Value, l.Prod.DecimalesEnCant))</td>
                </tr>
            </Fila>
        </PanelLineas>
    }
</div>
</GuardiaModulo>

@code {
    private List<TipoInforme> _tipos = new();
    private TipoInforme? _tipoElegido;
    private short _codAlmDest;

    private string _codigo = "";
    private bool _ocupado;
    private bool _anadiendo;
    private bool _registrando;
    private bool _cargandoInicial = true;
    private bool _enfocarBuscador;

    // Foco al buscador en cuanto aparece (tras elegir el tipo de informe).
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_enfocarBuscador)
        {
            _enfocarBuscador = false;
            await JS.InvokeVoidAsync("r5.seleccionar", "busquedaInforme");
        }
    }
    private string _aviso = "";
    private string _tipoAviso = "error";

    private InformeLin? _linea;
    private long _eanEscaneado;
    private short _cajas;
    private decimal _cant;
    private decimal _precioA;
    private decimal _precioB;
    private decimal _precioC;
    private string _valorA = "";
    private string _valorB = "";
    private string _valorC = "";

    private int _numInforme;
    private int _lineasAnadidas;
    private List<InformeLin> _lineasDoc = new();
    private bool _cargandoLineas;
    private readonly DateTime _fecha = DateTime.Today;

    private static string Oblig(byte visibilidad) => visibilidad == 2 ? " *" : "";
    private static string Etiqueta(string? desc, string porDefecto)
        => string.IsNullOrWhiteSpace(desc) ? porDefecto : desc;

    /// <summary>Con nº en la ruta, se reabre ese informe PENDIENTE para seguir
    /// añadiéndole líneas (Bcontinuar de R3).</summary>
    [Parameter] public int NumRuta { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await CargarTiposAsync();
        if (NumRuta <= 0) return;

        var inf = await Informes.GetInformeAsync(NumRuta);
        if (!inf.Ok || inf.Datos is null || inf.Datos.NumInforme <= 0)
        { MostrarError($"No se pudo cargar el informe {NumRuta}: {inf.Error}"); return; }
        if (inf.Datos.Estado)
        { MostrarError($"El informe {NumRuta} ya está registrado: no admite más líneas."); return; }

        _numInforme = inf.Datos.NumInforme;
        _tipoElegido = _tipos.FirstOrDefault(t => t.Tipo == inf.Datos.TipoInforme?.Tipo);
        if (_tipoElegido is null)
        { MostrarError($"El tipo del informe {NumRuta} no está disponible."); _numInforme = 0; return; }
        _codAlmDest = inf.Datos.AlmDest?.CodAlm ?? 0;
        _lineasAnadidas = (int)inf.Datos.Prods;
    }

    private async Task CargarTiposAsync()
    {
        _cargandoInicial = true;
        _aviso = "";
        try
        {
            var tipos = await Informes.GetTiposAsync();
            if (!tipos.Ok) { MostrarError(tipos.Error); return; }
            _tipos = tipos.Datos ?? new();
        }
        finally
        {
            _cargandoInicial = false;
        }
    }

    private void ElegirTipo(TipoInforme tipo)
    {
        _tipoElegido = tipo;
        _aviso = "";
        _enfocarBuscador = true;
    }

    private void CambiarTipo()
    {
        _tipoElegido = null;
        _linea = null;
        _aviso = "";
    }

    private async Task BuscarAsync()
    {
        string codigo = _codigo.Trim();
        if (_ocupado || codigo.Length == 0 || _tipoElegido is null || !Sesion.Autenticado) return;

        _ocupado = true;
        _aviso = "";
        _linea = null;
        _eanEscaneado = 0;
        try
        {
            short codAlm = Sesion.Usuario!.Almacen.CodAlm;

            // Códigos compuestos de balanza/trazabilidad (EanProdLote de R3): 16 díg =
            // prod+lote, 19 = prod+peso+importe, 28 = +lote. Se descompone ANTES de
            // decidir la ruta: los de 19/28 dígitos no caben en un long.
            var parseado = CodigoBarras.TryParse(codigo);

            // Dígito de control (R3 aceptar_EAN): un EAN13/14 con checksum erróneo se
            // rechaza aquí con el mensaje específico, no con el genérico del servidor.
            if (parseado is null && codigo.Length is 13 or 14 && codigo.All(char.IsAsciiDigit))
            { MostrarError($"EAN incorrecto: dígito de control erróneo ({codigo})."); return; }

            ApiRespuesta<InformeLin> respuesta;
            if (parseado is { Prod: > 0 })
            {
                // Compuesto escaneado: se busca por el código de producto embebido.
                respuesta = await Informes.GetProdPorCodAsync(_tipoElegido.Tipo, codAlm, parseado.Prod);
            }
            else if (codigo.Length >= 8 && long.TryParse(codigo, out long ean))
            {
                respuesta = await Informes.GetProdPorEanAsync(_tipoElegido.Tipo, codAlm, ean);
                _eanEscaneado = ean;
            }
            else if (int.TryParse(codigo, out int codProd) && codProd > 0)
            {
                // Teclear el código de producto exige permiso (RW_CodProdEnConsultas de R3).
                if (!Sesion.Usuario.CodProdEnConsultas) { MostrarError("Escanea el código de barras: no tienes permiso para buscar por código de producto."); return; }
                respuesta = await Informes.GetProdPorCodAsync(_tipoElegido.Tipo, codAlm, codProd);
            }
            else
            {
                MostrarError("Introduce un código numérico (producto o EAN).");
                return;
            }

            if (!respuesta.Ok || respuesta.Datos is null) { MostrarError(respuesta.Error); return; }
            if (respuesta.Datos.Prod.CodProd <= 0) { MostrarError($"El código {codigo} no corresponde a ningún producto."); return; }

            _linea = respuesta.Datos;
            // Bloqueos del producto: aviso informativo, como los MsgBox de R3 (992-999).
            var bloqueos = new List<string>();
            if (_linea.Prod.BloqueoCompra) bloqueos.Add("compra");
            if (_linea.Prod.BloqueoPedAlm) bloqueos.Add("pedido a almacén");
            if (bloqueos.Count > 0)
            {
                _tipoAviso = "aviso";
                _aviso = $"{_linea.Prod.DescProd}: producto con bloqueo de {string.Join(" y ", bloqueos)}.";
            }
            // Precarga de los tipos con RellenarCampos (precios/valores de la BD).
            _cajas = _linea.Cajas ?? 0;
            _cant = _linea.Cant ?? 0;
            _precioA = _linea.PrecioA ?? 0;
            _precioB = _linea.PrecioB ?? 0;
            _precioC = _linea.PrecioC ?? 0;
            _valorA = _linea.ValorA ?? "";
            _valorB = _linea.ValorB ?? "";
            _valorC = _linea.ValorC ?? "";
            // Trazabilidad desde el código compuesto (R3): el lote precarga ValorC y la
            // cantidad embebida (peso de balanza) precarga la cantidad.
            if (parseado is { Lote: > 0 } && _valorC.Length == 0) _valorC = parseado.Lote.ToString();
            if (parseado is { TraeCantidad: true } && _cant == 0) _cant = parseado.Cant;
        }
        finally
        {
            _ocupado = false;
            StateHasChanged();
            await JS.InvokeVoidAsync("r5.seleccionar", "busquedaInforme");
        }
    }

    // Cajas × U/C rellena la cantidad para productos sin decimales (tbcajas de R3).
    private void CajasCambiadas()
    {
        if (_linea is null || _linea.Prod.DecimalesEnCant || _linea.Prod.UnidsCaja <= 0) return;
        if (_cajas > 0) _cant = _cajas * _linea.Prod.UnidsCaja;
    }

    private bool ValidarObligatorios(out string faltan)
    {
        var pendientes = new List<string>();
        if (_tipoElegido!.Cajas == 2 && _cajas <= 0) pendientes.Add("Cajas");
        if (_tipoElegido.Cant == 2 && _cant <= 0) pendientes.Add("Cantidad");
        if (_tipoElegido.AlmDest == 2 && _codAlmDest <= 0) pendientes.Add("Almacén destino");
        if (_tipoElegido.PrecioA == 2 && _precioA <= 0) pendientes.Add(Etiqueta(_tipoElegido.PrecioA_Desc, "Precio A"));
        if (_tipoElegido.PrecioB == 2 && _precioB <= 0) pendientes.Add(Etiqueta(_tipoElegido.PrecioB_Desc, "Precio B"));
        if (_tipoElegido.PrecioC == 2 && _precioC <= 0) pendientes.Add(Etiqueta(_tipoElegido.PrecioC_Desc, "Precio C"));
        if (_tipoElegido.ValorA == 2 && string.IsNullOrWhiteSpace(_valorA)) pendientes.Add(Etiqueta(_tipoElegido.ValorA_Desc, "Valor A"));
        if (_tipoElegido.ValorB == 2 && string.IsNullOrWhiteSpace(_valorB)) pendientes.Add(Etiqueta(_tipoElegido.ValorB_Desc, "Valor B"));
        if (_tipoElegido.ValorC == 2 && string.IsNullOrWhiteSpace(_valorC)) pendientes.Add(Etiqueta(_tipoElegido.ValorC_Desc, "Valor C"));
        faltan = string.Join(", ", pendientes);
        return pendientes.Count == 0;
    }

    private async Task AnadirAsync()
    {
        if (_anadiendo || _linea is null || _tipoElegido is null) return;
        if (!ValidarObligatorios(out string faltan))
        {
            MostrarError($"Faltan campos obligatorios: {faltan}.");
            return;
        }

        _anadiendo = true;
        _aviso = "";
        try
        {
            var alta = new InformeLinInsertDTO
            {
                CodUsuario = Sesion.Usuario!.CodUsuario,
                Tipo = _tipoElegido.Tipo,
                NumInforme = _numInforme,
                Fecha = _fecha,
                CodAlmOrigen = Sesion.Usuario.Almacen.CodAlm,
                CodAlmDest = _codAlmDest,
                CodProd = _linea.Prod.CodProd,
                Cajas = _cajas,
                Cant = _cant,
                PrecioA = _precioA,
                PrecioB = _precioB,
                PrecioC = _precioC,
                ValorA = _valorA,
                ValorB = _valorB,
                ValorC = _valorC,
                CodEan = _eanEscaneado
            };
            var respuesta = await Informes.PostLineaAsync(alta);
            if (!respuesta.Ok || respuesta.Datos is null) { MostrarError(respuesta.Error); return; }

            _numInforme = respuesta.Datos.NumDoc;
            _lineasAnadidas++;
            _tipoAviso = "exito";
            _aviso = $"{_linea.Prod.DescProd} añadido al informe {_numInforme}.";
            _linea = null;
            _codigo = "";
            _ = RefrescarLineasAsync();
        }
        finally
        {
            _anadiendo = false;
            StateHasChanged();
            await JS.InvokeVoidAsync("r5.seleccionar", "busquedaInforme");
        }
    }

    // Refresca el panel de líneas sin bloquear el siguiente escaneo (ApiWeb no lanza).
    private async Task RefrescarLineasAsync()
    {
        if (_numInforme <= 0) return;
        _cargandoLineas = true;
        var r = await Informes.GetLineasAsync(_numInforme);
        if (r.Ok && r.Datos is not null) _lineasDoc = r.Datos;
        _cargandoLineas = false;
        StateHasChanged();
    }

    private async Task RegistrarAsync()
    {
        if (_registrando || _numInforme <= 0) return;

        _registrando = true;
        _aviso = "";
        try
        {
            var respuesta = await Informes.RegistrarAsync(_numInforme);
            if (!respuesta.Ok) { MostrarError(respuesta.Error); return; }

            Nav.NavigateTo($"/informes/{_numInforme}");
        }
        finally
        {
            _registrando = false;
        }
    }

    private void MostrarError(string mensaje)
    {
        _tipoAviso = "error";
        _aviso = mensaje;
    }

    private void Volver() => Nav.NavigateTo("/informes");
}
