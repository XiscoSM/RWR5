@* Detalle de albarán: líneas con lo que se coteja en recepción — cantidades pedidas
   vs recibidas y precio neto. Consulta. *@
@page "/recepcionAlb/{FechaRuta}/{NumAlbaran:int}"
@inject AlbaranService Albaranes
@inject SesionUsuario Sesion
@inject NavigationManager Nav

<GuardiaModulo CodMenu="9">
<div class="r5-columna">

    <div class="r5-fila" style="flex-wrap: wrap;">
        <button class="r5-btn r5-btn--secundario" @onclick="Volver">← Albaranes</button>
        <h2>Albarán @NumAlbaran · @(Fecha(_fecha))</h2>
        @if (Reg is not null)
        {
            <span class="r5-badge @(_registrado ? "r5-badge--cerrado" : "r5-badge--abierto")">
                @(_registrado ? "Registrado" : "Pendiente")
            </span>
        }
        @* Solo se ofrece registrar lo que la bandeja marca como pendiente: un albarán ya
           registrado no debe invitar a un segundo registro. *@
        @if (Reg == 0 && !_registrado)
        {
            <button class="r5-btn r5-btn--primario" style="margin-left:auto"
                    @onclick="AbrirFormularioLink" disabled="@(_fecha is null || _cargando || _lineas.Count == 0)">
                Registrar recepción
            </button>
        }
    </div>

    @if (_registrado)
    {
        <Aviso Tipo="exito" Mensaje="@_avisoRegistro" />
    }

    @if (_pidiendoLink)
    {
        <form class="r5-tarjeta r5-columna r5-ancho-form" @onsubmit="RegistrarAsync">
            <h3>Link del documento</h3>
            <p class="r5-texto-suave r5-texto-sm">Escanea la etiqueta de link pegada al albarán en papel.</p>
            <input id="linkDoc" class="r5-input r5-input--numero" type="text" inputmode="numeric" maxlength="13"
                   @bind="_linkTexto" @bind:event="oninput" autofocus disabled="@_registrando" />
            <Aviso Tipo="@_tipoAvisoRegistro" Mensaje="@_avisoRegistro" />
            <div class="r5-fila">
                <button type="submit" class="r5-btn r5-btn--primario"
                        disabled="@(_registrando || !long.TryParse(_linkTexto, out _))">
                    @(_registrando ? "Registrando…" : "Confirmar registro")
                </button>
                <button type="button" class="r5-btn r5-btn--fantasma" @onclick="() => _pidiendoLink = false">Cancelar</button>
            </div>
        </form>
    }

    @if (_fecha is null)
    {
        <Aviso Mensaje="La fecha del albarán no es válida." />
    }
    else if (_cargando)
    {
        <Cargando Texto="Cargando líneas…" />
    }
    else if (!string.IsNullOrEmpty(_error))
    {
        <Aviso Mensaje="@_error" />
    }
    else if (_lineas.Count == 0)
    {
        <div class="r5-cargando">
            <Icono Nombre="recepcion" Clase="r5-modulo__icono" />
            <span>El albarán no tiene líneas.</span>
        </div>
    }
    else
    {
        <div class="r5-tarjeta r5-tabla-scroll">
            <table class="r5-tabla">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th class="num">Cajas</th>
                        <th class="num">Cantidad</th>
                        <th class="num">Pedida</th>
                        <th class="num">Recibida</th>
                        <th class="num">PNC</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var linea in _lineas)
                    {
                        <tr @key="linea.Linea">
                            <td>
                                <div class="r5-doc__principal">
                                    <span>@linea.Prod.DescProd</span>
                                    <span class="r5-doc__detalle">@linea.Prod.CodProd</span>
                                </div>
                            </td>
                            <td class="num">@linea.Cajas</td>
                            <td class="num">@Cantidad(linea.Cant, linea.Prod.DecimalesEnCant)</td>
                            <td class="num">@Cantidad(linea.CantPedida, linea.Prod.DecimalesEnCant)</td>
                            <td class="num">@Cantidad(linea.CantRecibida, linea.Prod.DecimalesEnCant)</td>
                            <td class="num">@Moneda((decimal)linea.PNC)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <p class="r5-texto-suave r5-texto-sm">@_lineas.Count líneas.</p>
    }
</div>
</GuardiaModulo>

@code {
    [Parameter] public string FechaRuta { get; set; } = "";
    [Parameter] public int NumAlbaran { get; set; }

    /// <summary>Estado desde la bandeja (0=pendiente, 1=registrado); null en deep-link = solo consulta.</summary>
    [Parameter, SupplyParameterFromQuery(Name = "reg")] public int? Reg { get; set; }

    private DateTime? _fecha;
    private bool _cargando = true;
    private string _error = "";
    private List<AlbaranLin> _lineas = new();

    private bool _pidiendoLink;
    private bool _registrando;
    private bool _registrado;
    private string _linkTexto = "";
    private string _avisoRegistro = "";
    private string _tipoAvisoRegistro = "error";

    // Abre el formulario de link con el campo limpio y enfocado (lectura de escáner).
    private void AbrirFormularioLink()
    {
        _pidiendoLink = !_pidiendoLink;
        _linkTexto = "";
        _avisoRegistro = "";
    }

    // Registrar la recepción pendiente: exige el link del documento en papel.
    private async Task RegistrarAsync()
    {
        if (_registrando || _fecha is null || !long.TryParse(_linkTexto, out long link) || link <= 0) return;

        _registrando = true;
        _avisoRegistro = "";
        try
        {
            var respuesta = await Albaranes.RegistrarAsync(NumAlbaran, _fecha.Value, Sesion.Usuario!.CodUsuario, link);
            if (!respuesta.Ok)
            {
                _tipoAvisoRegistro = "error";
                _avisoRegistro = respuesta.Error;
                _linkTexto = ""; // el siguiente escaneo no debe concatenar sobre el link fallido
                return;
            }
            _registrado = true;
            _pidiendoLink = false;
            _tipoAvisoRegistro = "exito";
            _avisoRegistro = $"Albarán {NumAlbaran} registrado.";
        }
        finally
        {
            _registrando = false;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (!Sesion.Autenticado) return;
        _registrado = Reg == 1;

        if (!DateTime.TryParseExact(FechaRuta, "yyyy-MM-dd", null,
            System.Globalization.DateTimeStyles.None, out var fecha))
        {
            _fecha = null;
            _cargando = false;
            return;
        }
        _fecha = fecha;

        try
        {
            // Cabecera + líneas en paralelo. La cabecera del servidor manda sobre el ?reg=
            // de la bandeja: el deep-link sin query también muestra estado y acción correctos.
            var tCab = Albaranes.GetCabeceraAsync(NumAlbaran, fecha);
            var tLin = Albaranes.GetLineasAsync(NumAlbaran, fecha);
            await Task.WhenAll(tCab, tLin);

            if (tCab.Result.Ok && tCab.Result.Datos is { NumAlbaran: > 0 } cab)
            {
                Reg = cab.Reg ? 1 : 0;
                _registrado = cab.Reg;
            }

            if (!tLin.Result.Ok)
            {
                _error = tLin.Result.Error;
                return;
            }
            _lineas = tLin.Result.Datos ?? new();
        }
        finally
        {
            _cargando = false;
        }
    }

    private void Volver() => Nav.NavigateTo("/recepcionAlb");
}
