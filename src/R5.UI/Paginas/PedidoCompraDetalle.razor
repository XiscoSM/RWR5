@* Detalle de pedido a proveedor: líneas con cantidades, recibido, precio y stock. Consulta. *@
@page "/pedidoCompra/{NumPedido:int}"
@inject PedidoCompraService Pedidos
@inject SesionUsuario Sesion
@inject NavigationManager Nav

<GuardiaModulo CodMenu="8">
<div class="r5-columna">

    <div class="r5-fila">
        <button class="r5-btn r5-btn--secundario" @onclick="Volver">← Pedidos</button>
        <h2>Pedido @NumPedido</h2>
        @if (_lineas.Count > 0)
        {
            <div class="r5-fila" style="margin-left:auto">
                @if (!_confirmarMail)
                {
                    <button class="r5-btn r5-btn--secundario" @onclick="() => _confirmarMail = true" disabled="@_enviandoMail">
                        Enviar al proveedor
                    </button>
                }
                else
                {
                    <span class="r5-texto-suave">¿Encolar el mail al proveedor?</span>
                    <button class="r5-btn r5-btn--primario" @onclick="EnviarMailAsync" disabled="@_enviandoMail">
                        @(_enviandoMail ? "Enviando…" : "Sí, enviar")
                    </button>
                    <button class="r5-btn r5-btn--fantasma" @onclick="() => _confirmarMail = false" disabled="@_enviandoMail">No</button>
                }
            </div>
        }
    </div>

    <Aviso Tipo="@_tipoAviso" Mensaje="@_aviso" />

    @if (_cargando)
    {
        <Cargando Texto="Cargando líneas…" />
    }
    else if (!string.IsNullOrEmpty(_error))
    {
        <Aviso Mensaje="@_error" />
    }
    else if (_lineas.Count == 0)
    {
        <div class="r5-cargando">
            <Icono Nombre="pedido-compra" Clase="r5-modulo__icono" />
            <span>El pedido no tiene líneas.</span>
        </div>
    }
    else
    {
        <div class="r5-tarjeta">
            <table class="r5-tabla">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th class="num">Cajas</th>
                        <th class="num">Cantidad</th>
                        <th class="num">Recibida</th>
                        <th class="num">PNC</th>
                        <th class="num">Stock</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var linea in _lineas)
                    {
                        <tr @key="linea.Linea">
                            <td>
                                <div class="r5-doc__principal">
                                    <span>@linea.Prod.DescProd</span>
                                    <span class="r5-doc__detalle">@linea.Prod.CodProd</span>
                                </div>
                            </td>
                            <td class="num">@linea.Cajas</td>
                            <td class="num">@Cantidad(linea.Cant, linea.Prod.DecimalesEnCant)</td>
                            <td class="num">@Cantidad(linea.CantRecibida, linea.Prod.DecimalesEnCant)</td>
                            <td class="num">@Moneda(linea.PNC)</td>
                            <td class="num">@Cantidad(linea.Stock, linea.Prod.DecimalesEnCant)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <p class="r5-texto-suave r5-texto-sm">@_lineas.Count líneas.</p>
    }
</div>
</GuardiaModulo>

@code {
    [Parameter] public int NumPedido { get; set; }

    private bool _cargando = true;
    private string _error = "";
    private List<PedidoCompraLin> _lineas = new();

    private bool _confirmarMail;
    private bool _enviandoMail;
    private string _aviso = "";
    private string _tipoAviso = "error";

    protected override async Task OnInitializedAsync()
    {
        if (!Sesion.Autenticado) return;

        try
        {
            var respuesta = await Pedidos.GetLineasAsync(NumPedido);
            if (!respuesta.Ok)
            {
                _error = respuesta.Error;
                return;
            }
            _lineas = respuesta.Datos ?? new();
        }
        finally
        {
            _cargando = false;
        }
    }

    // Encola el mail en RW (cola de correo del ERP); el envío real lo hace el servidor.
    private async Task EnviarMailAsync()
    {
        if (_enviandoMail || !Sesion.Autenticado) return;

        _enviandoMail = true;
        _aviso = "";
        try
        {
            var respuesta = await Pedidos.EnviarMailAsync(NumPedido, Sesion.Usuario!.CodUsuario);
            if (!respuesta.Ok)
            {
                _tipoAviso = "error";
                _aviso = respuesta.Error;
                return;
            }
            _tipoAviso = "exito";
            _aviso = string.IsNullOrWhiteSpace(respuesta.Datos)
                ? $"Pedido {NumPedido} encolado para envío al proveedor."
                : respuesta.Datos;
            _confirmarMail = false;
        }
        finally
        {
            _enviandoMail = false;
        }
    }

    private void Volver() => Nav.NavigateTo("/pedidoCompra");
}
