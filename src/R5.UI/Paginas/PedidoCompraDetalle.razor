@* Detalle de pedido a proveedor: líneas con cantidades, recibido, precio y stock. Consulta. *@
@page "/pedidoCompra/{NumPedido:int}"
@inject PedidoCompraService Pedidos
@inject SesionUsuario Sesion
@inject NavigationManager Nav

<GuardiaModulo CodMenu="8">
<div class="r5-columna">

    <div class="r5-fila" style="flex-wrap: wrap;">
        <button class="r5-btn r5-btn--secundario" @onclick="Volver">← Pedidos</button>
        <h2>Pedido @NumPedido</h2>
        @if (Reg is not null)
        {
            <span class="r5-badge @(_registrado ? "r5-badge--cerrado" : "r5-badge--abierto")">
                @(_registrado ? "Registrado" : "Pendiente")
            </span>
        }
        @if (_lineas.Count > 0)
        {
            <div class="r5-fila" style="margin-left:auto; flex-wrap: wrap;">
                @if (Reg == 0 && !_registrado)
                {
                    @* Pendiente: la acción del detalle es completar el registro (envío previsto mañana). *@
                    <div class="r5-campo">
                        <label for="fechaPrevEnvio">Envío previsto</label>
                        <input id="fechaPrevEnvio" class="r5-input" type="date" @bind="_fechaPrevEnvio" disabled="@_registrando" />
                    </div>
                    <BotonConfirmar Texto="Registrar pedido"
                                    Pregunta="@($"¿Registrar el pedido {NumPedido} con {_lineas.Count} líneas? No se puede deshacer.")"
                                    TextoOcupado="Registrando…" Ocupado="@_registrando"
                                    OnConfirmar="RegistrarAsync" />
                }
                else if (Reg is null || _registrado)
                {
                    @* El mail al proveedor solo tiene sentido con el pedido registrado. *@
                    <BotonConfirmar Texto="Enviar al proveedor"
                                    Pregunta="¿Encolar el mail al proveedor?"
                                    TextoOcupado="Enviando…" Ocupado="@_enviandoMail"
                                    OnConfirmar="EnviarMailAsync" />
                }
            </div>
        }
    </div>

    <Aviso Tipo="@_tipoAviso" Mensaje="@_aviso" />

    @if (_cargando)
    {
        <Cargando Texto="Cargando líneas…" />
    }
    else if (!string.IsNullOrEmpty(_error))
    {
        <Aviso Mensaje="@_error" />
    }
    else if (_lineas.Count == 0)
    {
        <div class="r5-cargando">
            <Icono Nombre="pedido-compra" Clase="r5-modulo__icono" />
            <span>El pedido no tiene líneas.</span>
        </div>
    }
    else
    {
        <div class="r5-tarjeta r5-tabla-scroll">
            <table class="r5-tabla">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th class="num">Cajas</th>
                        <th class="num">Cantidad</th>
                        <th class="num">Recibida</th>
                        <th class="num">PNC</th>
                        <th class="num">Stock</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var linea in _lineas)
                    {
                        <tr @key="linea.Linea">
                            <td>
                                <div class="r5-doc__principal">
                                    <span>@linea.Prod.DescProd</span>
                                    <span class="r5-doc__detalle">@linea.Prod.CodProd</span>
                                </div>
                            </td>
                            <td class="num">@linea.Cajas</td>
                            <td class="num">@Cantidad(linea.Cant, linea.Prod.DecimalesEnCant)</td>
                            <td class="num">@Cantidad(linea.CantRecibida, linea.Prod.DecimalesEnCant)</td>
                            <td class="num">@Moneda(linea.PNC)</td>
                            <td class="num">@Cantidad(linea.Stock, linea.Prod.DecimalesEnCant)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <p class="r5-texto-suave r5-texto-sm">@_lineas.Count líneas.</p>
    }
</div>
</GuardiaModulo>

@code {
    [Parameter] public int NumPedido { get; set; }

    /// <summary>Estado desde la bandeja (0=pendiente, 1=registrado); null en deep-link.</summary>
    [Parameter, SupplyParameterFromQuery(Name = "reg")] public int? Reg { get; set; }

    private bool _cargando = true;
    private string _error = "";
    private List<PedidoCompraLin> _lineas = new();

    private bool _registrado;
    private bool _registrando;
    private DateTime _fechaPrevEnvio = DateTime.Today.AddDays(1);
    private bool _enviandoMail;
    private string _aviso = "";
    private string _tipoAviso = "error";

    // Registra el pedido pendiente (irreversible); después ya se puede enviar al proveedor.
    private async Task RegistrarAsync()
    {
        if (_registrando || !Sesion.Autenticado) return;

        _registrando = true;
        _aviso = "";
        try
        {
            var respuesta = await Pedidos.RegistrarAsync(NumPedido, Sesion.Usuario!.CodUsuario, _fechaPrevEnvio);
            if (!respuesta.Ok)
            {
                _tipoAviso = "error";
                _aviso = respuesta.Error;
                return;
            }
            _registrado = true;
            _tipoAviso = "exito";
            _aviso = $"Pedido {NumPedido} registrado. Ya puedes enviarlo al proveedor.";
        }
        finally
        {
            _registrando = false;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (!Sesion.Autenticado) return;
        _registrado = Reg == 1;

        try
        {
            // Cabecera + líneas en paralelo. La cabecera del servidor manda sobre el
            // estado que pasó la bandeja (?reg=): así el deep-link sin query también
            // muestra el badge y ofrece la acción correcta.
            var tCab = Pedidos.GetCabeceraAsync(NumPedido);
            var tLin = Pedidos.GetLineasAsync(NumPedido);
            await Task.WhenAll(tCab, tLin);

            if (tCab.Result.Ok && tCab.Result.Datos is { NumPedido: > 0 } cab)
            {
                Reg = cab.Reg ? 1 : 0;
                _registrado = cab.Reg;
            }

            if (!tLin.Result.Ok)
            {
                _error = tLin.Result.Error;
                return;
            }
            _lineas = tLin.Result.Datos ?? new();
        }
        finally
        {
            _cargando = false;
        }
    }

    // Encola el mail en RW (cola de correo del ERP); el envío real lo hace el servidor.
    private async Task EnviarMailAsync()
    {
        if (_enviandoMail || !Sesion.Autenticado) return;

        _enviandoMail = true;
        _aviso = "";
        try
        {
            var respuesta = await Pedidos.EnviarMailAsync(NumPedido, Sesion.Usuario!.CodUsuario);
            if (!respuesta.Ok)
            {
                _tipoAviso = "error";
                _aviso = respuesta.Error;
                return;
            }
            _tipoAviso = "exito";
            _aviso = string.IsNullOrWhiteSpace(respuesta.Datos)
                ? $"Pedido {NumPedido} encolado para envío al proveedor."
                : respuesta.Datos;
        }
        finally
        {
            _enviandoMail = false;
        }
    }

    private void Volver() => Nav.NavigateTo("/pedidoCompra");
}
