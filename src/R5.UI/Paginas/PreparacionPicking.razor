@* Picking de preparación: el preparador recorre el almacén central siguiendo el
   orden de ubicación. La pantalla muestra UNA línea grande (ubicación, producto,
   lo pedido y el stock), se confirma la cantidad preparada (por defecto lo pedido)
   y se salta a la siguiente. Cada confirmación graba una línea de traspaso
   central→tienda ligada al pedido (mismo modelo que RWR4/R3).
   Escanear un EAN valida que el producto en mano es el de la línea. *@
@page "/preparacion/{FechaRuta}/{Pedido:int}/picking"
@inject PreparacionService Preparaciones
@inject TraspasoService Traspasos
@inject SesionUsuario Sesion
@inject NavigationManager Nav
@inject IJSRuntime JS

<GuardiaModulo CodMenu="24">
<div class="r5-columna">

    <div class="r5-fila">
        <button class="r5-btn r5-btn--secundario" @onclick="Volver">← Pedido @Pedido</button>
        <h2>Preparando · @(_cabecera?.Alm.DescAlm)</h2>
        <div class="r5-fila" style="margin-left:auto">
            <span class="r5-chip" style="background: var(--c-primario-claro); color: var(--c-primario-osc);">
                @_preparadasSesion preparadas
            </span>
            <button class="r5-btn r5-btn--secundario" @onclick="RegistrarAsync" disabled="@(_ocupado || _cabecera is null)">Registrar</button>
            @* Finalizar exige el control de cuadre de R3: teclear cuántos productos quedan
               pendientes y cotejarlo contra el contador real del pedido. *@
            <button class="r5-btn r5-btn--primario" @onclick="AbrirFinalizarAsync"
                    disabled="@(_ocupado || _cabecera is null)">Finalizar</button>
        </div>
    </div>

    @if (_verificandoFinal)
    {
        <form class="r5-tarjeta r5-columna r5-ancho-form" @onsubmit="FinalizarVerificadoAsync">
            <h3>Finalizar preparación del pedido @Pedido</h3>
            <p class="r5-texto-suave r5-texto-sm">
                Control de cuadre: cuenta los productos que quedan SIN preparar y teclea el número.
                Productos preparados hasta ahora: <strong>@(_cabecera?.Preparados)</strong>.
            </p>
            <div class="r5-campo" style="max-width: 240px;">
                <label for="pendientesFin">Productos pendientes</label>
                <input id="pendientesFin" class="r5-input r5-input--numero" type="number" inputmode="numeric" min="0"
                       @bind="_pendientesTecleados" disabled="@_ocupado" />
            </div>
            <div class="r5-fila">
                <button type="submit" class="r5-btn r5-btn--primario" disabled="@(_ocupado || _pendientesTecleados is null)">
                    @(_ocupado ? "Finalizando…" : "Confirmar y finalizar")
                </button>
                <button type="button" class="r5-btn r5-btn--fantasma" @onclick="() => _verificandoFinal = false">Cancelar</button>
            </div>
        </form>
    }

    <Aviso Tipo="@_tipoAviso" Mensaje="@_aviso" />

    @* Controles del recorrido de R3: ver todas las líneas (no solo pendientes),
       saltar a un pasillo concreto y añadir un producto no incluido en el pedido. *@
    <div class="r5-fila" style="flex-wrap: wrap;">
        <label class="r5-fila" style="gap: var(--esp-2); cursor: pointer;">
            <input type="checkbox" checked="@_verTodos" @onchange="ToggleVerTodosAsync" />
            <span class="r5-texto-suave">Ver todas las líneas (no solo pendientes)</span>
        </label>
        <button class="r5-btn r5-btn--fantasma" @onclick="TogglePasillosAsync" disabled="@_ocupado">
            @(_verPasillos ? "Ocultar pasillos" : "Pasillos")
        </button>
        <button class="r5-btn r5-btn--fantasma" @onclick="() => _verProdNuevo = !_verProdNuevo">
            + Producto no incluido
        </button>
    </div>

    @if (_verPasillos && _pasillos.Count > 0)
    {
        <div class="r5-fila" style="flex-wrap: wrap;">
            @foreach (var p in _pasillos)
            {
                <button @key="p.Pasillo" class="r5-btn r5-btn--secundario" @onclick="() => IrAPasilloAsync(p)">
                    Pasillo @p.Pasillo · @p.CountProdPreparados/@p.CountProdPedidos
                </button>
            }
        </div>
    }

    @if (_verProdNuevo)
    {
        <form class="r5-tarjeta r5-columna r5-ancho-form" @onsubmit="AnadirProdNuevoAsync">
            <h3>Añadir producto no incluido en el pedido</h3>
            <div class="r5-fila">
                <div class="r5-campo" style="flex:1">
                    <label for="prodNuevo">Código de producto</label>
                    <input id="prodNuevo" class="r5-input r5-input--numero" type="text" inputmode="numeric"
                           @bind="_prodNuevoTexto" disabled="@_ocupado" />
                </div>
                <div class="r5-campo" style="flex:1">
                    <label for="cantNueva">Cantidad pedida</label>
                    <input id="cantNueva" class="r5-input r5-input--numero" type="number" inputmode="decimal" min="0.001" step="0.001"
                           @bind="_cantNueva" disabled="@_ocupado" />
                </div>
            </div>
            <div class="r5-fila">
                <button type="submit" class="r5-btn r5-btn--secundario"
                        disabled="@(_ocupado || string.IsNullOrWhiteSpace(_prodNuevoTexto) || _cantNueva <= 0)">Añadir al pedido</button>
                <button type="button" class="r5-btn r5-btn--fantasma" @onclick="() => _verProdNuevo = false">Cancelar</button>
            </div>
        </form>
    }

    @if (_fecha is null)
    {
        <Aviso Mensaje="La fecha del pedido no es válida." />
    }
    else if (_cargando)
    {
        <Cargando Texto="Buscando siguiente línea…" />
    }
    else if (_linea is null && _tipoAviso != "error")
    {
        @* Fin de recorrido real: solo si no venimos de un error de carga (un fallo de red
           no debe invitar a finalizar un pedido que ni se ha podido leer). *@
        <div class="r5-cargando">
            <Icono Nombre="ok" Clase="r5-modulo__icono" />
            <span>No quedan líneas pendientes en el recorrido. Puedes Registrar o Finalizar.</span>
        </div>
    }
    else if (_linea is null)
    {
        <div class="r5-fila">
            <button class="r5-btn r5-btn--secundario" @onclick='() => SiguienteAsync(0, "0")'>Reintentar</button>
        </div>
    }
    else
    {
        <div class="r5-tarjeta r5-columna">
            <div class="r5-fila">
                <span class="r5-badge r5-badge--neutro" style="font-size: var(--texto-lg);">
                    Ubicación @_linea.Prod.Ubicacion
                </span>
                <div class="r5-fila" style="margin-left:auto">
                    <button class="r5-btn r5-btn--fantasma" @onclick="AnteriorAsync" disabled="@_ocupado">← Anterior</button>
                    <button class="r5-btn r5-btn--fantasma" @onclick="() => SiguienteAsync(_linea.Prod.CodProd, _linea.Prod.Ubicacion)" disabled="@_ocupado">Saltar →</button>
                </div>
            </div>

            <div class="r5-ficha__identidad">
                <span class="r5-ficha__codigo">@_linea.Prod.CodProd</span>
                <span class="r5-ficha__nombre">@_linea.Prod.DescProd</span>
            </div>

            <dl class="r5-datos">
                <div><dt>Cajas pedidas</dt><dd>@_linea.CajasPedidas</dd></div>
                <div><dt>Cantidad pedida</dt><dd>@Cantidad(_linea.CantPedida, _linea.Prod.DecimalesEnCant)</dd></div>
                @if (_linea.CantEnviada > 0)
                {
                    <div><dt>Ya preparada</dt><dd>@Cantidad(_linea.CantEnviada, _linea.Prod.DecimalesEnCant)</dd></div>
                }
                <div><dt>Stock central</dt><dd>@Cantidad(_linea.StockCentral, _linea.Prod.DecimalesEnCant)</dd></div>
            </dl>

            <form @onsubmit="ValidarEscaneoAsync" class="r5-buscador">
                <input id="escaneoPicking" class="r5-input" type="text" inputmode="numeric"
                       placeholder="Escanea el producto para validar (opcional)"
                       @bind="_escaneo" @bind:event="oninput" />
                <button type="submit" class="r5-btn r5-btn--secundario" disabled="@string.IsNullOrWhiteSpace(_escaneo)">Validar</button>
            </form>

            <div class="r5-fila">
                <div class="r5-campo" style="flex:1">
                    <label for="cajasPick">Cajas</label>
                    <input id="cajasPick" class="r5-input r5-input--numero" type="text" inputmode="numeric" min="0"
                           value="@_cajas" @oninput="CambioCajas" />
                </div>
                <div class="r5-campo" style="flex:1">
                    <label for="cantPick">Cantidad preparada</label>
                    <input id="cantPick" class="r5-input r5-input--numero" type="number" inputmode="decimal"
                           step="@(_linea.Prod.DecimalesEnCant ? "0.001" : "1")" min="0"
                           @bind="_cantidad" @bind:event="oninput" />
                </div>
            </div>

            <button class="r5-btn r5-btn--primario r5-btn--bloque" @onclick="ConfirmarAsync"
                    disabled="@(_ocupado || _cantidad <= 0)">
                @(_ocupado ? "Grabando…" : $"Confirmar {Cantidad(_cantidad, _linea.Prod.DecimalesEnCant)} y seguir")
            </button>
        </div>
    }
</div>
</GuardiaModulo>

@code {
    [Parameter] public string FechaRuta { get; set; } = "";
    [Parameter] public int Pedido { get; set; }

    private DateTime? _fecha;
    private PrepPedCentral? _cabecera;
    private PrepPedCentralLin? _linea;
    private bool _cargando = true;
    private bool _ocupado;
    private string _aviso = "";
    private string _tipoAviso = "error";
    private string _escaneo = "";
    private short _cajas;
    private decimal _cantidad;
    private int _preparadasSesion;

    private short UnidsCaja => _linea is null || _linea.Prod.UnidsCaja <= 0 ? (short)1 : _linea.Prod.UnidsCaja;

    protected override async Task OnInitializedAsync()
    {
        if (!DateTime.TryParseExact(FechaRuta, "yyyy-MM-dd", null,
            System.Globalization.DateTimeStyles.None, out var fecha))
        {
            _fecha = null;
            _cargando = false;
            return;
        }
        _fecha = fecha;

        var usuario = Sesion.Usuario!;
        var cabecera = await Preparaciones.GetAsync(fecha, Pedido, usuario.CodUsuario, usuario.Almacen.SoloConStock);
        if (!cabecera.Ok || cabecera.Datos is null)
        {
            MostrarError(cabecera.Error);
            _cargando = false;
            return;
        }
        _cabecera = cabecera.Datos;

        await SiguienteAsync(0, "0");
    }

    private async Task SiguienteAsync(int codProdActual, string ubicacion)
    {
        if (_fecha is null) return;

        _cargando = true;
        _linea = null;
        try
        {
            var usuario = Sesion.Usuario!;
            var respuesta = await Preparaciones.GetLineaSiguienteAsync(
                _fecha.Value, Pedido, usuario.CodUsuario, usuario.Almacen.SoloConStock, codProdActual, ubicacion, _verTodos);
            if (!respuesta.Ok) { MostrarError(respuesta.Error); return; }

            if (respuesta.Datos is null || respuesta.Datos.Prod.CodProd <= 0)
            {
                _linea = null; // fin del recorrido
                return;
            }
            PrepararLinea(respuesta.Datos);
        }
        finally
        {
            _cargando = false;
            // El escaneo de validación de la nueva línea no debe requerir tocar la pantalla.
            StateHasChanged();
            if (_linea is not null) await JS.InvokeVoidAsync("r5.seleccionar", "escaneoPicking");
        }
    }

    private async Task AnteriorAsync()
    {
        if (_fecha is null || _linea is null) return;

        _cargando = true;
        try
        {
            var usuario = Sesion.Usuario!;
            var respuesta = await Preparaciones.GetLineaAnteriorAsync(
                _fecha.Value, Pedido, usuario.CodUsuario, usuario.Almacen.SoloConStock,
                _linea.Prod.CodProd, _linea.Prod.Ubicacion, _verTodos);
            if (!respuesta.Ok) { MostrarError(respuesta.Error); return; }
            if (respuesta.Datos is not null && respuesta.Datos.Prod.CodProd > 0) PrepararLinea(respuesta.Datos);
        }
        finally
        {
            _cargando = false;
            StateHasChanged();
            if (_linea is not null) await JS.InvokeVoidAsync("r5.seleccionar", "escaneoPicking");
        }
    }

    // ---- Controles del recorrido de R3 (ver todos / pasillos / producto nuevo) ----
    private bool _verTodos;
    private bool _verPasillos;
    private List<PrepPedCentralPasillo> _pasillos = new();
    private bool _verProdNuevo;
    private string _prodNuevoTexto = "";
    private decimal _cantNueva = 1;

    // Alternar todos/pendientes reinicia el recorrido con el nuevo criterio.
    private async Task ToggleVerTodosAsync(ChangeEventArgs e)
    {
        _verTodos = e.Value is bool b && b;
        await SiguienteAsync(0, "0");
    }

    private async Task TogglePasillosAsync()
    {
        if (_verPasillos) { _verPasillos = false; return; }
        if (_fecha is null || !Sesion.Autenticado) return;
        var usuario = Sesion.Usuario!;
        var r = await Preparaciones.GetPasillosAsync(_fecha.Value, Pedido, usuario.CodUsuario,
            usuario.Almacen.SoloConStock, usuario.Almacen.NumDigitosPasillo);
        if (!r.Ok) { MostrarError(r.Error); return; }
        _pasillos = r.Datos ?? new();
        _verPasillos = _pasillos.Count > 0;
        if (!_verPasillos) MostrarError("El pedido no tiene pasillos con líneas.");
    }

    // Saltar al primer producto del pasillo: se reposiciona el recorrido en su ubicación.
    private async Task IrAPasilloAsync(PrepPedCentralPasillo p)
    {
        _verPasillos = false;
        await SiguienteAsync(0, p.Pasillo);
    }

    // Alta de producto no incluido en el pedido (PROC_PedidoCentralLin_InsertNuevo de R3).
    private async Task AnadirProdNuevoAsync()
    {
        if (_ocupado || _fecha is null || _cabecera is null || !Sesion.Autenticado) return;
        if (!int.TryParse(_prodNuevoTexto.Trim(), out int codProd) || codProd <= 0)
        { MostrarError("Código de producto no válido."); return; }
        if (_cantNueva <= 0 || _cantNueva >= 10000) { MostrarError("Cantidad no válida."); return; }

        _ocupado = true;
        _aviso = "";
        try
        {
            var usuario = Sesion.Usuario!;
            var r = await Preparaciones.PostLineaNuevaAsync(new PrepPedCentralLinInsertDTO
            {
                CodProd = codProd,
                CodUsuario = usuario.CodUsuario,
                CodAlm = _cabecera.Alm.CodAlm,
                CodAlmCentral = usuario.Almacen.CodAlm,
                CantPedida = _cantNueva,
                Fecha = _fecha.Value,
                NumPedido = Pedido
            });
            if (!r.Ok) { MostrarError(r.Error); return; }

            _tipoAviso = "exito";
            _aviso = $"Producto {codProd} añadido al pedido con {Cantidad(_cantNueva, true)}.";
            _verProdNuevo = false;
            _prodNuevoTexto = "";
            _cantNueva = 1;
            // El recorrido se reinicia para que la línea nueva entre en él.
            await SiguienteAsync(0, "0");
        }
        finally
        {
            _ocupado = false;
        }
    }

    private void PrepararLinea(PrepPedCentralLin linea)
    {
        _linea = linea;
        _escaneo = "";
        decimal pendiente = linea.CantPedida - linea.CantEnviada;
        _cantidad = pendiente > 0 ? pendiente : linea.CantPedida;
        _cajas = (short)(linea.CajasPedidas - linea.CajasEnviadas > 0 ? linea.CajasPedidas - linea.CajasEnviadas : linea.CajasPedidas);
    }

    private void CambioCajas(ChangeEventArgs e)
    {
        if (short.TryParse(e.Value?.ToString(), out short cajas) && cajas >= 0)
        {
            _cajas = cajas;
            _cantidad = cajas * UnidsCaja;
        }
    }

    // El escaneo compara el producto en mano con la línea actual: evita preparar lo que no toca.
    private async Task ValidarEscaneoAsync()
    {
        if (_linea is null || _fecha is null || string.IsNullOrWhiteSpace(_escaneo)) return;

        var usuario = Sesion.Usuario!;
        long.TryParse(_escaneo.Trim(), out long ean);
        var respuesta = await Traspasos.GetLineaProductoAsync(0, DateTime.Today,
            usuario.Almacen.CodAlm, _cabecera!.Alm.CodAlm, 0, ean, _fecha, Pedido);

        if (respuesta.Ok && respuesta.Datos?.Prod.CodProd == _linea.Prod.CodProd)
        {
            _tipoAviso = "exito";
            _aviso = "Producto correcto.";
        }
        else
        {
            MostrarError($"El escaneo NO corresponde a {_linea.Prod.DescProd}.");
        }
        _escaneo = "";
        await JS.InvokeVoidAsync("r5.seleccionar", "escaneoPicking");
    }

    // Confirmar = grabar línea de traspaso central→tienda ligada al pedido, y pasar a la siguiente.
    private async Task ConfirmarAsync()
    {
        if (_ocupado || _linea is null || _fecha is null || _cabecera is null || _cantidad <= 0) return;

        // Tope de sanidad: una lectura del escaner caida en el campo cantidad (>=10.000)
        // no puede acabar grabada como unidades.
        if (_cantidad >= 10000) { MostrarError($"Cantidad {_cantidad} no valida: ¿has escaneado un codigo en el campo de cantidad?"); return; }

        // Cajas coherentes con la cantidad preparada (por si se editó la cantidad a mano).
        _cajas = (short)Math.Ceiling(_cantidad / UnidsCaja);

        _ocupado = true;
        _aviso = "";
        try
        {
            var usuario = Sesion.Usuario!;

            // Coste para el importe de la línea (obligatorio en el proc de traspasos).
            // Si no se puede leer, se aborta: grabar la línea con importe 0 corrompe el
            // dato económico en silencio.
            var lineaTraspaso = await Traspasos.GetLineaProductoAsync(0, DateTime.Today,
                usuario.Almacen.CodAlm, _cabecera.Alm.CodAlm, _linea.Prod.CodProd, 0, _fecha, Pedido);
            if (!lineaTraspaso.Ok || lineaTraspaso.Datos is null)
            {
                MostrarError($"No se pudo obtener el coste del producto ({lineaTraspaso.Error}). Reintenta la confirmación.");
                return;
            }
            decimal coste = lineaTraspaso.Datos.Prod.UltPrecioCoste;

            var alta = new TraspLinInsertDTO
            {
                Fecha = DateTime.Today,
                NumTraspaso = 0,
                CodAlmOrigen = usuario.Almacen.CodAlm,
                CodAlmDest = _cabecera.Alm.CodAlm,
                CodProd = _linea.Prod.CodProd,
                CodEan = _linea.Ean.CodEan ?? 0,
                Cajas = _cajas,
                UnidCaja = UnidsCaja,
                Cant = _cantidad,
                Importe = Math.Round(_cantidad * coste, 2),
                CodUsuario = usuario.CodUsuario,
                Lote = _linea.Prod.Lote ?? 0,
                Registrado = false,
                FechaPedido = _fecha.Value,
                NumPedido = Pedido
            };
            var respuesta = await Traspasos.PostLineaAsync(alta);
            if (!respuesta.Ok) { MostrarError(respuesta.Error); return; }

            _preparadasSesion++;
            _tipoAviso = "exito";
            _aviso = $"{_linea.Prod.DescProd}: {Cantidad(_cantidad, _linea.Prod.DecimalesEnCant)} preparado.";

            int prodActual = _linea.Prod.CodProd;
            string ubicacion = _linea.Prod.Ubicacion;
            await SiguienteAsync(prodActual, ubicacion);
        }
        finally
        {
            _ocupado = false;
        }
    }

    // Registrar consolida lo preparado; el pedido sigue asignado.
    private async Task RegistrarAsync()
    {
        if (_ocupado || _fecha is null) return;
        _ocupado = true;
        try
        {
            var respuesta = await Preparaciones.RegistrarAsync(_fecha.Value, Pedido, Sesion.Usuario!.CodUsuario);
            if (!respuesta.Ok) { MostrarError(respuesta.Error); return; }
            _tipoAviso = "exito";
            _aviso = "Preparación registrada.";
        }
        finally
        {
            _ocupado = false;
        }
    }

    // --- Finalizar con control de cuadre (paridad R3: Bfinalizar_Click) ---
    private bool _verificandoFinal;
    private int? _pendientesTecleados;

    // Abre la verificación con el contador de pendientes RECIÉN leído del servidor
    // (la cabecera en memoria puede estar desfasada tras el picking).
    private async Task AbrirFinalizarAsync()
    {
        if (_ocupado || _fecha is null || !Sesion.Autenticado) return;
        _ocupado = true;
        _aviso = "";
        try
        {
            var cab = await Preparaciones.GetAsync(_fecha.Value, Pedido, Sesion.Usuario!.CodUsuario,
                Sesion.Usuario.Almacen.SoloConStock);
            if (cab.Ok && cab.Datos is not null) _cabecera = cab.Datos;
            _pendientesTecleados = null;
            _verificandoFinal = true;
        }
        finally
        {
            _ocupado = false;
        }
    }

    // Finalizar cierra la preparación del pedido (estado preparado). Irreversible desde la
    // app, por eso exige cuadrar el conteo de pendientes con el real (como R3).
    private async Task FinalizarVerificadoAsync()
    {
        if (_ocupado || _fecha is null || _cabecera is null || _pendientesTecleados is null) return;

        if (_pendientesTecleados.Value != _cabecera.CountPendientes)
        {
            MostrarError($"El conteo no cuadra: has tecleado {_pendientesTecleados} pendientes y el pedido tiene {_cabecera.CountPendientes}. Revisa el recorrido antes de finalizar.");
            return;
        }

        _ocupado = true;
        try
        {
            var respuesta = await Preparaciones.FinalizarAsync(_fecha.Value, Pedido, Sesion.Usuario!.CodUsuario);
            if (!respuesta.Ok) { MostrarError(respuesta.Error); return; }
            Nav.NavigateTo("/preparacion");
        }
        finally
        {
            _ocupado = false;
        }
    }

    private void MostrarError(string mensaje)
    {
        _tipoAviso = "error";
        _aviso = mensaje;
    }

    private void Volver() => Nav.NavigateTo($"/preparacion/{FechaRuta}/{Pedido}");
}
