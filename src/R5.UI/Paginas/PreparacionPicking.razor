@* Picking de preparación: el preparador recorre el almacén central siguiendo el
   orden de ubicación. La pantalla muestra UNA línea grande (ubicación, producto,
   lo pedido y el stock), se confirma la cantidad preparada (por defecto lo pedido)
   y se salta a la siguiente. Cada confirmación graba una línea de traspaso
   central→tienda ligada al pedido (mismo modelo que RWR4/R3).
   Escanear un EAN valida que el producto en mano es el de la línea. *@
@page "/preparacion/{FechaRuta}/{Pedido:int}/picking"
@inject PreparacionService Preparaciones
@inject TraspasoService Traspasos
@inject SesionUsuario Sesion
@inject NavigationManager Nav
@inject IJSRuntime JS

<GuardiaModulo CodMenu="24">
<div class="r5-columna">

    <div class="r5-fila">
        <button class="r5-btn r5-btn--secundario" @onclick="Volver">← Pedido @Pedido</button>
        <h2>Preparando · @(_cabecera?.Alm.DescAlm)</h2>
        <div class="r5-fila" style="margin-left:auto">
            <span class="r5-chip" style="background: var(--c-primario-claro); color: var(--c-primario-osc);">
                @_preparadasSesion preparadas
            </span>
            <button class="r5-btn r5-btn--secundario" @onclick="RegistrarAsync" disabled="@_ocupado">Registrar</button>
            <button class="r5-btn r5-btn--primario" @onclick="FinalizarAsync" disabled="@_ocupado">Finalizar</button>
        </div>
    </div>

    <Aviso Tipo="@_tipoAviso" Mensaje="@_aviso" />

    @if (_fecha is null)
    {
        <Aviso Mensaje="La fecha del pedido no es válida." />
    }
    else if (_cargando)
    {
        <Cargando Texto="Buscando siguiente línea…" />
    }
    else if (_linea is null)
    {
        <div class="r5-cargando">
            <Icono Nombre="ok" Clase="r5-modulo__icono" />
            <span>No quedan líneas pendientes en el recorrido. Puedes Registrar o Finalizar.</span>
        </div>
    }
    else
    {
        <div class="r5-tarjeta r5-columna">
            <div class="r5-fila">
                <span class="r5-badge r5-badge--neutro" style="font-size: var(--texto-lg);">
                    Ubicación @_linea.Prod.Ubicacion
                </span>
                <div class="r5-fila" style="margin-left:auto">
                    <button class="r5-btn r5-btn--fantasma" @onclick="AnteriorAsync" disabled="@_ocupado">← Anterior</button>
                    <button class="r5-btn r5-btn--fantasma" @onclick="() => SiguienteAsync(_linea.Prod.CodProd, _linea.Prod.Ubicacion)" disabled="@_ocupado">Saltar →</button>
                </div>
            </div>

            <div class="r5-ficha__identidad">
                <span class="r5-ficha__codigo">@_linea.Prod.CodProd</span>
                <span class="r5-ficha__nombre">@_linea.Prod.DescProd</span>
            </div>

            <dl class="r5-datos">
                <div><dt>Cajas pedidas</dt><dd>@_linea.CajasPedidas</dd></div>
                <div><dt>Cantidad pedida</dt><dd>@Cantidad(_linea.CantPedida, _linea.Prod.DecimalesEnCant)</dd></div>
                @if (_linea.CantEnviada > 0)
                {
                    <div><dt>Ya preparada</dt><dd>@Cantidad(_linea.CantEnviada, _linea.Prod.DecimalesEnCant)</dd></div>
                }
                <div><dt>Stock central</dt><dd>@Cantidad(_linea.StockCentral, _linea.Prod.DecimalesEnCant)</dd></div>
            </dl>

            <form @onsubmit="ValidarEscaneoAsync" class="r5-buscador">
                <input id="escaneoPicking" class="r5-input" type="text" inputmode="numeric"
                       placeholder="Escanea el producto para validar (opcional)"
                       @bind="_escaneo" @bind:event="oninput" />
                <button type="submit" class="r5-btn r5-btn--secundario" disabled="@string.IsNullOrWhiteSpace(_escaneo)">Validar</button>
            </form>

            <div class="r5-fila">
                <div class="r5-campo" style="flex:1">
                    <label for="cajasPick">Cajas</label>
                    <input id="cajasPick" class="r5-input r5-input--numero" type="number" inputmode="numeric" min="0"
                           value="@_cajas" @oninput="CambioCajas" />
                </div>
                <div class="r5-campo" style="flex:1">
                    <label for="cantPick">Cantidad preparada</label>
                    <input id="cantPick" class="r5-input r5-input--numero" type="number" inputmode="decimal"
                           step="@(_linea.Prod.DecimalesEnCant ? "0.001" : "1")" min="0"
                           @bind="_cantidad" @bind:event="oninput" />
                </div>
            </div>

            <button class="r5-btn r5-btn--primario r5-btn--bloque" @onclick="ConfirmarAsync"
                    disabled="@(_ocupado || _cantidad <= 0)">
                @(_ocupado ? "Grabando…" : $"Confirmar {Cantidad(_cantidad, _linea.Prod.DecimalesEnCant)} y seguir")
            </button>
        </div>
    }
</div>
</GuardiaModulo>

@code {
    [Parameter] public string FechaRuta { get; set; } = "";
    [Parameter] public int Pedido { get; set; }

    private DateTime? _fecha;
    private PrepPedCentral? _cabecera;
    private PrepPedCentralLin? _linea;
    private bool _cargando = true;
    private bool _ocupado;
    private string _aviso = "";
    private string _tipoAviso = "error";
    private string _escaneo = "";
    private short _cajas;
    private decimal _cantidad;
    private int _preparadasSesion;

    private short UnidsCaja => _linea is null || _linea.Prod.UnidsCaja <= 0 ? (short)1 : _linea.Prod.UnidsCaja;

    protected override async Task OnInitializedAsync()
    {
        if (!DateTime.TryParseExact(FechaRuta, "yyyy-MM-dd", null,
            System.Globalization.DateTimeStyles.None, out var fecha))
        {
            _fecha = null;
            _cargando = false;
            return;
        }
        _fecha = fecha;

        var usuario = Sesion.Usuario!;
        var cabecera = await Preparaciones.GetAsync(fecha, Pedido, usuario.CodUsuario, usuario.Almacen.SoloConStock);
        if (!cabecera.Ok || cabecera.Datos is null)
        {
            MostrarError(cabecera.Error);
            _cargando = false;
            return;
        }
        _cabecera = cabecera.Datos;

        await SiguienteAsync(0, "0");
    }

    private async Task SiguienteAsync(int codProdActual, string ubicacion)
    {
        if (_fecha is null) return;

        _cargando = true;
        _linea = null;
        try
        {
            var usuario = Sesion.Usuario!;
            var respuesta = await Preparaciones.GetLineaSiguienteAsync(
                _fecha.Value, Pedido, usuario.CodUsuario, usuario.Almacen.SoloConStock, codProdActual, ubicacion);
            if (!respuesta.Ok) { MostrarError(respuesta.Error); return; }

            if (respuesta.Datos is null || respuesta.Datos.Prod.CodProd <= 0)
            {
                _linea = null; // fin del recorrido
                return;
            }
            PrepararLinea(respuesta.Datos);
        }
        finally
        {
            _cargando = false;
        }
    }

    private async Task AnteriorAsync()
    {
        if (_fecha is null || _linea is null) return;

        _cargando = true;
        try
        {
            var usuario = Sesion.Usuario!;
            var respuesta = await Preparaciones.GetLineaAnteriorAsync(
                _fecha.Value, Pedido, usuario.CodUsuario, usuario.Almacen.SoloConStock,
                _linea.Prod.CodProd, _linea.Prod.Ubicacion);
            if (!respuesta.Ok) { MostrarError(respuesta.Error); return; }
            if (respuesta.Datos is not null && respuesta.Datos.Prod.CodProd > 0) PrepararLinea(respuesta.Datos);
        }
        finally
        {
            _cargando = false;
        }
    }

    private void PrepararLinea(PrepPedCentralLin linea)
    {
        _linea = linea;
        _escaneo = "";
        decimal pendiente = linea.CantPedida - linea.CantEnviada;
        _cantidad = pendiente > 0 ? pendiente : linea.CantPedida;
        _cajas = (short)(linea.CajasPedidas - linea.CajasEnviadas > 0 ? linea.CajasPedidas - linea.CajasEnviadas : linea.CajasPedidas);
    }

    private void CambioCajas(ChangeEventArgs e)
    {
        if (short.TryParse(e.Value?.ToString(), out short cajas) && cajas >= 0)
        {
            _cajas = cajas;
            _cantidad = cajas * UnidsCaja;
        }
    }

    // El escaneo compara el producto en mano con la línea actual: evita preparar lo que no toca.
    private async Task ValidarEscaneoAsync()
    {
        if (_linea is null || _fecha is null || string.IsNullOrWhiteSpace(_escaneo)) return;

        var usuario = Sesion.Usuario!;
        long.TryParse(_escaneo.Trim(), out long ean);
        var respuesta = await Traspasos.GetLineaProductoAsync(0, DateTime.Today,
            usuario.Almacen.CodAlm, _cabecera!.Alm.CodAlm, 0, ean, _fecha, Pedido);

        if (respuesta.Ok && respuesta.Datos?.Prod.CodProd == _linea.Prod.CodProd)
        {
            _tipoAviso = "exito";
            _aviso = "Producto correcto.";
        }
        else
        {
            MostrarError($"El escaneo NO corresponde a {_linea.Prod.DescProd}.");
        }
        _escaneo = "";
        await JS.InvokeVoidAsync("r5.seleccionar", "escaneoPicking");
    }

    // Confirmar = grabar línea de traspaso central→tienda ligada al pedido, y pasar a la siguiente.
    private async Task ConfirmarAsync()
    {
        if (_ocupado || _linea is null || _fecha is null || _cabecera is null || _cantidad <= 0) return;

        _ocupado = true;
        _aviso = "";
        try
        {
            var usuario = Sesion.Usuario!;

            // Coste para el importe de la línea (obligatorio en el proc de traspasos).
            var lineaTraspaso = await Traspasos.GetLineaProductoAsync(0, DateTime.Today,
                usuario.Almacen.CodAlm, _cabecera.Alm.CodAlm, _linea.Prod.CodProd, 0, _fecha, Pedido);
            decimal coste = lineaTraspaso.Datos?.Prod.UltPrecioCoste ?? 0;

            var alta = new TraspLinInsertDTO
            {
                Fecha = DateTime.Today,
                NumTraspaso = 0,
                CodAlmOrigen = usuario.Almacen.CodAlm,
                CodAlmDest = _cabecera.Alm.CodAlm,
                CodProd = _linea.Prod.CodProd,
                CodEan = _linea.Ean.CodEan ?? 0,
                Cajas = _cajas,
                UnidCaja = UnidsCaja,
                Cant = _cantidad,
                Importe = Math.Round(_cantidad * coste, 2),
                CodUsuario = usuario.CodUsuario,
                Lote = _linea.Prod.Lote ?? 0,
                Registrado = false,
                FechaPedido = _fecha.Value,
                NumPedido = Pedido
            };
            var respuesta = await Traspasos.PostLineaAsync(alta);
            if (!respuesta.Ok) { MostrarError(respuesta.Error); return; }

            _preparadasSesion++;
            _tipoAviso = "exito";
            _aviso = $"{_linea.Prod.DescProd}: {Cantidad(_cantidad, _linea.Prod.DecimalesEnCant)} preparado.";

            int prodActual = _linea.Prod.CodProd;
            string ubicacion = _linea.Prod.Ubicacion;
            await SiguienteAsync(prodActual, ubicacion);
        }
        finally
        {
            _ocupado = false;
        }
    }

    // Registrar consolida lo preparado; el pedido sigue asignado.
    private async Task RegistrarAsync()
    {
        if (_ocupado || _fecha is null) return;
        _ocupado = true;
        try
        {
            var respuesta = await Preparaciones.RegistrarAsync(_fecha.Value, Pedido, Sesion.Usuario!.CodUsuario);
            if (!respuesta.Ok) { MostrarError(respuesta.Error); return; }
            _tipoAviso = "exito";
            _aviso = "Preparación registrada.";
        }
        finally
        {
            _ocupado = false;
        }
    }

    // Finalizar cierra la preparación del pedido (estado preparado). Irreversible desde la app.
    private async Task FinalizarAsync()
    {
        if (_ocupado || _fecha is null) return;
        _ocupado = true;
        try
        {
            var respuesta = await Preparaciones.FinalizarAsync(_fecha.Value, Pedido, Sesion.Usuario!.CodUsuario);
            if (!respuesta.Ok) { MostrarError(respuesta.Error); return; }
            Nav.NavigateTo("/preparacion");
        }
        finally
        {
            _ocupado = false;
        }
    }

    private void MostrarError(string mensaje)
    {
        _tipoAviso = "error";
        _aviso = mensaje;
    }

    private void Volver() => Nav.NavigateTo($"/preparacion/{FechaRuta}/{Pedido}");
}
