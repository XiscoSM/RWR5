@* Alta de pedido a proveedor: proveedor/condición por escaneo (como en recepción),
   fecha prevista de envío, y líneas encadenadas con precio y stock a la vista.
   La cabecera se crea al añadir la primera línea; al final Registrar y, si el
   proveedor tiene mail, encolar el envío. *@
@page "/pedidoCompra/alta"
@page "/pedidoCompra/alta/{NumRuta:int}"
@inject PedidoCompraService Pedidos
@inject ProveedorService Proveedores
@inject SesionUsuario Sesion
@inject NavigationManager Nav
@inject IJSRuntime JS

<GuardiaModulo CodMenu="8">
<div class="r5-columna">

    <div class="r5-fila">
        <button class="r5-btn r5-btn--secundario" @onclick="Volver">← Pedidos</button>
        <h2>@(NumRuta > 0 ? "Continuar pedido" : "Nuevo pedido a proveedor")</h2>
        @if (_numPedido > 0)
        {
            <div class="r5-fila" style="margin-left:auto">
                <span class="r5-chip" style="background: var(--c-primario-claro); color: var(--c-primario-osc);">
                    Pedido @_numPedido · @_lineasAnadidas líneas
                </span>
                <BotonConfirmar Texto="Registrar pedido"
                                Pregunta="@($"¿Registrar el pedido {_numPedido} con {_lineasAnadidas} líneas? No se puede deshacer.")"
                                TextoOcupado="Registrando…" Ocupado="@_registrando"
                                OnConfirmar="RegistrarAsync" />
            </div>
        }
    </div>

    @if (_gamaElegida is null)
    {
        <div class="r5-tarjeta r5-columna r5-ancho-form">
            <h3>Proveedor</h3>
            <form @onsubmit="BuscarProveedorAsync" class="r5-buscador">
                <input id="busquedaProvPed" class="r5-input" type="text" inputmode="numeric"
                       placeholder="Escanea un producto del proveedor o teclea su código"
                       @bind="_codigoProv" @bind:event="oninput" autofocus disabled="@_ocupado" />
                <button type="submit" class="r5-btn r5-btn--secundario" disabled="@(_ocupado || string.IsNullOrWhiteSpace(_codigoProv))">
                    Buscar
                </button>
            </form>

            <Aviso Mensaje="@(_tipoAviso == "error" ? _aviso : "")" />

            @if (_gamas.Count > 0)
            {
                <h3>Elige la condición de compra</h3>
                <div class="r5-docs">
                    @foreach (var gama in _gamas)
                    {
                        <button @key="@($"{gama.CodProv}-{gama.Gama.CodGama}")" class="r5-doc" @onclick="() => ElegirGama(gama)">
                            <Icono Nombre="pedido-compra" Clase="r5-modulo__icono" />
                            <span class="r5-doc__principal">
                                <span class="r5-doc__titulo">@gama.DescProv</span>
                                <span class="r5-doc__detalle">Prov. @gama.CodProv · Gama @gama.Gama.CodGama · @gama.Gama.DescGama</span>
                            </span>
                        </button>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="r5-tarjeta r5-columna">
            <div class="r5-fila" style="flex-wrap: wrap;">
                <span class="r5-texto-suave">Proveedor:</span>
                <strong>@_gamaElegida.DescProv · Gama @_gamaElegida.Gama.CodGama</strong>
                @if (_numPedido == 0)
                {
                    <button class="r5-btn r5-btn--fantasma" @onclick="CambiarProveedor">Cambiar</button>
                }
                <div class="r5-campo" style="margin-left:auto; min-width: 200px;">
                    <label for="fechaPrevEnvio">Fecha prevista de envío</label>
                    <input id="fechaPrevEnvio" class="r5-input" type="date" @bind="_fechaPrevEnvio" />
                </div>
            </div>

            <form @onsubmit="BuscarProductoAsync" class="r5-buscador">
                <input id="busquedaPedProv" class="r5-input" type="text" inputmode="@(_porRefProv ? "text" : "numeric")"
                       placeholder="@(_porRefProv ? "Teclea la referencia del proveedor" : "Escanea un EAN o teclea el código de producto")"
                       @bind="_codigo" @bind:event="oninput" disabled="@_ocupado" />
                <button type="submit" class="r5-btn r5-btn--secundario" disabled="@(_ocupado || string.IsNullOrWhiteSpace(_codigo))">
                    Buscar
                </button>
            </form>
            @* Alternativa de búsqueda: por la referencia con la que el PROVEEDOR nombra el
               producto (viene en su catálogo/albarán), no por nuestro código. *@
            <label class="r5-fila" style="gap: var(--esp-2); cursor: pointer;">
                <input type="checkbox" @bind="_porRefProv" />
                <span class="r5-texto-suave">Buscar por referencia del proveedor</span>
            </label>
        </div>

        <Aviso Tipo="@_tipoAviso" Mensaje="@_aviso" />

        @if (_ocupado)
        {
            <Cargando />
        }
        else if (_linea is not null)
        {
            <div class="r5-tarjeta r5-columna">
                <div class="r5-ficha__identidad">
                    <span class="r5-ficha__codigo">@_linea.Prod.CodProd</span>
                    <span class="r5-ficha__nombre">@_linea.Prod.DescProd</span>
                </div>

                <dl class="r5-datos">
                    <div><dt>Precio tarifa</dt><dd>@Moneda(_linea.PTarifa)</dd></div>
                    <div><dt>Precio neto (PNC)</dt><dd>@Moneda(_linea.PNC)</dd></div>
                    <div><dt>Unidades por caja</dt><dd>@UnidsCaja</dd></div>
                    <div><dt>Stock actual</dt><dd>@Cantidad(_linea.Stock, _linea.Prod.DecimalesEnCant)</dd></div>
                </dl>

                @* Producto ya en el pedido: la cantidad viene precargada y el proc SUSTITUYE
                   la línea (upsert), como el 'puede modificarlo' de R3. *@
                @if (_yaPedido)
                {
                    <Aviso Tipo="aviso" Mensaje="@($"Producto ya pedido ({Cantidad(_cantYaPedida, _linea.Prod.DecimalesEnCant)}): la cantidad que confirmes SUSTITUIRÁ a la actual.")" />
                }

                <div class="r5-fila">
                    <div class="r5-campo" style="flex:1">
                        <label for="cajasPed">Cajas</label>
                        <input id="cajasPed" class="r5-input r5-input--numero" type="text" inputmode="numeric" min="0"
                               value="@_cajas" @oninput="CambioCajas" />
                    </div>
                    <div class="r5-campo" style="flex:1">
                        <label for="cantPed">Cantidad</label>
                        <input id="cantPed" class="r5-input r5-input--numero" type="number" inputmode="decimal"
                               step="@(_linea.Prod.DecimalesEnCant ? "0.001" : "1")" min="0"
                               @bind="_cantidad" @bind:event="oninput" />
                    </div>
                </div>

                <div class="r5-fila">
                    <button class="r5-btn r5-btn--primario" style="flex:1" @onclick="AnadirAsync"
                            disabled="@(_anadiendo || _cantidad <= 0)">
                        @(_anadiendo ? "Añadiendo…" : $"{(_yaPedido ? "Cambiar a" : "Añadir")} {Cantidad(_cantidad, _linea.Prod.DecimalesEnCant)}")
                    </button>
                    @if (_yaPedido && _linea.Linea > 0)
                    {
                        <button class="r5-btn r5-btn--peligro" disabled="@_anadiendo"
                                @onclick='() => EliminarLineaAsync(_linea.Linea, _linea.Prod.DescProd ?? "")'>
                            Eliminar del pedido
                        </button>
                    }
                </div>
            </div>
        }

        <PanelLineas Items="_lineasDoc" Cargando="_cargandoLineas" Titulo="Líneas del pedido">
            <Cabecera>
                <th>Cód.</th><th>Producto</th><th class="num">Cajas</th><th class="num">Cant.</th><th></th>
            </Cabecera>
            <Fila Context="l">
                <tr @key="l.Prod.CodProd">
                    <td>@l.Prod.CodProd</td>
                    <td>@l.Prod.DescProd</td>
                    <td class="num">@l.Cajas</td>
                    <td class="num">@Cantidad(l.Cant, l.Prod.DecimalesEnCant)</td>
                    <td class="num">
                        @if (_lineaBorrando == l.Linea)
                        {
                            <button class="r5-btn r5-btn--peligro r5-btn--sm" @onclick='() => EliminarLineaAsync(l.Linea, l.Prod.DescProd ?? "")'>¿Seguro?</button>
                            <button class="r5-btn r5-btn--fantasma r5-btn--sm" @onclick="() => _lineaBorrando = 0">No</button>
                        }
                        else
                        {
                            <button class="r5-btn r5-btn--fantasma r5-btn--sm" @onclick="() => _lineaBorrando = l.Linea">Quitar</button>
                        }
                    </td>
                </tr>
            </Fila>
        </PanelLineas>
    }
</div>
</GuardiaModulo>

@code {
    // Reanudación: si la ruta trae número, se carga ese pedido pendiente y se sigue
    // añadiendo/cambiando líneas (paridad con "Continuar" de R3).
    [Parameter] public int NumRuta { get; set; }

    private string _codigoProv = "";
    private List<Proveedor> _gamas = new();
    private Proveedor? _gamaElegida;

    private string _codigo = "";
    private bool _ocupado;
    private bool _anadiendo;
    private bool _registrando;
    private bool _enfocarBuscador;
    private bool _porRefProv;          // buscar por referencia del proveedor en vez de EAN/código
    private int _lineaBorrando;        // línea con confirmación de borrado abierta (0 = ninguna)

    protected override async Task OnInitializedAsync()
    {
        if (NumRuta <= 0) return;

        _ocupado = true;
        try
        {
            var cab = await Pedidos.GetCabeceraAsync(NumRuta);
            if (!cab.Ok || cab.Datos is null || cab.Datos.NumPedido <= 0)
            {
                MostrarError($"No se pudo cargar el pedido {NumRuta}: {cab.Error}");
                return;
            }
            if (cab.Datos.Reg)
            {
                MostrarError($"El pedido {NumRuta} ya está registrado: no admite cambios.");
                return;
            }

            _numPedido = cab.Datos.NumPedido;
            _fecha = cab.Datos.Fecha;
            _gamaElegida = cab.Datos.Prov;
            if (cab.Datos.FechaPrevEnvio > DateTime.Today) _fechaPrevEnvio = cab.Datos.FechaPrevEnvio;
            await RefrescarLineasAsync();
            _lineasAnadidas = _lineasDoc.Count;
        }
        finally
        {
            _ocupado = false;
        }
    }

    // Foco directo al buscador de proveedor al entrar (el autofocus de Blazor no dispara
    // al navegar) y, después, al buscador de producto en cuanto aparece (tras elegir gama).
    // Al reanudar, el proveedor ya está fijado: el foco va directo al buscador de producto.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("r5.seleccionar", _numPedido > 0 ? "busquedaPedProv" : "busquedaProvPed");
            return;
        }
        if (_enfocarBuscador)
        {
            _enfocarBuscador = false;
            await JS.InvokeVoidAsync("r5.seleccionar", "busquedaPedProv");
        }
    }
    private string _aviso = "";
    private string _tipoAviso = "error";

    private PedidoCompraLin? _linea;
    private long _eanEscaneado;
    private short _cajas;
    private decimal _cantidad;
    private int _numPedido;
    private int _lineasAnadidas;
    private List<PedidoCompraLin> _lineasDoc = new();
    private bool _cargandoLineas;
    private DateTime _fecha = DateTime.Today;   // al reanudar se toma la del pedido
    private DateTime _fechaPrevEnvio = DateTime.Today.AddDays(1);

    // Producto ya en el pedido: el Get devuelve su línea con la cantidad actual.
    private bool _yaPedido => _linea is not null && _linea.Linea > 0 && _cantYaPedida > 0;
    private decimal _cantYaPedida;

    private short UnidsCaja => _linea is null ? (short)1
        : (_linea.Ean.UnidCaja > 1 ? _linea.Ean.UnidCaja : (_linea.Prod.UnidsCaja > 0 ? _linea.Prod.UnidsCaja : (short)1));

    private async Task BuscarProveedorAsync()
    {
        string codigo = _codigoProv.Trim();
        if (_ocupado || codigo.Length == 0) return;

        _ocupado = true;
        _aviso = "";
        _gamas = new();
        try
        {
            ApiRespuesta<List<Proveedor>> respuesta;
            if (codigo.Length >= 8 && long.TryParse(codigo, out long ean))
            {
                respuesta = await Proveedores.GetGamasPorEanAsync(ean);
            }
            else if (int.TryParse(codigo, out int codProv) && codProv > 0)
            {
                respuesta = await Proveedores.GetGamasPorProvAsync(codProv);
            }
            else
            {
                MostrarError("Introduce un EAN o un código de proveedor numérico.");
                return;
            }

            if (!respuesta.Ok || respuesta.Datos is null) { MostrarError(respuesta.Error); return; }
            if (respuesta.Datos.Count == 0) { MostrarError("Sin condiciones de compra para ese código."); return; }

            _gamas = respuesta.Datos;
            if (_gamas.Count == 1) ElegirGama(_gamas[0]);
        }
        finally
        {
            _ocupado = false;
        }
    }

    private void ElegirGama(Proveedor gama)
    {
        _gamaElegida = gama;
        _aviso = "";
        _enfocarBuscador = true;
    }

    private void CambiarProveedor()
    {
        _gamaElegida = null;
        _gamas = new();
        _linea = null;
        _aviso = "";
    }

    private void CambioCajas(ChangeEventArgs e)
    {
        if (short.TryParse(e.Value?.ToString(), out short cajas) && cajas >= 0)
        {
            _cajas = cajas;
            _cantidad = cajas * UnidsCaja;
        }
    }

    private async Task BuscarProductoAsync()
    {
        string codigo = _codigo.Trim();
        if (_ocupado || codigo.Length == 0 || _gamaElegida is null || !Sesion.Autenticado) return;

        _ocupado = true;
        _aviso = "";
        _linea = null;
        _eanEscaneado = 0;
        _cantYaPedida = 0;
        try
        {
            short codAlm = Sesion.Usuario!.Almacen.CodAlm;

            ApiRespuesta<PedidoCompraLin> respuesta;
            if (_porRefProv)
            {
                // Por referencia del proveedor (puede ser alfanumérica).
                respuesta = await Pedidos.GetProductoPorRefProvAsync(_numPedido, _fecha,
                    _gamaElegida.CodProv, _gamaElegida.Gama.CodGama, codigo, codAlm);
            }
            else
            {
                int codProd = 0;
                long codEan = 0;
                if (codigo.Length >= 8 && long.TryParse(codigo, out long ean)) codEan = ean;
                else if (int.TryParse(codigo, out int cod) && cod > 0) codProd = cod;
                else { MostrarError("Introduce un código numérico (producto o EAN)."); return; }

                respuesta = await Pedidos.GetProductoAsync(_numPedido, _fecha,
                    _gamaElegida.CodProv, _gamaElegida.Gama.CodGama, codProd, codEan, codAlm);
                _eanEscaneado = codEan;
            }
            if (!respuesta.Ok || respuesta.Datos is null) { MostrarError(respuesta.Error); return; }
            if (respuesta.Datos.Prod.CodProd <= 0) { MostrarError($"El código {codigo} no corresponde a ningún producto de esta gama."); return; }

            _linea = respuesta.Datos;
            // Ya pedido: precarga la cantidad actual para modificarla (el proc sustituye).
            _cantYaPedida = _linea.Linea > 0 ? _linea.Cant : 0;
            if (_cantYaPedida > 0)
            {
                _cantidad = _cantYaPedida;
                _cajas = _linea.Cajas;
            }
            else
            {
                _cajas = 1;
                _cantidad = UnidsCaja;
            }
        }
        finally
        {
            _ocupado = false;
            StateHasChanged();
            await JS.InvokeVoidAsync("r5.seleccionar", "busquedaPedProv");
        }
    }

    private async Task AnadirAsync()
    {
        if (_anadiendo || _linea is null || _gamaElegida is null || _cantidad <= 0) return;

        // Tope de sanidad: una lectura del escaner caida en el campo cantidad (>=10.000)
        // no puede acabar grabada como unidades.
        if (_cantidad >= 10000) { MostrarError($"Cantidad {_cantidad} no valida: ¿has escaneado un codigo en el campo de cantidad?"); return; }

        // Cajas coherentes con la cantidad final (por si se editó la cantidad a mano).
        _cajas = (short)Math.Ceiling(_cantidad / UnidsCaja);

        _anadiendo = true;
        _aviso = "";
        try
        {
            // La primera línea necesita cabecera: se crea aquí y devuelve el número de pedido.
            if (_numPedido == 0)
            {
                var cabecera = new PedidoCompraInsertDTO
                {
                    NumPedido = 0,
                    Fecha = _fecha,
                    FechaPrevEnvio = _fechaPrevEnvio,
                    CodProv = _gamaElegida.CodProv,
                    CodGama = _gamaElegida.Gama.CodGama,
                    CodUsuario = Sesion.Usuario!.CodUsuario,
                    CodAlm = Sesion.Usuario.Almacen.CodAlm
                };
                var alta = await Pedidos.PostCabeceraAsync(cabecera);
                if (!alta.Ok || alta.Datos <= 0) { MostrarError(alta.Error); return; }
                _numPedido = alta.Datos;
            }

            var lineaDto = new PedidoCompraLinInsertDTO
            {
                NumPedido = _numPedido,
                Fecha = _fecha,
                CodProv = _gamaElegida.CodProv,
                CodGama = _gamaElegida.Gama.CodGama,
                CodProd = _linea.Prod.CodProd,
                CodEan = _eanEscaneado,
                CodProdProv = "",
                CodUsuario = Sesion.Usuario!.CodUsuario,
                Cant = _cantidad,
                Cajas = _cajas,
                CodAlm = Sesion.Usuario.Almacen.CodAlm
            };
            var respuesta = await Pedidos.PostLineaAsync(lineaDto);
            if (!respuesta.Ok) { MostrarError(respuesta.Error); return; }

            _lineasAnadidas++;
            _tipoAviso = "exito";
            _aviso = $"{_linea.Prod.DescProd}: {Cantidad(_cantidad, _linea.Prod.DecimalesEnCant)} añadido al pedido {_numPedido}.";
            _linea = null;
            _codigo = "";
            _ = RefrescarLineasAsync();
        }
        finally
        {
            _anadiendo = false;
            StateHasChanged();
            await JS.InvokeVoidAsync("r5.seleccionar", "busquedaPedProv");
        }
    }

    // Refresca el panel de líneas sin bloquear el siguiente escaneo (ApiWeb no lanza).
    // El contador del chip sale de la lista real (los borrados también cuentan).
    private async Task RefrescarLineasAsync()
    {
        if (_numPedido <= 0) return;
        _cargandoLineas = true;
        var r = await Pedidos.GetLineasAsync(_numPedido);
        if (r.Ok && r.Datos is not null)
        {
            _lineasDoc = r.Datos;
            _lineasAnadidas = _lineasDoc.Count;
        }
        _cargandoLineas = false;
        StateHasChanged();
    }

    // Elimina una línea del pedido abierto (desde la ficha o desde el panel de líneas).
    private async Task EliminarLineaAsync(int linea, string descProd)
    {
        if (_anadiendo || _numPedido <= 0 || linea <= 0) return;

        _anadiendo = true;
        _lineaBorrando = 0;
        _aviso = "";
        try
        {
            var r = await Pedidos.DeleteLineaAsync(_numPedido, linea);
            if (!r.Ok) { MostrarError(r.Error); return; }

            _tipoAviso = "exito";
            _aviso = $"{descProd}: línea eliminada del pedido {_numPedido}.";
            _linea = null;
            _cantYaPedida = 0;
            _ = RefrescarLineasAsync();
        }
        finally
        {
            _anadiendo = false;
            StateHasChanged();
            await JS.InvokeVoidAsync("r5.seleccionar", "busquedaPedProv");
        }
    }

    // Registrar el pedido: irreversible desde la app (queda listo para enviar al proveedor).
    private async Task RegistrarAsync()
    {
        if (_registrando || _numPedido <= 0) return;

        // Validación de R3: la fecha prevista de envío debe ser posterior a hoy y a la
        // fecha del pedido (no tiene sentido comprometer un envío en el pasado).
        if (_fechaPrevEnvio.Date <= DateTime.Today || _fechaPrevEnvio.Date <= _fecha.Date)
        {
            MostrarError($"La fecha prevista de envío ({_fechaPrevEnvio:dd/MM/yy}) debe ser posterior a hoy y a la fecha del pedido.");
            return;
        }

        _registrando = true;
        _aviso = "";
        try
        {
            var respuesta = await Pedidos.RegistrarAsync(_numPedido, Sesion.Usuario!.CodUsuario, _fechaPrevEnvio);
            if (!respuesta.Ok) { MostrarError(respuesta.Error); return; }

            Nav.NavigateTo($"/pedidoCompra/{_numPedido}");
        }
        finally
        {
            _registrando = false;
        }
    }

    private void MostrarError(string mensaje)
    {
        _tipoAviso = "error";
        _aviso = mensaje;
    }

    private void Volver() => Nav.NavigateTo("/pedidoCompra");
}
