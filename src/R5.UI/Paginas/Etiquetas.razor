@* Etiquetas Madisa: el operario pide reimpresión de etiquetas de estantería.
   Dos modos (como R3/RWR4): "Del día" actualiza el PriceItem y "PDA" encola en
   la tabla de etiquetas del terminal. En manual, el escaneo muestra el producto
   y el PVP antes de confirmar; en automático, cada escaneo solicita directamente.
   La cola del terminal se ve y se puede vaciar. *@
@page "/etiquetas"
@inject EtiquetaService ServicioEtiquetas
@inject EanListService EanList
@inject SesionUsuario Sesion
@inject NavigationManager Nav
@inject IJSRuntime JS

<GuardiaModulo CodMenu="12">
<div class="r5-columna">

    <div class="r5-tarjeta r5-columna">
        <div class="r5-fila" style="flex-wrap: wrap;">
            <div class="r5-segmento">
                <button class="@(!_modoPda ? "activo" : "")" aria-pressed="@(!_modoPda)" @onclick="() => CambiarModo(false)">Etiquetas del día</button>
                <button class="@(_modoPda ? "activo" : "")" aria-pressed="@_modoPda" @onclick="() => CambiarModo(true)">Etiquetas PDA</button>
            </div>
            <label class="r5-fila" style="gap: var(--esp-2); margin-left: auto; cursor: pointer;">
                <input type="checkbox" style="width: 24px; height: 24px;" @bind="_automatico" />
                <span>Automático (solicitar al escanear)</span>
            </label>
            @* Cola EanList (cambios de PVP del día + operativas manual/serie/albarán/bultos). *@
            <button class="r5-btn r5-btn--secundario" @onclick='() => Nav.NavigateTo("/etiquetas/cola")'>
                Cola de etiquetas @(_pendientesEanList > 0 ? $"({_pendientesEanList})" : "")
            </button>
        </div>

        <form @onsubmit="EscanearAsync" class="r5-buscador">
            <input id="busquedaEtiqueta" class="r5-input" type="text" inputmode="numeric"
                   placeholder="Escanea el EAN del producto"
                   @bind="_codigo" @bind:event="oninput" autofocus disabled="@_ocupado" />
            <button type="submit" class="r5-btn r5-btn--primario" disabled="@(_ocupado || string.IsNullOrWhiteSpace(_codigo))">
                @(_automatico ? "Solicitar" : "Buscar")
            </button>
        </form>
    </div>

    <Aviso Tipo="@_tipoAviso" Mensaje="@_aviso" />

    @if (_ocupado)
    {
        <Cargando />
    }
    else if (_producto is not null)
    {
        <div class="r5-tarjeta r5-columna">
            <div class="r5-fila">
                <div class="r5-ficha__identidad">
                    <span class="r5-ficha__codigo">@_producto.CodProd</span>
                    <span class="r5-ficha__nombre">@_producto.DescProd</span>
                </div>
                <div class="r5-ficha__precio">
                    @if (_producto.PvpSinOferta is > 0 && _producto.Pvp < _producto.PvpSinOferta)
                    {
                        <span class="r5-ficha__pvp-anterior">@Moneda(_producto.PvpSinOferta)</span>
                    }
                    <span class="r5-ficha__pvp">@Moneda(_producto.Pvp)</span>
                </div>
            </div>

            @if (!_automatico)
            {
                <button class="r5-btn r5-btn--primario r5-btn--bloque" @onclick="SolicitarAsync" disabled="@_ocupado">
                    Solicitar etiqueta @(_modoPda ? "PDA" : "del día")
                </button>
            }
        </div>
    }

    @* La cola de reimpresión es un concepto del modo PDA (tabla de etiquetas del terminal);
       en "Etiquetas del día" no aplica y no debe mostrarse. *@
    @if (_modoPda)
    {
    <div class="r5-tarjeta r5-columna">
        <div class="r5-fila">
            <h3>Cola del terminal @Sesion.Usuario?.NumTerminal</h3>
            <div class="r5-fila" style="margin-left:auto">
                <button class="r5-btn r5-btn--fantasma" @onclick="CargarColaAsync" disabled="@_ocupado">Actualizar</button>
                <BotonConfirmar Texto="Vaciar cola" Peligro="true"
                                Pregunta="@($"¿Vaciar las {_cola.Count} etiquetas pendientes del terminal?")"
                                TextoOcupado="Vaciando…" Ocupado="@_ocupado"
                                Deshabilitado="@(_cola.Count == 0)"
                                OnConfirmar="VaciarColaAsync" />
            </div>
        </div>

        @if (_cola.Count == 0)
        {
            <p class="r5-texto-suave">La cola está vacía.</p>
        }
        else
        {
            <dl class="r5-datos">
                @foreach (var (producto, i) in _cola.Select((p, i) => (p, i)))
                {
                    <div @key="i">
                        <dt>@producto.CodProd · @producto.DescProd</dt>
                        <dd>@Moneda(producto.Pvp)</dd>
                    </div>
                }
            </dl>
        }
    </div>
    }
</div>
</GuardiaModulo>

@code {
    private bool _modoPda = true;
    private bool _automatico;
    private string _codigo = "";
    private bool _ocupado;
    private string _aviso = "";
    private string _tipoAviso = "error";

    private Producto? _producto;
    private long _eanActual;
    private List<Producto> _cola = new();

    // Aviso de etiquetas EanList pendientes al entrar (paridad con el MsgBox de R3):
    // se muestra el contador en el botón de la cola. Mejor esfuerzo, no bloquea.
    private int _pendientesEanList;

    protected override async Task OnInitializedAsync()
    {
        await CargarColaAsync();
        if (Sesion.Autenticado)
        {
            var p = await EanList.GetPendientesAsync(Sesion.Usuario!.Almacen.CodAlm, etiqPda: false);
            if (p.Ok && p.Datos is not null && p.Datos.Count > 0)
            {
                _pendientesEanList = p.Datos.Count;
                _tipoAviso = "info";
                _aviso = $"Tienes {_pendientesEanList} etiquetas de cambios de PVP pendientes de imprimir en la cola.";
            }
        }
    }

    // Foco directo al escáner al entrar (el autofocus de Blazor no dispara al navegar).
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await JS.InvokeVoidAsync("r5.seleccionar", "busquedaEtiqueta");
    }

    // Cambiar de modo invalida el producto cargado: el PVP y la acción se resolvieron
    // para el modo anterior. Se limpia y se pide re-escanear, evitando solicitar en el
    // modo equivocado.
    private void CambiarModo(bool pda)
    {
        if (_modoPda == pda) return;
        _modoPda = pda;
        _producto = null;
        _eanActual = 0;
        _aviso = "";
    }

    // Option del proc Madisa: manual = consulta (0) y luego confirma (2 PDA / 4 día);
    // automático = directo (1 PDA / 3 día).
    private byte OpcionDirecta => _modoPda ? (byte)1 : (byte)3;
    private byte OpcionConfirmar => _modoPda ? (byte)2 : (byte)4;

    private async Task EscanearAsync()
    {
        string codigo = _codigo.Trim();
        if (_ocupado || codigo.Length == 0 || !Sesion.Autenticado) return;
        if (!long.TryParse(codigo, out long ean) || ean <= 0)
        {
            MostrarError("Introduce un EAN numérico.");
            return;
        }

        _ocupado = true;
        _aviso = "";
        try
        {
            _eanActual = ean;
            var respuesta = await ServicioEtiquetas.PostEtiquetaAsync(Solicitud(_automatico ? OpcionDirecta : (byte)0));
            if (!respuesta.Ok || respuesta.Datos is null) { MostrarError(respuesta.Error); _producto = null; return; }
            if (respuesta.Datos.CodProd <= 0) { MostrarError($"El EAN {ean} no corresponde a ningún producto."); _producto = null; return; }

            _producto = respuesta.Datos;
            if (_automatico)
            {
                _tipoAviso = "exito";
                _aviso = $"{_producto.DescProd}: etiqueta {(_modoPda ? "PDA" : "del día")} solicitada.";
                if (_modoPda) await CargarColaAsync();
            }
            _codigo = "";
        }
        finally
        {
            _ocupado = false;
            StateHasChanged();
            await JS.InvokeVoidAsync("r5.seleccionar", "busquedaEtiqueta");
        }
    }

    private async Task SolicitarAsync()
    {
        if (_ocupado || _producto is null || _eanActual <= 0) return;

        _ocupado = true;
        _aviso = "";
        try
        {
            var respuesta = await ServicioEtiquetas.PostEtiquetaAsync(Solicitud(OpcionConfirmar));
            if (!respuesta.Ok) { MostrarError(respuesta.Error); return; }

            _tipoAviso = "exito";
            _aviso = $"{_producto.DescProd}: etiqueta {(_modoPda ? "PDA" : "del día")} solicitada.";
            _producto = null;
            if (_modoPda) await CargarColaAsync();
        }
        finally
        {
            _ocupado = false;
            StateHasChanged();
            await JS.InvokeVoidAsync("r5.seleccionar", "busquedaEtiqueta");
        }
    }

    private EanUserTermDTO Solicitud(byte opcion) => new()
    {
        CodEan = _eanActual,
        CodAlm = Sesion.Usuario!.Almacen.CodAlm,
        CodUsuario = Sesion.Usuario.CodUsuario,
        NumTerminal = Sesion.Usuario.NumTerminal,
        Option = opcion
    };

    private async Task CargarColaAsync()
    {
        if (!Sesion.Autenticado) return;
        var respuesta = await ServicioEtiquetas.GetColaAsync(Sesion.Usuario!.Almacen.CodAlm, Sesion.Usuario.NumTerminal);
        if (!respuesta.Ok)
        {
            // Un fallo de red no debe disfrazarse de "cola vacía": se conserva la última
            // cola conocida y se avisa.
            MostrarError($"No se pudo leer la cola: {respuesta.Error}");
            return;
        }
        _cola = respuesta.Datos ?? new();
    }

    // Vaciar borra la cola pendiente del terminal (no las etiquetas ya impresas).
    private async Task VaciarColaAsync()
    {
        if (_ocupado || !Sesion.Autenticado) return;
        _ocupado = true;
        try
        {
            var respuesta = await ServicioEtiquetas.VaciarColaAsync(Sesion.Usuario!.Almacen.CodAlm, Sesion.Usuario.NumTerminal);
            if (!respuesta.Ok) { MostrarError(respuesta.Error); return; }
            _cola = new();
            _tipoAviso = "exito";
            _aviso = "Cola vaciada.";
        }
        finally
        {
            _ocupado = false;
        }
    }

    private void MostrarError(string mensaje)
    {
        _tipoAviso = "error";
        _aviso = mensaje;
    }
}
