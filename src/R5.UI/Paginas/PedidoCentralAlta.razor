@* Alta de pedido a central: el operario de tienda escanea productos y pide.
   Elige centro de distribución una vez (chips), escanea, ve lo que decide
   (stock local, stock en central, ya pedido) y confirma cantidad con atajos
   de caja. Tras añadir, el foco vuelve al buscador para encadenar escaneos. *@
@page "/pedidoCentral/alta"
@inject PedidoCentralService Pedidos
@inject SesionUsuario Sesion
@inject NavigationManager Nav
@inject IJSRuntime JS

<GuardiaModulo CodMenu="19">
<div class="r5-columna">

    <div class="r5-fila">
        <button class="r5-btn r5-btn--secundario" @onclick="Volver">← Pedidos</button>
        <h2>Añadir a pedido</h2>
        @if (_ultimoPedido > 0)
        {
            <button class="r5-btn r5-btn--fantasma" style="margin-left:auto" @onclick="VerPedido">
                Ver pedido @_ultimoPedido →
            </button>
        }
    </div>

    <div class="r5-tarjeta r5-columna">
        <div class="r5-campo">
            <label>Centro de distribución</label>
            @if (_cargandoCentros)
            {
                <span class="r5-texto-suave">Cargando centros…</span>
            }
            else if (_centros.Count == 0)
            {
                @* Sin centros no se puede pedir (todas las búsquedas necesitan uno): se bloquea. *@
                <Aviso Mensaje="@(_aviso.Length > 0 ? _aviso : "No se pudieron cargar los centros de distribución.")"
                       OnReintentar="CargarCentrosAsync" Reintentando="_cargandoCentros" />
            }
            else
            {
                <div class="r5-segmento">
                    @foreach (var centro in _centros)
                    {
                        <button @key="centro.CentroDist" class="@(_centroDist == centro.CentroDist ? "activo" : "")"
                                @onclick="() => ElegirCentro(centro.CentroDist)">
                            @centro.DescCentroDist
                        </button>
                    }
                </div>
            }
        </div>

        <form @onsubmit="BuscarAsync" class="r5-buscador">
            <input id="busquedaPedido" class="r5-input" type="text" inputmode="numeric"
                   placeholder="Escanea un EAN o teclea el código de producto"
                   @bind="_codigo" @bind:event="oninput" autofocus disabled="@(_ocupado || _centros.Count == 0)" />
            <button type="submit" class="r5-btn r5-btn--secundario"
                    disabled="@(_ocupado || _centros.Count == 0 || string.IsNullOrWhiteSpace(_codigo))">
                Buscar
            </button>
        </form>
    </div>

    <Aviso Tipo="@_tipoAviso" Mensaje="@_aviso" />

    @if (_ocupado)
    {
        <Cargando />
    }
    else if (_linea is not null && _dto is not null)
    {
        <div class="r5-tarjeta r5-columna">
            <div class="r5-fila">
                <div class="r5-ficha__identidad">
                    <span class="r5-ficha__codigo">@_linea.Prod.CodProd</span>
                    <span class="r5-ficha__nombre">@_linea.Prod.DescProd</span>
                </div>
            </div>

            <dl class="r5-datos">
                <div><dt>Stock tienda</dt><dd>@Cantidad(_linea.StockAlm, _linea.Prod.DecimalesEnCant)</dd></div>
                <div><dt>Stock central</dt><dd>@Cantidad(_dto.StockAlmCentral, _linea.Prod.DecimalesEnCant)</dd></div>
                @if (_dto.CantYaPedida > 0)
                {
                    <div><dt>Ya pedida (pedido abierto)</dt><dd>@Cantidad(_dto.CantYaPedida, _linea.Prod.DecimalesEnCant)</dd></div>
                }
                <div><dt>Unidades por caja</dt><dd>@_linea.Prod.UnidsCaja</dd></div>
            </dl>

            <div class="r5-campo">
                <label for="cantidad">Cantidad a pedir</label>
                <div class="r5-fila">
                    <button class="r5-btn r5-btn--secundario" @onclick="() => SumarCajas(-1)"
                            disabled="@(_cantidad < _linea.Prod.UnidsCaja)">− caja</button>
                    <input id="cantidad" class="r5-input r5-input--numero" type="number" inputmode="decimal"
                           step="@(_linea.Prod.DecimalesEnCant ? "0.001" : "1")" min="0"
                           @bind="_cantidad" @bind:event="oninput" />
                    <button class="r5-btn r5-btn--secundario" @onclick="() => SumarCajas(1)">+ caja (@_linea.Prod.UnidsCaja)</button>
                </div>
            </div>

            @if (_confirmandoPedir)
            {
                @* Avisos de R3/R4 antes de grabar (ya pedido / sin stock / stock inferior /
                   sobre-stock): una confirmación explícita para todos. *@
                <div class="r5-columna" style="gap: var(--esp-2);">
                    @foreach (var aviso in _avisosPedir)
                    {
                        <Aviso Tipo="aviso" Mensaje="@aviso" ConSonido="false" />
                    }
                </div>
                <div class="r5-fila">
                    <button class="r5-btn r5-btn--primario" @onclick="ContinuarPedirAsync" disabled="@_anadiendo">
                        @(_cantidad == 0 ? "Eliminar igualmente" : "Pedir igualmente")
                    </button>
                    <button class="r5-btn r5-btn--fantasma" @onclick="() => _confirmandoPedir = false">Cancelar</button>
                </div>
            }
            else
            {
                <button class="r5-btn r5-btn--primario r5-btn--bloque" @onclick="AnadirAsync"
                        disabled="@(_anadiendo || (_cantidad <= 0 && _dto.CantYaPedida <= 0))">
                    @(_anadiendo ? "Añadiendo…"
                        : _cantidad == 0 && _dto.CantYaPedida > 0 ? "Eliminar del pedido (cantidad 0)"
                        : $"Añadir {Cantidad(_cantidad, _linea.Prod.DecimalesEnCant)} al pedido")
                </button>
            }
        </div>
    }

    <PanelLineas Items="_lineasDoc" Cargando="_cargandoLineas" Titulo="Líneas del pedido">
        <Cabecera>
            <th>Cód.</th><th>Producto</th><th class="num">Cant.</th>
        </Cabecera>
        <Fila Context="l">
            <tr @key="l.Prod.CodProd">
                <td>@l.Prod.CodProd</td>
                <td>@l.Prod.DescProd</td>
                <td class="num">@Cantidad(l.CantPedida, l.Prod.DecimalesEnCant)</td>
            </tr>
        </Fila>
    </PanelLineas>
</div>
</GuardiaModulo>

@code {
    private List<CentroDistribucion> _centros = new();
    private byte _centroDist = 1;
    private string _codigo = "";
    private bool _ocupado;
    private bool _anadiendo;
    private bool _cargandoCentros = true;
    private string _aviso = "";
    private string _tipoAviso = "error";

    private PedidoCentralLin? _linea;
    private PedidoCentralLineaSelectDTO? _dto;
    private decimal _cantidad;
    private int _ultimoPedido;
    private DateTime _ultimaFecha;
    private short _ultimoAlmCentral;
    private List<PedidoCentralLin> _lineasDoc = new();
    private bool _cargandoLineas;

    protected override Task OnInitializedAsync() => CargarCentrosAsync();

    private async Task CargarCentrosAsync()
    {
        _cargandoCentros = true;
        _aviso = "";
        try
        {
            var centros = await Pedidos.GetCentrosDistAsync();
            if (!centros.Ok) { MostrarError(centros.Error); return; }
            _centros = centros.Datos ?? new();
            if (_centros.Count > 0) _centroDist = _centros[0].CentroDist;
        }
        finally
        {
            _cargandoCentros = false;
            // El buscador está deshabilitado hasta que hay centros, así que el foco no puede
            // ir en el primer render: se da aquí, cuando el campo ya es utilizable.
            StateHasChanged();
            if (_centros.Count > 0) await JS.InvokeVoidAsync("r5.seleccionar", "busquedaPedido");
        }
    }

    // Cambiar de centro invalida la ficha cargada: su stock central y el pedido destino
    // se calcularon para el centro anterior. Se limpia y se pide re-escanear.
    private void ElegirCentro(byte centro)
    {
        if (_centroDist == centro) return;
        _centroDist = centro;
        if (_linea is not null || _dto is not null)
        {
            _linea = null;
            _dto = null;
            _tipoAviso = "info";
            _aviso = "Centro cambiado: vuelve a escanear el producto para recalcular el stock central.";
        }
    }

    private void SumarCajas(int cajas)
    {
        if (_linea is null) return;
        decimal nueva = _cantidad + cajas * _linea.Prod.UnidsCaja;
        _cantidad = nueva < 0 ? 0 : nueva;
    }

    private async Task BuscarAsync()
    {
        string codigo = _codigo.Trim();
        if (_ocupado || codigo.Length == 0 || !Sesion.Autenticado) return;

        _ocupado = true;
        _aviso = "";
        _linea = null;
        _dto = null;
        try
        {
            short codAlm = Sesion.Usuario!.Almacen.CodAlm;

            ApiRespuesta<PedidoCentralLin> respuesta;
            if (codigo.Length >= 8 && long.TryParse(codigo, out long ean))
            {
                respuesta = await Pedidos.GetLineaPorEanAsync(codAlm, ean);
            }
            else if (int.TryParse(codigo, out int codProd) && codProd > 0)
            {
                respuesta = await Pedidos.GetLineaPorProdAsync(codAlm, codProd);
            }
            else
            {
                MostrarError("Introduce un código numérico (producto o EAN).");
                return;
            }

            if (!respuesta.Ok || respuesta.Datos is null) { MostrarError(respuesta.Error); return; }
            if (respuesta.Datos.Prod.CodProd <= 0) { MostrarError($"El código {codigo} no corresponde a ningún producto."); return; }

            var dto = await Pedidos.GetLineaDtoAsync(codAlm, respuesta.Datos.Prod.CodProd,
                Sesion.Usuario.CodUsuario, _centroDist, 0);
            if (!dto.Ok || dto.Datos is null) { MostrarError(dto.Error); return; }
            if (dto.Datos.CodAlmCentral <= 0)
            {
                MostrarError($"El centro seleccionado no sirve este producto. Prueba con otro centro de distribución.");
                return;
            }

            _linea = respuesta.Datos;
            _dto = dto.Datos;
            _pedirAceptado = false;
            _confirmandoPedir = false;
            // Ya pedido: precarga la cantidad actual para modificarla (0 = eliminar).
            // Si no, arranque táctil: una caja por defecto (lo más habitual al pedir a central).
            _cantidad = _dto.CantYaPedida > 0 ? _dto.CantYaPedida : _linea.Prod.UnidsCaja;
        }
        finally
        {
            _ocupado = false;
            StateHasChanged();
            await JS.InvokeVoidAsync("r5.seleccionar", "busquedaPedido");
        }
    }

    // Confirmaciones previas al alta pendientes de aceptar.
    private bool _confirmandoPedir;
    private bool _pedirAceptado;
    private List<string> _avisosPedir = new();

    private async Task ContinuarPedirAsync()
    {
        _pedirAceptado = true;
        _confirmandoPedir = false;
        await AnadirAsync();
    }

    private async Task AnadirAsync()
    {
        // Cantidad 0 solo es válida para ELIMINAR un producto ya pedido (semántica R3/R4).
        if (_anadiendo || _linea is null || _dto is null) return;
        if (_cantidad < 0 || (_cantidad == 0 && _dto.CantYaPedida <= 0)) return;

        // Tope de sanidad: una lectura del escaner caida en el campo cantidad (>=10.000)
        // no puede acabar grabada como unidades.
        if (_cantidad >= 10000) { MostrarError($"Cantidad {_cantidad} no valida: ¿has escaneado un codigo en el campo de cantidad?"); return; }

        // --- Confirmaciones de R3/R4 antes de grabar ---
        if (!_pedirAceptado)
        {
            var avisos = new List<string>();
            bool decimales = _linea.Prod.DecimalesEnCant;

            if (_dto.CantYaPedida > 0)
            {
                avisos.Add(_cantidad == 0
                    ? $"El producto ya está pedido ({Cantidad(_dto.CantYaPedida, decimales)}): se ELIMINARÁ del pedido."
                    : $"El producto ya está pedido ({Cantidad(_dto.CantYaPedida, decimales)}): la cantidad se CAMBIARÁ a {Cantidad(_cantidad, decimales)}.");
            }

            // El control de stock del central solo aplica en los modos 2 y 4 (mismo criterio que R3/R4).
            bool controlaStock = _dto.RecibirPedCentral is 2 or 4;
            if (_cantidad > 0 && controlaStock && _dto.StockAlmCentral <= 0)
            {
                if (_linea.Prod.FueraColeccion) avisos.Add("Producto fuera de colección.");
                avisos.Add("En este momento el central NO tiene stock del producto.");
            }
            else if (_cantidad > 0 && controlaStock && _dto.StockAlmCentral < _cantidad)
            {
                avisos.Add($"Stock central ({Cantidad(_dto.StockAlmCentral, decimales)}) inferior a la cantidad pedida ({Cantidad(_cantidad, decimales)}).");
            }

            // Sobre-stock (control de R3): el stock de tienda ya supera el máximo del producto.
            if (_cantidad > 0 && _linea.Prod.StockMax is > 0 && _linea.StockAlm > _linea.Prod.StockMax)
            {
                if (!Sesion.Usuario!.Almacen.PedCentralStockMax)
                {
                    MostrarError($"No se permite el pedido con sobre-stock: el stock de tienda ({Cantidad(_linea.StockAlm, decimales)}) supera el máximo ({_linea.Prod.StockMax}).");
                    return;
                }
                avisos.Add($"Sobre-stock: el stock de tienda ({Cantidad(_linea.StockAlm, decimales)}) supera el máximo ({_linea.Prod.StockMax}).");
            }

            if (avisos.Count > 0)
            {
                _avisosPedir = avisos;
                _confirmandoPedir = true;
                return;
            }
        }

        _anadiendo = true;
        _aviso = "";
        try
        {
            var alta = new PedidoCentralLinInsertDTO
            {
                CodProd = _linea.Prod.CodProd,
                CodUsuario = Sesion.Usuario!.CodUsuario,
                CodAlm = Sesion.Usuario.Almacen.CodAlm,
                CodAlmCentral = _dto.CodAlmCentral,
                CantPedida = _cantidad,
                Fecha = _dto.Fecha,
                NumPedido = _dto.NumPedido
            };
            var respuesta = await Pedidos.PostLineaAsync(alta);
            if (!respuesta.Ok || respuesta.Datos is null) { MostrarError(respuesta.Error); return; }

            _ultimoPedido = respuesta.Datos.NumPedido;
            _ultimaFecha = respuesta.Datos.Fecha;
            _ultimoAlmCentral = _dto.CodAlmCentral;
            _tipoAviso = "exito";
            _aviso = _cantidad == 0
                ? $"{_linea.Prod.DescProd}: eliminado del pedido {_ultimoPedido}."
                : $"{_linea.Prod.DescProd}: {Cantidad(_cantidad, _linea.Prod.DecimalesEnCant)} añadido al pedido {_ultimoPedido}.";
            _linea = null;
            _dto = null;
            _codigo = "";
            _pedirAceptado = false;
            _confirmandoPedir = false;
            _ = RefrescarLineasAsync();
        }
        finally
        {
            _anadiendo = false;
            StateHasChanged();
            await JS.InvokeVoidAsync("r5.seleccionar", "busquedaPedido");
        }
    }

    // Refresca el panel de líneas sin bloquear el siguiente escaneo (ApiWeb no lanza).
    private async Task RefrescarLineasAsync()
    {
        if (_ultimoPedido <= 0) return;
        _cargandoLineas = true;
        var r = await Pedidos.GetLineasAsync(Sesion.Usuario!.Almacen.CodAlm, _ultimaFecha, _ultimoPedido);
        if (r.Ok && r.Datos is not null) _lineasDoc = r.Datos;
        _cargandoLineas = false;
        StateHasChanged();
    }

    private void MostrarError(string mensaje)
    {
        _tipoAviso = "error";
        _aviso = mensaje;
    }

    private void Volver() => Nav.NavigateTo("/pedidoCentral");

    private void VerPedido()
        => Nav.NavigateTo($"/pedidoCentral/{_ultimaFecha:yyyy-MM-dd}/{_ultimoPedido}?estado=0&almCentral={_ultimoAlmCentral}");
}
