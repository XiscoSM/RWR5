@* Preparación (lado central): el preparador ve sus preparaciones asignadas y el
   pool de pedidos cerrados pendientes de asignar. Los contadores de cada fila
   (pedidos, pendientes, preparados) dicen de un vistazo cuánto trabajo queda. *@
@page "/preparacion"
@inject PreparacionService Preparaciones
@inject SesionUsuario Sesion
@inject NavigationManager Nav

<GuardiaModulo CodMenu="24">
<div class="r5-columna">

    <div class="r5-fila">
        <div class="r5-segmento">
            <button class="@(!_verCerrados ? "activo" : "")" aria-pressed="@(!_verCerrados)" @onclick="() => CambiarVistaAsync(false)" disabled="@_cargando">Mis preparaciones</button>
            <button class="@(_verCerrados ? "activo" : "")" aria-pressed="@_verCerrados" @onclick="() => CambiarVistaAsync(true)" disabled="@_cargando">Pedidos cerrados</button>
        </div>
        @* Pedidos de la tienda online: flujo propio (api/PreparacionWww). *@
        <button class="r5-btn r5-btn--secundario" @onclick='() => Nav.NavigateTo("/preparacionWww")'>
            Pedidos web →
        </button>
        @* Asignación masiva (BAsigTodos/bPrepararAll de R3): todos los cerrados a mí. *@
        @if (_verCerrados && _preparaciones.Count > 0)
        {
            <BotonConfirmar Texto="@($"Asignarme todos ({_preparaciones.Count})")"
                            Pregunta="@($"¿Asignarte los {_preparaciones.Count} pedidos cerrados para prepararlos tú?")"
                            TextoOcupado="Asignando…" Ocupado="@_asignandoTodos"
                            OnConfirmar="AsignarTodosAsync" />
        }
        @* El pool cambia según trabajan otros preparadores: refresco manual para no
           quedarse con una foto vieja (la lista no se auto-actualiza). *@
        <button class="r5-btn r5-btn--fantasma" style="margin-left:auto" @onclick="CargarAsync" disabled="@_cargando">
            @(_cargando ? "Actualizando…" : "Actualizar")
        </button>
    </div>

    @if (_cargando)
    {
        <Cargando Texto="Cargando…" />
    }
    else if (!string.IsNullOrEmpty(_error))
    {
        <Aviso Mensaje="@_error" />
    }
    else if (_preparaciones.Count == 0)
    {
        <div class="r5-cargando">
            <Icono Nombre="preparacion" Clase="r5-modulo__icono" />
            <span>@(_verCerrados ? "No hay pedidos cerrados pendientes en este almacén." : "No tienes preparaciones asignadas.")</span>
        </div>
    }
    else
    {
        <ListaPaginada Items="_preparaciones" Context="prep">
            <Fila>
                <button @key="@($"{prep.Fecha:yyyyMMdd}-{prep.Pedido}")" class="r5-doc"
                        @onclick="() => AbrirDetalle(prep)">
                    <Icono Nombre="preparacion" Clase="r5-modulo__icono" />
                    <span class="r5-doc__principal">
                        <span class="r5-doc__titulo">Pedido @prep.Pedido · @prep.Alm.DescAlm</span>
                        <span class="r5-doc__detalle">
                            @Fecha(prep.Fecha)
                            @if (prep.CountPedidos > 1)
                            {
                                <text> · agrupa @prep.CountPedidos pedidos</text>
                            }
                        </span>
                    </span>
                    <span class="r5-doc__derecha">
                        <span class="r5-doc__detalle">@prep.Preparados preparados · @prep.CountPendientes pendientes</span>
                    </span>
                </button>
            </Fila>
        </ListaPaginada>
    }
</div>
</GuardiaModulo>

@code {
    private bool _verCerrados;
    private bool _asignandoTodos;

    // Asignación masiva (bPrepararAll de R3): bucle de asignar sobre los cerrados listados.
    private async Task AsignarTodosAsync()
    {
        if (_asignandoTodos || !Sesion.Autenticado || _preparaciones.Count == 0) return;
        _asignandoTodos = true;
        try
        {
            int ok = 0, fallos = 0;
            foreach (var p in _preparaciones.ToList())
            {
                var r = await Preparaciones.AsignarAsync(p.Fecha, p.Pedido, Sesion.Usuario!.CodUsuario);
                if (r.Ok) ok++; else fallos++;
            }
            _error = fallos > 0 ? $"{ok} pedidos asignados; {fallos} fallaron (reintenta o revisa)." : "";
        }
        finally
        {
            _asignandoTodos = false;
        }
        await CargarAsync();
    }
    private bool _cargando = true;
    private string _error = "";
    private List<PrepPedCentral> _preparaciones = new();

    protected override Task OnInitializedAsync() => CargarAsync();

    private Task CambiarVistaAsync(bool verCerrados)
    {
        if (_verCerrados == verCerrados) return Task.CompletedTask;
        _verCerrados = verCerrados;
        return CargarAsync();
    }

    private async Task CargarAsync()
    {
        if (!Sesion.Autenticado) return;

        _cargando = true;
        _error = "";
        try
        {
            short codAlm = Sesion.Usuario!.Almacen.CodAlm;
            var respuesta = _verCerrados
                ? await Preparaciones.GetPedidosCerradosAsync(codAlm)
                : await Preparaciones.GetPreparacionesAsync(codAlm, Sesion.Usuario.CodUsuario, Sesion.Usuario.Almacen.SoloConStock);
            if (!respuesta.Ok)
            {
                _error = respuesta.Error;
                _preparaciones = new();
                return;
            }
            _preparaciones = respuesta.Datos ?? new();
        }
        finally
        {
            _cargando = false;
        }
    }

    private void AbrirDetalle(PrepPedCentral prep)
        => Nav.NavigateTo($"/preparacion/{prep.Fecha:yyyy-MM-dd}/{prep.Pedido}");
}
