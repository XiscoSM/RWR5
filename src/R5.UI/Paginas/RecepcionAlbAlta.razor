@* Recepción de albarán (alta): tres pasos en una pantalla progresiva.
   1) Identificar proveedor: escaneando un producto suyo (lo habitual en el muelle)
      o tecleando su código; se elige la gama si hay varias.
   2) Nº de albarán del proveedor (papel que acompaña la mercancía).
   3) Escaneo encadenado de líneas con cajas/cantidad y precios de la condición
      de compra; la primera línea crea el albarán. Registrar al terminar. *@
@page "/recepcionAlb/alta"
@page "/recepcionAlb/alta/{FechaRuta}/{NumRuta:int}"
@inject AlbaranService Albaranes
@inject ComentarioService Comentarios
@inject ProveedorService Proveedores
@inject PedidoCompraService Pedidos
@inject DispositivoService Dispositivo
@inject SesionUsuario Sesion
@inject NavigationManager Nav
@inject IJSRuntime JS

<GuardiaModulo CodMenu="9">
<div class="r5-columna">

    <div class="r5-fila">
        <button class="r5-btn r5-btn--secundario" @onclick="Volver">← Albaranes</button>
        <h2>@(NumRuta > 0 ? "Continuar recepción" : "Nueva recepción")</h2>
        @if (_numAlbaran > 0)
        {
            <div class="r5-fila" style="margin-left:auto">
                <span class="r5-chip" style="background: var(--c-primario-claro); color: var(--c-primario-osc);">
                    Albarán @_numAlbaran · @_lineasAnadidas líneas
                </span>
                @* Comentario de cabecera del albarán (predefinidos tipo 3, como R3). *@
                <SelectorComentario TipoDoc="3" Etiqueta="Comentario albarán"
                                    NumDoc="_numAlbaran" Fecha="_fecha" />
                <button class="r5-btn r5-btn--primario" @onclick="() => _pidiendoLink = true" disabled="@_registrando">
                    Registrar recepción
                </button>
            </div>
        }
    </div>

    @if (_pidiendoLink)
    {
        @* El registro exige el "link": código de barras que une el albarán en papel con el
           documento digital (se escanea de la etiqueta pegada al papel). *@
        <form class="r5-tarjeta r5-columna r5-ancho-form" @onsubmit="RegistrarAsync">
            <h3>Registrar recepción</h3>

            @* Controles de cuadre de la gama: obligan a teclear los totales del papel y se
               cotejan contra lo grabado antes de registrar (mismo control que R3). *@
            @if (_gamaElegida is not null && _gamaElegida.Gama.ControlCant)
            {
                <div class="r5-campo">
                    <label for="ctrlCant">Cantidad total (según el albarán en papel)</label>
                    <input id="ctrlCant" class="r5-input r5-input--numero" type="number" inputmode="decimal" step="0.001"
                           @bind="_ctrlCant" disabled="@_registrando" />
                </div>
            }
            @if (_gamaElegida is not null && _gamaElegida.Gama.ControlImporte)
            {
                <div class="r5-campo">
                    <label for="ctrlImp">Importe total € (según el albarán en papel)</label>
                    <input id="ctrlImp" class="r5-input r5-input--numero" type="number" inputmode="decimal" step="0.01"
                           @bind="_ctrlImporte" disabled="@_registrando" />
                </div>
            }

            @* Link del documento según la configuración de la empresa (tri-estado R3):
               0 = no se pide, 1 = opcional (vacío o «0» registra sin link), 2 = obligatorio. *@
            @if (_nivelLink > 0)
            {
                <div class="r5-campo">
                    <label for="linkDoc">Link del documento @(_nivelLink == 1 ? "(opcional)" : "")</label>
                    <input id="linkDoc" class="r5-input r5-input--numero" type="text" inputmode="numeric" maxlength="13"
                           placeholder="Escanea la etiqueta pegada al albarán en papel"
                           @bind="_linkTexto" @bind:event="oninput" autofocus disabled="@_registrando" />
                </div>
            }
            <Aviso Tipo="@_tipoAviso" Mensaje="@_aviso" />
            <div class="r5-fila">
                <button type="submit" class="r5-btn r5-btn--primario"
                        disabled="@(_registrando || !LinkValido || FaltanControles)">
                    @(_registrando ? "Registrando…" : (_descuadreAvisado ? "Registrar igualmente" : "Confirmar registro"))
                </button>
                <button type="button" class="r5-btn r5-btn--fantasma" @onclick="CancelarRegistro">Cancelar</button>
            </div>
        </form>
    }
    else if (_gamaElegida is null)
    {
        <div class="r5-tarjeta r5-columna r5-ancho-form">
            <h3>Proveedor</h3>
            <form @onsubmit="BuscarProveedorAsync" class="r5-buscador">
                <input id="busquedaProv" class="r5-input" type="text" inputmode="numeric"
                       placeholder="Escanea un producto del proveedor o teclea su código"
                       @bind="_codigoProv" @bind:event="oninput" autofocus disabled="@_ocupado" />
                <button type="submit" class="r5-btn r5-btn--secundario" disabled="@(_ocupado || string.IsNullOrWhiteSpace(_codigoProv))">
                    Buscar
                </button>
            </form>

            <Aviso Mensaje="@(_tipoAviso == "error" ? _aviso : "")" />

            @if (_gamas.Count > 0)
            {
                <h3>Elige la condición de compra</h3>
                <div class="r5-docs">
                    @foreach (var gama in _gamas)
                    {
                        <button @key="@($"{gama.CodProv}-{gama.Gama.CodGama}")" class="r5-doc" @onclick="() => ElegirGama(gama)">
                            <Icono Nombre="recepcion" Clase="r5-modulo__icono" />
                            <span class="r5-doc__principal">
                                <span class="r5-doc__titulo">@gama.DescProv</span>
                                <span class="r5-doc__detalle">Prov. @gama.CodProv · Gama @gama.Gama.CodGama · @gama.Gama.DescGama</span>
                            </span>
                        </button>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="r5-tarjeta r5-columna">
            <div class="r5-fila" style="flex-wrap: wrap;">
                <span class="r5-texto-suave">Proveedor:</span>
                <strong>@_gamaElegida.DescProv · Gama @_gamaElegida.Gama.CodGama</strong>
                @if (_numAlbaran == 0)
                {
                    <button class="r5-btn r5-btn--fantasma" @onclick="CambiarProveedor">Cambiar</button>
                }
                @* Tope de 12 caracteres como R3: evita que una lectura de EAN del escáner
                   caiga en este campo y acabe como nº de albarán del proveedor. *@
                <div class="r5-campo" style="margin-left:auto; min-width: 220px;">
                    <label for="numAlbProv">Nº albarán del proveedor</label>
                    <input id="numAlbProv" class="r5-input" type="text" maxlength="12"
                           @bind="_numAlbProv" @bind:event="oninput" disabled="@(_numAlbaran > 0)" />
                </div>
            </div>

            @* Recepción contra pedido de compra (opcional): imputa el albarán a un pedido
               y precarga las cantidades pedidas. El nº de pedido viaja al Get de producto y
               a la línea. Se elige tecleando el número o de la lista de pendientes, y se
               confirma viendo los productos del pedido. Solo antes de la 1ª línea. *@
            @if (_pedidoConfirmado)
            {
                <div class="r5-fila">
                    <span class="r5-chip r5-chip--suave">Contra pedido @_numPedidoContra</span>
                    @if (_numAlbaran == 0)
                    {
                        <button class="r5-btn r5-btn--fantasma r5-btn--sm" @onclick="QuitarPedido">Quitar</button>
                    }
                </div>
            }
            else if (_numAlbaran == 0)
            {
                <div class="r5-columna" style="gap: var(--esp-2);">
                    <div class="r5-fila" style="flex-wrap: wrap; align-items: flex-end;">
                        <div class="r5-campo" style="min-width: 200px;">
                            <label for="numPedidoContra">Recepción contra pedido (opcional)</label>
                            <input id="numPedidoContra" class="r5-input r5-input--numero" type="text" inputmode="numeric"
                                   placeholder="Nº de pedido" @bind="_numPedidoTexto" @bind:event="oninput" disabled="@_ocupadoPedido" />
                        </div>
                        <button class="r5-btn r5-btn--secundario" @onclick="() => VerPedidoAsync(0)"
                                disabled="@(_ocupadoPedido || string.IsNullOrWhiteSpace(_numPedidoTexto))">Ver pedido</button>
                        <button class="r5-btn r5-btn--fantasma" @onclick="ListarPedidosAsync" disabled="@_ocupadoPedido">
                            Pedidos pendientes del proveedor
                        </button>
                    </div>

                    @if (_ocupadoPedido)
                    {
                        <Cargando Texto="Cargando pedido…" />
                    }
                    else if (_verLineasPedido)
                    {
                        <div class="r5-tarjeta r5-columna">
                            <h3 style="margin:0">Pedido @_pedidoPrevio · @_lineasPedido.Count líneas</h3>
                            <p class="r5-texto-suave r5-texto-sm">Comprueba que es el pedido correcto por sus productos.</p>
                            <div class="r5-tabla-scroll">
                                <table class="r5-tabla">
                                    <thead><tr><th>Cód.</th><th>Producto</th><th class="num">Pedida</th></tr></thead>
                                    <tbody>
                                        @foreach (var l in _lineasPedido)
                                        {
                                            <tr @key="l.Linea">
                                                <td>@l.Prod.CodProd</td>
                                                <td>@l.Prod.DescProd</td>
                                                <td class="num">@Cantidad(l.Cant, l.Prod.DecimalesEnCant)</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            <div class="r5-fila">
                                <button class="r5-btn r5-btn--primario" @onclick="ConfirmarPedido">Sí, recepcionar contra este pedido</button>
                                <button class="r5-btn r5-btn--fantasma" @onclick="CancelarSeleccionPedido">Cancelar</button>
                            </div>
                        </div>
                    }
                    else if (_pedidosPendientes.Count > 0)
                    {
                        <div class="r5-docs">
                            @foreach (var p in _pedidosPendientes)
                            {
                                <button @key="p.NumPedido" class="r5-doc" @onclick="() => VerPedidoAsync(p.NumPedido)">
                                    <Icono Nombre="pedido-compra" Clase="r5-modulo__icono" />
                                    <span class="r5-doc__principal">
                                        <span class="r5-doc__titulo">Pedido @p.NumPedido</span>
                                        <span class="r5-doc__detalle">@Fecha(p.Fecha) · @p.Prods prods</span>
                                    </span>
                                </button>
                            }
                        </div>
                    }
                </div>
            }

            <form @onsubmit="BuscarProductoAsync" class="r5-buscador">
                <input id="busquedaRecepcion" class="r5-input" type="text" inputmode="numeric"
                       placeholder="Escanea un EAN o teclea el código de producto"
                       @bind="_codigo" @bind:event="oninput" disabled="@_ocupado" />
                <button type="submit" class="r5-btn r5-btn--secundario"
                        disabled="@(_ocupado || string.IsNullOrWhiteSpace(_codigo) || string.IsNullOrWhiteSpace(_numAlbProv))">
                    Buscar
                </button>
                <button type="button" class="r5-btn r5-btn--fantasma" @onclick="AlternarProdsGamaAsync"
                        disabled="@(_ocupado || string.IsNullOrWhiteSpace(_numAlbProv))">
                    @(_verProdsGama ? "Ocultar productos" : "Ver productos")
                </button>
            </form>

            @* Panel de productos de la gama/pedido (modo NoIntroEanCompra y consulta de R3):
               permite elegir el producto tocándolo, sin escanear. Se abre solo si el almacén
               o la gama lo exigen; también a demanda con el botón. *@
            @if (_verProdsGama)
            {
                <div class="r5-tarjeta r5-columna">
                    <div class="r5-fila">
                        <h3 style="margin:0">Productos de la condición de compra</h3>
                        <input class="r5-input" style="max-width: 240px; margin-left:auto;" type="text"
                               placeholder="Filtrar por descripción" @bind="_filtroProds" @bind:event="oninput" />
                    </div>
                    @if (_prodsGama.Count == 0)
                    {
                        <p class="r5-texto-suave">Sin productos para esta gama.</p>
                    }
                    else
                    {
                        <div class="r5-tabla-scroll" style="max-height: 320px; overflow-y: auto;">
                            <table class="r5-tabla">
                                <thead><tr><th>Cód.</th><th>Producto</th><th class="num">Pedida</th><th class="num">Recibida</th></tr></thead>
                                <tbody>
                                    @foreach (var p in ProdsGamaFiltrados)
                                    {
                                        <tr @key="p.Prod.CodProd" style="cursor: pointer;" @onclick="() => ElegirProdGamaAsync(p)">
                                            <td>@p.Prod.CodProd</td>
                                            <td>@p.Prod.DescProd</td>
                                            <td class="num">@(p.CantPedida != 0 ? Cantidad(p.CantPedida, p.Prod.DecimalesEnCant) : "")</td>
                                            <td class="num">@(p.CantRecibida != 0 ? Cantidad(p.CantRecibida, p.Prod.DecimalesEnCant) : "")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            }
            @if (string.IsNullOrWhiteSpace(_numAlbProv))
            {
                <span class="r5-texto-suave r5-texto-sm">Introduce el nº de albarán del proveedor antes de escanear.</span>
            }
        </div>

        <Aviso Tipo="@_tipoAviso" Mensaje="@_aviso" />

        @if (_albaranRegPendiente is not null)
        {
            <div class="r5-fila">
                <button class="r5-btn r5-btn--peligro" @onclick="ModificarRegistradoAsync">Modificar la compra registrada</button>
                <button class="r5-btn r5-btn--fantasma" @onclick="Volver">Volver</button>
            </div>
        }

        @if (_ocupado)
        {
            <Cargando />
        }
        else if (_linea is not null)
        {
            <div class="r5-tarjeta r5-columna">
                <div class="r5-ficha__identidad">
                    <span class="r5-ficha__codigo">@_linea.Prod.CodProd</span>
                    <span class="r5-ficha__nombre">@_linea.Prod.DescProd</span>
                </div>

                <dl class="r5-datos">
                    <div><dt>Precio tarifa</dt><dd>@Moneda((decimal)_linea.PTarifa)</dd></div>
                    <div><dt>Precio neto (PNC)</dt><dd>@Moneda((decimal)_linea.PNC)</dd></div>
                    @if (!string.IsNullOrWhiteSpace(_linea.DtosComercialesTexto))
                    {
                        <div><dt>Dtos. comerciales</dt><dd>@_linea.DtosComercialesTexto</dd></div>
                    }
                    <div><dt>Unidades por caja</dt><dd>@UnidsCaja</dd></div>
                    @if (_linea.CantPedida > 0)
                    {
                        <div><dt>Cantidad pedida</dt><dd>@Cantidad(_linea.CantPedida, _linea.Prod.DecimalesEnCant)</dd></div>
                    }
                    <div><dt>Stock actual</dt><dd>@Cantidad(_linea.Stock, _linea.Prod.DecimalesEnCant)</dd></div>
                </dl>

                @* Aviso de doble recepción: el producto ya tiene cantidad en este albarán u otro
                   del día (mismo criterio que R3/R4: CantAlbTotal). No bloquea, informa. *@
                @if (_linea.CantAlbTotal != 0)
                {
                    <Aviso Tipo="aviso" Mensaje="@($"Ya se han recepcionado {Cantidad(_linea.CantAlbTotal, _linea.Prod.DecimalesEnCant)} de este producto.")" />
                }

                @* Trazabilidad: fecha de caducidad obligatoria si el producto la controla
                   (DiasCaducidad > 0 o perfil de compra) y lote del proveedor si controla lotes. *@
                @if (PideFechaCad || PideLote)
                {
                    <div class="r5-fila" style="flex-wrap: wrap;">
                        @if (PideFechaCad)
                        {
                            <div class="r5-campo" style="flex:1; min-width: 200px;">
                                <label for="fechaCadRec">Fecha de caducidad</label>
                                <input id="fechaCadRec" class="r5-input" type="date"
                                       @bind="_fechaCaducidad" disabled="@_anadiendo" />
                                @if (_linea.Prod.DiasCaducidad > 0)
                                {
                                    <span class="r5-texto-suave r5-texto-sm">
                                        Mínimo sin aviso: @DateTime.Today.AddDays(_linea.Prod.DiasCaducidad).ToString("dd/MM/yy") (@_linea.Prod.DiasCaducidad días)
                                    </span>
                                }
                            </div>
                        }
                        @if (PideLote)
                        {
                            <div class="r5-campo" style="flex:1; min-width: 200px;">
                                <label for="loteProvRec">Lote del proveedor</label>
                                <input id="loteProvRec" class="r5-input" type="text" maxlength="20"
                                       @bind="_loteProv" @bind:after="BuscarLoteAsync" disabled="@_anadiendo" />
                            </div>
                        }
                    </div>
                }

                @* Lote ya recibido en este albarán (SelectLoteBD de R3): se recupera su
                   trazabilidad y la cantidad tecleada pasa a ser el TOTAL del lote. *@
                @if (_lineaLote > 0)
                {
                    <Aviso Tipo="aviso" Mensaje="@($"El lote «{_loteProv}» ya tiene {Cantidad(_cantAntLote, _linea.Prod.DecimalesEnCant)} recibido en este albarán. La cantidad que introduzcas será el TOTAL del lote (reemplaza la línea {_lineaLote}).")" />
                }

                @* Datos legales de trazabilidad cárnica según el perfil de compra del
                   producto (Compra_* de R3): cada campo solo aparece si su flag lo pide. *@
                @if (TieneTraza)
                {
                    <div class="r5-columna" style="gap: var(--esp-3); border: 1px solid var(--c-borde); border-radius: 10px; padding: 12px;">
                        <strong>Trazabilidad</strong>
                        <div class="r5-fila" style="flex-wrap: wrap;">
                            @if (_linea.CompraCrotal > 0)
                            {
                                <div class="r5-campo" style="flex:2; min-width: 240px;">
                                    <label for="crotalRec">Crotal (o etiqueta GS1-128)</label>
                                    <input id="crotalRec" class="r5-input" type="text" maxlength="40"
                                           @bind="_traza.Crotal" @bind:after="DecodificarCrotal" disabled="@_anadiendo" />
                                </div>
                            }
                            @if (_linea.CompraCategoria > 0)
                            {
                                <div class="r5-campo" style="min-width: 130px;">
                                    <label for="categoriaRec">Categoría</label>
                                    <input id="categoriaRec" class="r5-input" type="text" maxlength="3"
                                           placeholder="p. ej. AU3" @bind="_traza.Categoria" disabled="@_anadiendo" />
                                </div>
                            }
                            @if (_linea.CompraCanal > 0)
                            {
                                <div class="r5-campo" style="min-width: 120px;">
                                    <label for="canalRec">Canal</label>
                                    <input id="canalRec" class="r5-input r5-input--numero" type="number" inputmode="numeric" min="1"
                                           @bind="_traza.Canal" disabled="@_anadiendo" />
                                </div>
                            }
                        </div>
                        <div class="r5-fila" style="flex-wrap: wrap;">
                            @if (_linea.CompraPaisNac > 0)
                            {
                                <div class="r5-campo" style="min-width: 150px;">
                                    <label for="paisNacRec">País nacimiento</label>
                                    <input id="paisNacRec" class="r5-input" type="text" maxlength="2" style="text-transform: uppercase;"
                                           @bind="_traza.PaisNac" disabled="@_anadiendo" />
                                    <span class="r5-texto-suave r5-texto-sm">@NombrePais(_traza.PaisNac)</span>
                                </div>
                            }
                            @if (_linea.CompraPaisEng > 0)
                            {
                                <div class="r5-campo" style="min-width: 150px;">
                                    <label for="paisEngRec">País engorde</label>
                                    <input id="paisEngRec" class="r5-input" type="text" maxlength="2" style="text-transform: uppercase;"
                                           @bind="_traza.PaisEng" disabled="@_anadiendo" />
                                    <span class="r5-texto-suave r5-texto-sm">@NombrePais(_traza.PaisEng)</span>
                                </div>
                            }
                            @if (_linea.CompraPaisSac > 0)
                            {
                                <div class="r5-campo" style="min-width: 150px;">
                                    <label for="paisSacRec">País sacrificio</label>
                                    <input id="paisSacRec" class="r5-input" type="text" maxlength="2" style="text-transform: uppercase;"
                                           @bind="_traza.PaisSac" disabled="@_anadiendo" />
                                    <span class="r5-texto-suave r5-texto-sm">@NombrePais(_traza.PaisSac)</span>
                                </div>
                            }
                        </div>
                        <div class="r5-fila" style="flex-wrap: wrap;">
                            @if (_linea.CompraRegSanitarioSac > 0)
                            {
                                <div class="r5-campo" style="flex:1; min-width: 200px;">
                                    <label for="regSacRec">Reg. sanitario sacrificio</label>
                                    <input id="regSacRec" class="r5-input" type="text" maxlength="30" style="text-transform: uppercase;"
                                           @bind="_traza.RegSanitarioSac" disabled="@_anadiendo" />
                                </div>
                            }
                            @if (_linea.CompraRegSanitarioDesp > 0)
                            {
                                <div class="r5-campo" style="flex:1; min-width: 200px;">
                                    <label for="regDespRec">Reg. sanitario despiece</label>
                                    <input id="regDespRec" class="r5-input" type="text" maxlength="30" style="text-transform: uppercase;"
                                           @bind="_traza.RegSanitarioDesp" disabled="@_anadiendo" />
                                </div>
                            }
                        </div>
                        <div class="r5-fila" style="flex-wrap: wrap;">
                            @if (_linea.CompraFechaNac > 0)
                            {
                                <div class="r5-campo" style="min-width: 180px;">
                                    <label for="fechaNacRec">Fecha nacimiento</label>
                                    <input id="fechaNacRec" class="r5-input" type="date" @bind="_traza.FechaNac" disabled="@_anadiendo" />
                                </div>
                            }
                            @if (_linea.CompraFechaSac > 0)
                            {
                                <div class="r5-campo" style="min-width: 180px;">
                                    <label for="fechaSacRec">Fecha sacrificio</label>
                                    <input id="fechaSacRec" class="r5-input" type="date" @bind="_traza.FechaSac" disabled="@_anadiendo" />
                                </div>
                            }
                            @if (_linea.CompraEstiba > 0)
                            {
                                <label class="r5-fila" style="gap: var(--esp-2); cursor: pointer; align-self: flex-end;">
                                    <input type="checkbox" @bind="_traza.EstibaOk" disabled="@_anadiendo" />
                                    <span>Estiba OK</span>
                                </label>
                            }
                            @if (_linea.CompraTemperatura > 0)
                            {
                                <label class="r5-fila" style="gap: var(--esp-2); cursor: pointer; align-self: flex-end;">
                                    <input type="checkbox" @bind="_traza.TempOk" disabled="@_anadiendo" />
                                    <span>Temperatura OK</span>
                                </label>
                            }
                        </div>
                    </div>
                }

                @* Precio abierto: la condición de compra permite teclear el precio real
                   (solo sin pedido, como R3). Vacío = usar el PNC de la condición. *@
                @if (_linea.PrecioAbierto && _numPedidoContra == 0)
                {
                    <div class="r5-campo" style="max-width: 260px;">
                        <label for="precioAbiertoRec">Precio de compra (abierto)</label>
                        <input id="precioAbiertoRec" class="r5-input r5-input--numero" type="number" inputmode="decimal"
                               step="0.01" min="0.10" max="999" placeholder="@Moneda((decimal)_linea.PNC)"
                               @bind="_precioAbierto" disabled="@_anadiendo" />
                        <span class="r5-texto-suave r5-texto-sm">Entre 0,10 y 999 €. Vacío = precio de la condición.</span>
                    </div>
                }

                <div class="r5-fila" style="flex-wrap: wrap;">
                    <label class="r5-fila" style="gap: var(--esp-2); cursor: pointer;">
                        <input type="checkbox" @bind="_sinCargo" disabled="@_anadiendo" />
                        <span>Mercancía sin cargo (no se factura)</span>
                    </label>
                    @* Comentario de LÍNEA (predefinidos tipo 2, incluye las anotaciones
                       S.Cargo): se adjunta y se graba con la línea al añadirla. *@
                    <SelectorComentario @ref="_selectorComentLinea" TipoDoc="2" Etiqueta="Comentario línea"
                                        OnComentarioListo="t => _comentarioLinea = t" />
                </div>

                <div class="r5-fila">
                    <div class="r5-campo" style="flex:1">
                        <label for="cajasRec">Cajas</label>
                        <input id="cajasRec" class="r5-input r5-input--numero" type="text" inputmode="numeric"
                               value="@_cajas" @oninput="CambioCajas" />
                    </div>
                    <div class="r5-campo" style="flex:1">
                        <label for="cantRec">Cantidad</label>
                        <input id="cantRec" class="r5-input r5-input--numero" type="number" inputmode="decimal"
                               step="@(_linea.Prod.DecimalesEnCant ? "0.001" : "1")"
                               @bind="_cantidad" @bind:event="oninput" />
                        <span class="r5-texto-suave r5-texto-sm">Negativa = devolución.</span>
                    </div>
                </div>

                @if (_confirmarCadCorta)
                {
                    @* Fecha de caducidad corta: aviso con confirmación explícita (SIN comentario
                       automático: decisión de 15/07/26, igual que R3 actual y R4). *@
                    <Aviso Tipo="aviso" Mensaje="@($"Fecha de caducidad corta: {_fechaCaducidad:dd/MM/yy} está a menos de {_linea.Prod.DiasCaducidad} días. ¿Continuar?")" />
                    <div class="r5-fila">
                        <button class="r5-btn r5-btn--primario" @onclick="ContinuarCadCortaAsync" disabled="@_anadiendo">Continuar igualmente</button>
                        <button class="r5-btn r5-btn--fantasma" @onclick="() => _confirmarCadCorta = false">Corregir fecha</button>
                    </div>
                }
                else
                {
                    <button class="r5-btn r5-btn--primario r5-btn--bloque" @onclick="AnadirAsync"
                            disabled="@(_anadiendo || _cantidad == 0 || (_linea.Prod.DiasCaducidad > 0 && _fechaCaducidad is null))">
                        @(_anadiendo ? "Añadiendo…" : $"Añadir {Cantidad(_cantidad, _linea.Prod.DecimalesEnCant)} al albarán")
                    </button>
                }
            </div>
        }

        <PanelLineas Items="_lineasDoc" Cargando="_cargandoLineas" Titulo="Líneas del albarán">
            <Cabecera>
                <th>Cód.</th><th>Producto</th><th class="num">Cajas</th><th class="num">Cant.</th>
            </Cabecera>
            <Fila Context="l">
                <tr @key="l.Linea">
                    <td>@l.Prod.CodProd</td>
                    <td>@l.Prod.DescProd</td>
                    <td class="num">@l.Cajas</td>
                    <td class="num">@Cantidad(l.Cant, l.Prod.DecimalesEnCant)</td>
                </tr>
            </Fila>
        </PanelLineas>
    }
</div>
</GuardiaModulo>

@code {
    // Reanudación: si la ruta trae fecha+número, se carga ese albarán pendiente
    // y se sigue añadiendo líneas sobre él (paridad con "Continuar" de R3).
    [Parameter] public string? FechaRuta { get; set; }
    [Parameter] public int NumRuta { get; set; }

    private string _codigoProv = "";
    private List<Proveedor> _gamas = new();
    private Proveedor? _gamaElegida;
    private string _numAlbProv = "";

    private string _codigo = "";
    private bool _ocupado;
    private bool _anadiendo;
    private bool _registrando;
    private bool _enfocarAlbaran;
    private string _aviso = "";
    private string _tipoAviso = "error";

    // Reanudación de un albarán pendiente: carga cabecera y líneas y deja el flujo
    // exactamente donde estaba (proveedor/gama fijados, escáner listo).
    protected override async Task OnInitializedAsync()
    {
        // Nivel de exigencia del link del documento (ConfEmpresa, vía ApiInfo). Si la
        // llamada falla se mantiene el nivel 2 (obligatorio), el comportamiento seguro.
        var info = await Dispositivo.ProbarApiAsync();
        if (info.Ok && info.Datos is not null) _nivelLink = info.Datos.NivelLink;

        await CargarAlbaranRutaAsync();
    }

    private bool _modificarRegistradoAceptado;
    private Albaran? _albaranRegPendiente;

    // El operario confirmó modificar una compra ya registrada (Bcontinuar de R3).
    private async Task ModificarRegistradoAsync()
    {
        _modificarRegistradoAceptado = true;
        _albaranRegPendiente = null;
        _aviso = "";
        await CargarAlbaranRutaAsync();
    }

    private async Task CargarAlbaranRutaAsync()
    {
        if (NumRuta <= 0 || string.IsNullOrEmpty(FechaRuta)
            || !DateTime.TryParse(FechaRuta, out DateTime fecha)) return;

        _ocupado = true;
        try
        {
            var cab = await Albaranes.GetCabeceraAsync(NumRuta, fecha);
            if (!cab.Ok || cab.Datos is null || cab.Datos.NumAlbaran <= 0)
            {
                MostrarError($"No se pudo cargar el albarán {NumRuta}: {cab.Error}");
                return;
            }
            if (cab.Datos.Reg && !_modificarRegistradoAceptado)
            {
                // R3 permite modificar una compra registrada tras confirmar (Bcontinuar):
                // se avisa y se exige un toque explícito antes de cargarla.
                _albaranRegPendiente = cab.Datos;
                _tipoAviso = "aviso";
                _aviso = $"El albarán {NumRuta} YA ESTÁ REGISTRADO. ¿Seguro que quieres modificar una compra registrada?";
                return;
            }

            _fecha = fecha;
            _numAlbaran = cab.Datos.NumAlbaran;
            _gamaElegida = cab.Datos.Prov;
            _numAlbProv = cab.Datos.NumAlbProv;
            _numPedidoContra = cab.Datos.NumPedido;
            _pedidoConfirmado = cab.Datos.NumPedido > 0;
            _dupComprobado = true; // el albarán ya existe: el aviso de duplicado no aplica
            await RefrescarLineasAsync();
            _lineasAnadidas = _lineasDoc.Count;
        }
        finally
        {
            _ocupado = false;
        }
    }

    // Foco directo al buscador de proveedor al entrar (el autofocus de Blazor no dispara
    // al navegar) y, después, al nº de albarán en cuanto aparece (tras elegir gama): el
    // operario debe teclearlo antes de escanear productos.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Al reanudar, el proveedor ya está fijado: el foco va directo al escáner.
            await JS.InvokeVoidAsync("r5.seleccionar", _numAlbaran > 0 ? "busquedaRecepcion" : "busquedaProv");
            return;
        }
        if (_enfocarAlbaran)
        {
            _enfocarAlbaran = false;
            await JS.InvokeVoidAsync("r5.seleccionar", "numAlbProv");
        }
    }

    private AlbaranLin? _linea;
    private long _eanEscaneado;
    private short _cajas;
    private decimal _cantidad;
    private int _numAlbaran;
    private int _lineasAnadidas;
    private List<AlbaranLin> _lineasDoc = new();
    private bool _cargandoLineas;
    private DateTime _fecha = DateTime.Today;   // al reanudar se toma la del albarán

    // Trazabilidad de la línea en curso (F1.1): caducidad obligatoria si DiasCaducidad>0,
    // lote del proveedor si el producto controla lotes. Se limpian al añadir.
    private DateTime? _fechaCaducidad;
    private string _loteProv = "";
    private bool _confirmarCadCorta;   // aviso de caducidad corta pendiente de confirmar
    private bool _cadCortaAceptada;    // el operario ya aceptó la fecha corta de ESTA línea

    // Precio abierto y sin cargo (F1.2).
    private decimal? _precioAbierto;
    private bool _sinCargo;

    // Comentario de línea diferido: se graba justo después de insertar la línea.
    private string _comentarioLinea = "";
    private SelectorComentario? _selectorComentLinea;

    // Aviso (no bloqueante) de nº de albarán de proveedor duplicado: se comprueba una vez.
    private bool _dupComprobado;

    // Cuadre al registrar (ControlCant/ControlImporte de la gama).
    private decimal? _ctrlCant;
    private decimal? _ctrlImporte;
    private bool _descuadreAvisado;    // ya se avisó del descuadre: el siguiente submit registra

    // Con control activo, el total del papel es obligatorio (como en R3).
    private bool FaltanControles =>
        _gamaElegida is not null &&
        ((_gamaElegida.Gama.ControlCant && _ctrlCant is null) ||
         (_gamaElegida.Gama.ControlImporte && _ctrlImporte is null));

    private void CancelarRegistro()
    {
        _pidiendoLink = false;
        _descuadreAvisado = false;
        _aviso = "";
    }

    // Recepción contra pedido de compra (opcional).
    private string _numPedidoTexto = "";
    private int _numPedidoContra;           // pedido confirmado al que se imputa el albarán (0 = libre)
    private bool _pedidoConfirmado;
    private bool _ocupadoPedido;
    private bool _verLineasPedido;          // mostrando las líneas del pedido para confirmar
    private int _pedidoPrevio;              // pedido en previsualización
    private List<PedidoCompra> _pedidosPendientes = new();
    private List<PedidoCompraLin> _lineasPedido = new();

    private short UnidsCaja => _linea is null ? (short)1
        : (_linea.UnidsCaja > 0 ? _linea.UnidsCaja : (_linea.Prod.UnidsCaja > 0 ? _linea.Prod.UnidsCaja : (short)1));

    private async Task BuscarProveedorAsync()
    {
        string codigo = _codigoProv.Trim();
        if (_ocupado || codigo.Length == 0) return;

        _ocupado = true;
        _aviso = "";
        _gamas = new();
        try
        {
            ApiRespuesta<List<Proveedor>> respuesta;
            if (codigo.Length >= 8 && long.TryParse(codigo, out long ean))
            {
                respuesta = await Proveedores.GetGamasPorEanAsync(ean);
            }
            else if (int.TryParse(codigo, out int codProv) && codProv > 0)
            {
                respuesta = await Proveedores.GetGamasPorProvAsync(codProv);
            }
            else
            {
                MostrarError("Introduce un EAN o un código de proveedor numérico.");
                return;
            }

            if (!respuesta.Ok || respuesta.Datos is null) { MostrarError(respuesta.Error); return; }
            if (respuesta.Datos.Count == 0) { MostrarError("Sin condiciones de compra para ese código."); return; }

            _gamas = respuesta.Datos;
            if (_gamas.Count == 1) ElegirGama(_gamas[0]);
        }
        finally
        {
            _ocupado = false;
        }
    }

    private void ElegirGama(Proveedor gama)
    {
        _gamaElegida = gama;
        _aviso = "";
        _enfocarAlbaran = true; // el siguiente paso es teclear el nº de albarán del proveedor
        // Modo sin EAN (NoIntroEanCompra del almacén o del proveedor, R3): el panel de
        // productos se abre solo y el operario elige tocando.
        if (Sesion.Usuario!.Almacen.NoIntroEanCompra || gama.Gama.NoIntroEanCompra)
            _ = AbrirPanelProdsAsync();
    }

    private async Task AbrirPanelProdsAsync()
    {
        await CargarProdsGamaAsync();
        _verProdsGama = true;
        StateHasChanged();
    }

    private void CambiarProveedor()
    {
        _gamaElegida = null;
        _gamas = new();
        _linea = null;
        _aviso = "";
        // Los pedidos son por proveedor: cambiar de proveedor invalida la selección.
        QuitarPedido();
        _numPedidoTexto = "";
        _pedidosPendientes = new();
        CancelarSeleccionPedido();
    }

    // --- Recepción contra pedido ---

    // Previsualiza las líneas de un pedido (por nº tecleado si num=0, o el de la lista)
    // para que el operario confirme que es el correcto antes de imputarle el albarán.
    private async Task VerPedidoAsync(int num)
    {
        int pedido = num;
        if (pedido == 0 && !int.TryParse(_numPedidoTexto.Trim(), out pedido)) { MostrarError("Introduce un nº de pedido válido."); return; }
        if (_ocupadoPedido || pedido <= 0) return;

        _ocupadoPedido = true;
        _aviso = "";
        _verLineasPedido = false;
        try
        {
            var r = await Pedidos.GetLineasAsync(pedido);
            if (!r.Ok) { MostrarError(r.Error); return; }
            _lineasPedido = r.Datos ?? new();
            if (_lineasPedido.Count == 0) { MostrarError($"El pedido {pedido} no tiene líneas o no existe."); return; }
            _pedidoPrevio = pedido;
            _verLineasPedido = true;
            _pedidosPendientes = new(); // colapsa la lista al pasar a previsualizar
        }
        finally
        {
            _ocupadoPedido = false;
        }
    }

    // Lista los pedidos de compra pendientes del proveedor elegido (filtrado en cliente).
    private async Task ListarPedidosAsync()
    {
        if (_ocupadoPedido || _gamaElegida is null || !Sesion.Autenticado) return;

        _ocupadoPedido = true;
        _aviso = "";
        _verLineasPedido = false;
        try
        {
            var r = await Pedidos.GetPedidosAsync(Sesion.Usuario!.Almacen.CodAlm, Sesion.Usuario.CodUsuario, reg: false);
            if (!r.Ok) { MostrarError(r.Error); return; }
            _pedidosPendientes = (r.Datos ?? new()).Where(p => p.Prov.CodProv == _gamaElegida.CodProv).ToList();
            if (_pedidosPendientes.Count == 0) MostrarError("Este proveedor no tiene pedidos de compra pendientes.");
        }
        finally
        {
            _ocupadoPedido = false;
        }
    }

    private void ConfirmarPedido()
    {
        _numPedidoContra = _pedidoPrevio;
        _pedidoConfirmado = true;
        _verLineasPedido = false;
        _pedidosPendientes = new();
        _lineasPedido = new();
        _tipoAviso = "info";
        _aviso = $"Recepcionando contra el pedido {_numPedidoContra}: los productos vendrán con su cantidad pedida.";
    }

    private void CancelarSeleccionPedido()
    {
        _verLineasPedido = false;
        _pedidoPrevio = 0;
        _lineasPedido = new();
    }

    private void QuitarPedido()
    {
        _pedidoConfirmado = false;
        _numPedidoContra = 0;
    }

    // Cajas y cantidad van ligadas: cambiar cajas recalcula cantidad (cajas × unids/caja).
    private void CambioCajas(ChangeEventArgs e)
    {
        if (short.TryParse(e.Value?.ToString(), out short cajas) && cajas >= 0)
        {
            _cajas = cajas;
            _cantidad = cajas * UnidsCaja;
        }
    }

    private async Task BuscarProductoAsync()
    {
        string codigo = _codigo.Trim();
        if (_ocupado || codigo.Length == 0 || _gamaElegida is null || !Sesion.Autenticado) return;

        // Sin nº de albarán del proveedor no se puede recepcionar: avisar (con sonido) en vez
        // de que el Enter del escáner no haga nada de forma silenciosa.
        if (string.IsNullOrWhiteSpace(_numAlbProv))
        {
            MostrarError("Introduce primero el nº de albarán del proveedor.");
            _codigo = "";
            _enfocarAlbaran = true;
            return;
        }

        _ocupado = true;
        _aviso = "";
        _linea = null;
        _eanEscaneado = 0;
        try
        {
            short codAlm = Sesion.Usuario!.Almacen.CodAlm;

            ApiRespuesta<AlbaranLin> respuesta;
            if (codigo.Length >= 8 && long.TryParse(codigo, out long ean))
            {
                respuesta = await Albaranes.GetLineaPorEanAsync(_numAlbaran, _fecha, ean, codAlm,
                    _gamaElegida.CodProv, _gamaElegida.Gama.CodGama, _numPedidoContra);
                _eanEscaneado = ean;
            }
            else if (int.TryParse(codigo, out int codProd) && codProd > 0)
            {
                // Teclear el código exige permiso: producto en consultas o código de
                // proveedor en compras (RW_CodProdEnConsultas / RW_CodProvEnCompras de R3).
                // Elegir del panel de la gama no lo exige (equivale al grid de R3).
                if (!_desdePanel && !Sesion.Usuario.CodProdEnConsultas && !Sesion.Usuario.CodProvEnCompras)
                { MostrarError("Escanea el código de barras: no tienes permiso para buscar por código."); return; }
                _desdePanel = false;
                respuesta = await Albaranes.GetLineaPorProdAsync(_numAlbaran, _fecha, codProd, codAlm,
                    _gamaElegida.CodProv, _gamaElegida.Gama.CodGama, _numPedidoContra);
            }
            else
            {
                MostrarError("Introduce un código numérico (producto o EAN).");
                return;
            }

            if (!respuesta.Ok || respuesta.Datos is null) { MostrarError(respuesta.Error); return; }
            if (respuesta.Datos.Prod.CodProd <= 0) { MostrarError($"El código {codigo} no corresponde a ningún producto de este proveedor."); return; }

            _linea = respuesta.Datos;
            _cajas = 1;
            // EAN de balanza/peso variable: la cantidad viene embebida en el código
            // (port de EanProdLote de R3); si no, arranque por caja.
            var parseado = CodigoBarras.TryParse(codigo);
            _cantidad = parseado is { TraeCantidad: true } ? parseado.Cant : UnidsCaja;
            // Estado de trazabilidad/extras de la línea nueva.
            _fechaCaducidad = null;
            _loteProv = "";
            _precioAbierto = null;
            _sinCargo = false;
            _confirmarCadCorta = false;
            _cadCortaAceptada = false;
            LimpiarTrazabilidad();
            // Caducidad automática (R3: Compra_FechaCad=1 + FechaCadAuto): se precarga
            // fecha del documento + DiasCaducidad + 1; el operario puede corregirla.
            if (_linea is not null && _linea.CompraFechaCad == 1 && _linea.CompraFechaCadAuto)
                _fechaCaducidad = _fecha.AddDays(_linea.Prod.DiasCaducidad + 1);

            // Aviso de duplicado (una sola vez, antes de crear el albarán): si el usuario ya
            // tiene un albarán de este proveedor con el mismo nº de proveedor, probablemente
            // esté recepcionando dos veces el mismo papel. No bloquea: informa.
            if (!_dupComprobado && _numAlbaran == 0)
            {
                _dupComprobado = true;
                await AvisarSiAlbaranDuplicadoAsync();
            }
        }
        finally
        {
            _ocupado = false;
            StateHasChanged();
            await JS.InvokeVoidAsync("r5.seleccionar", "busquedaRecepcion");
        }
    }

    // Busca en los albaranes del usuario (pendientes y registrados) uno del mismo proveedor
    // con el mismo nº de albarán de proveedor. Mejor esfuerzo: si falla, no molesta.
    private async Task AvisarSiAlbaranDuplicadoAsync()
    {
        if (_gamaElegida is null || !Sesion.Autenticado) return;
        string numProv = _numAlbProv.Trim();
        if (numProv.Length == 0) return;

        short codAlm = Sesion.Usuario!.Almacen.CodAlm;
        short codUsuario = Sesion.Usuario.CodUsuario;
        foreach (bool reg in new[] { false, true })
        {
            var r = await Albaranes.GetAlbaranesAsync(codAlm, codUsuario, reg);
            var dup = r.Datos?.FirstOrDefault(a =>
                a.Prov.CodProv == _gamaElegida.CodProv &&
                string.Equals(a.NumAlbProv?.Trim(), numProv, StringComparison.OrdinalIgnoreCase));
            if (dup is not null)
            {
                _tipoAviso = "aviso";
                _aviso = $"Ojo: ya existe el albarán {dup.NumAlbaran} del {Fecha(dup.Fecha)} ({(dup.Reg ? "registrado" : "pendiente")}) con el nº de proveedor «{numProv}». Comprueba que no está duplicado.";
                return;
            }
        }
    }

    // ---- Panel de productos de la gama (NoIntroEanCompra + consulta, R3) ----
    private bool _desdePanel;
    private bool _verProdsGama;
    private List<AlbaranLin> _prodsGama = new();
    private string _filtroProds = "";

    private IEnumerable<AlbaranLin> ProdsGamaFiltrados => _filtroProds.Trim().Length == 0
        ? _prodsGama
        : _prodsGama.Where(p => p.Prod.DescProd.Contains(_filtroProds.Trim(), StringComparison.OrdinalIgnoreCase));

    private async Task AlternarProdsGamaAsync()
    {
        if (_verProdsGama) { _verProdsGama = false; return; }
        await CargarProdsGamaAsync();
        _verProdsGama = true;
    }

    private async Task CargarProdsGamaAsync()
    {
        if (_gamaElegida is null || !Sesion.Autenticado) return;
        var r = await Albaranes.GetProdsPorGamaAsync(_numAlbaran, _fecha,
            _gamaElegida.Gama.CodGama, Sesion.Usuario!.Almacen.CodAlm);
        _prodsGama = r.Datos ?? new();
        if (!r.Ok) MostrarError(r.Error);
    }

    // Producto elegido del panel: mismo flujo que teclear su código (sin exigir el
    // permiso de teclear, como el grid de R3).
    private async Task ElegirProdGamaAsync(AlbaranLin p)
    {
        _codigo = p.Prod.CodProd.ToString();
        _verProdsGama = false;
        _desdePanel = true;
        await BuscarProductoAsync();
    }

    // ---- Trazabilidad cárnica (perfil Compra_* de R3) ----
    private DatosTrazabilidad _traza = new();
    // Lote ya recibido en el albarán: línea a reemplazar y cantidad acumulada (CantAnt de R3).
    private int _lineaLote;
    private decimal _cantAntLote;
    private bool _totalLoteAceptado;
    private bool _cantGrandeAceptada;

    // Lote tecleado: si ya existe en el albarán se recupera su trazabilidad previa y se
    // avisa de la cantidad acumulada (SelectLoteBD de R3, 9_Compras.vb:3353-3387).
    private async Task BuscarLoteAsync()
    {
        _lineaLote = 0;
        _cantAntLote = 0;
        _totalLoteAceptado = false;
        string lote = _loteProv.Trim().ToUpperInvariant();
        _loteProv = lote;
        if (_linea is null || lote.Length == 0 || _numAlbaran <= 0) return;

        var r = await Albaranes.GetLineaPorLoteAsync(_numAlbaran, _fecha, _linea.Prod.CodProd, lote);
        if (!r.Ok || r.Datos is null || r.Datos.Linea <= 0) return;

        var previo = r.Datos;
        _lineaLote = previo.Linea;
        _cantAntLote = previo.Cant;
        // Se precarga la trazabilidad previa del lote; el operario puede corregirla.
        _traza.Canal = previo.DatosCanal;
        if (previo.DatosCategoria.Length > 0) _traza.Categoria = previo.DatosCategoria;
        if (previo.DatosCrotal.Length > 0) _traza.Crotal = previo.DatosCrotal;
        _traza.EstibaOk = previo.DatosEstibaOk;
        _traza.TempOk = previo.DatosTempOk;
        if (previo.DatosFechaCad is not null) _fechaCaducidad = previo.DatosFechaCad;
        if (previo.DatosFechaNac is not null) _traza.FechaNac = previo.DatosFechaNac;
        if (previo.DatosFechaSac is not null) _traza.FechaSac = previo.DatosFechaSac;
        if (previo.DatosPaisNac.Length > 0) _traza.PaisNac = previo.DatosPaisNac;
        if (previo.DatosPaisEng.Length > 0) _traza.PaisEng = previo.DatosPaisEng;
        if (previo.DatosPaisSac.Length > 0) _traza.PaisSac = previo.DatosPaisSac;
        if (previo.DatosRegSanitarioSac.Length > 0) _traza.RegSanitarioSac = previo.DatosRegSanitarioSac;
        StateHasChanged();
    }

    private bool PideFechaCad => _linea is not null && (_linea.Prod.DiasCaducidad > 0 || _linea.CompraFechaCad > 0);
    private bool PideLote => _linea is not null && (_linea.Prod.ControlaLotes || _linea.CompraLoteProv);
    private bool TieneTraza => _linea is not null &&
        (_linea.CompraCrotal + _linea.CompraCategoria + _linea.CompraCanal
         + _linea.CompraPaisNac + _linea.CompraPaisEng + _linea.CompraPaisSac
         + _linea.CompraRegSanitarioSac + _linea.CompraRegSanitarioDesp
         + _linea.CompraFechaNac + _linea.CompraFechaSac
         + _linea.CompraEstiba + _linea.CompraTemperatura) > 0;

    private static string NombrePais(string iso2)
        => iso2.Trim().Length == 2 ? Paises.PorIso2(iso2)?.Nombre ?? "país no válido" : "";

    // Crotal tecleado o etiqueta GS1-128 escaneada (DecoEan128Ternera de R3): el AI 251
    // es el crotal y el AI 7030 trae país numérico + reg. sanitario de sacrificio.
    private void DecodificarCrotal()
    {
        string texto = _traza.Crotal.Trim();
        if (texto.Length == 0) return;

        var gs1 = CodigoBarras.TryParseTernera(texto);
        if (gs1 is null) { MostrarError($"«{texto}»: EAN128 no válido."); _traza.Crotal = ""; return; }

        _traza.Crotal = gs1.Crotal;
        if (gs1.PaisNum > 0 && _linea is not null)
        {
            var pais = Paises.PorNumero(gs1.PaisNum);
            if (pais is not null)
            {
                if (_linea.CompraPaisSac > 0) _traza.PaisSac = pais.Iso2;
                if (_linea.CompraRegSanitarioSac > 0 && gs1.RegSanitarioSac.Length > 0)
                    _traza.RegSanitarioSac = gs1.RegSanitarioSac;
            }
        }
        // El crotal empieza por el país: se valida y se propaga al país de nacimiento (R3).
        if (_traza.Crotal.Length >= 4 && _linea is not null)
        {
            string prefijo = _traza.Crotal[..2];
            if (Paises.PorIso2(prefijo) is not null && _linea.CompraPaisNac > 0 && _traza.PaisNac.Length == 0)
                _traza.PaisNac = prefijo;
        }
        _aviso = "";
    }

    // Validaciones de ErrorValidaciones de R3 (9_Compras.vb:3241-3464) aplicadas de golpe
    // al añadir. Devuelve null si todo es correcto.
    private string? ValidarTrazabilidad()
    {
        if (_linea is null) return null;

        if (_linea.CompraCrotal > 0)
        {
            if (_traza.Crotal.Trim().Length < 4) return "Crotal no válido (mínimo 4 caracteres).";
            if (Paises.PorIso2(_traza.Crotal[..2]) is null) return "País del crotal no válido.";
        }
        if (_linea.CompraCategoria > 0)
        {
            // Patrón de R3: [AEDBC][SEUROP][1-5] (sexo/edad + conformación + engrasamiento).
            _traza.Categoria = _traza.Categoria.Trim().ToUpperInvariant();
            if (!System.Text.RegularExpressions.Regex.IsMatch(_traza.Categoria, "^[AEDBC][SEUROP][1-5]$"))
                return $"Categoría «{_traza.Categoria}» no válida (formato letra+letra+número, p. ej. AU3).";
        }
        if (_linea.CompraCanal > 0 && _traza.Canal <= 0) return "Obligatorio rellenar el canal.";
        foreach (var (flag, valor, nombre) in new[]
        {
            (_linea.CompraPaisNac, _traza.PaisNac, "país de nacimiento"),
            (_linea.CompraPaisEng, _traza.PaisEng, "país de engorde"),
            (_linea.CompraPaisSac, _traza.PaisSac, "país de sacrificio")
        })
        {
            if (flag == 0) continue;
            if (Paises.PorIso2(valor) is null) return $"Código de {nombre} no válido.";
        }
        if (_linea.CompraPaisNac > 0 && _linea.CompraCrotal > 0 && _traza.Crotal.Length > 2
            && !_traza.Crotal.StartsWith(_traza.PaisNac.Trim().ToUpperInvariant(), StringComparison.Ordinal))
            return "El código de país no coincide con el crotal.";
        if (_linea.CompraRegSanitarioSac > 0 && _traza.RegSanitarioSac.Trim().Length == 0)
            return "Registro sanitario de sacrificio obligatorio.";
        if (_linea.CompraRegSanitarioDesp > 0 && _traza.RegSanitarioDesp.Trim().Length == 0)
            return "Registro sanitario de despiece obligatorio.";
        if (_linea.CompraFechaNac > 0)
        {
            if (_traza.FechaNac is null) return "Falta la fecha de nacimiento.";
            if (_traza.FechaNac > DateTime.Today) return "La fecha de nacimiento no puede ser posterior a hoy.";
        }
        if (_linea.CompraFechaSac > 0)
        {
            if (_traza.FechaSac is null) return "Falta la fecha de sacrificio.";
            if (_traza.FechaSac > DateTime.Today) return "La fecha de sacrificio no puede ser posterior a hoy.";
            if (_traza.FechaNac is not null && _traza.FechaSac <= _traza.FechaNac)
                return "La fecha de sacrificio debe ser posterior a la de nacimiento.";
        }
        if (_linea.CompraEstiba > 0 && !_traza.EstibaOk) return "La estiba debe estar OK para recepcionar.";
        if (_linea.CompraTemperatura > 0 && !_traza.TempOk) return "La temperatura debe estar OK para recepcionar.";
        return null;
    }

    // JSON de Datos para el proc: con perfil de trazabilidad se construye con el
    // contrato de R3 (DatosToJson); sin perfil, passthrough del Get (canon R4).
    private string ConstruirDatos()
    {
        if (_linea is null) return "";
        if (!TieneTraza && !PideLote && _linea.CompraFechaCad == 0) return _linea.Datos ?? "";
        _traza.LoteProv = _loteProv.Trim().ToUpperInvariant();
        _traza.FechaCad = _fechaCaducidad;
        return _traza.ToJson(_linea);
    }

    // Tras añadir, los campos con flag 2 retienen su valor para el siguiente producto
    // (semántica "se pide y mantiene" de R3); el resto se limpia.
    private void LimpiarTrazabilidad()
    {
        if (_linea is null) { _traza = new(); return; }
        var previa = _traza;
        _traza = new DatosTrazabilidad
        {
            Crotal = _linea.CompraCrotal == 2 ? previa.Crotal : "",
            Categoria = _linea.CompraCategoria == 2 ? previa.Categoria : "",
            Canal = _linea.CompraCanal == 2 ? previa.Canal : 0,
            PaisNac = _linea.CompraPaisNac == 2 ? previa.PaisNac : "",
            PaisEng = _linea.CompraPaisEng == 2 ? previa.PaisEng : "",
            PaisSac = _linea.CompraPaisSac == 2 ? previa.PaisSac : "",
            RegSanitarioSac = _linea.CompraRegSanitarioSac == 2 ? previa.RegSanitarioSac : "",
            RegSanitarioDesp = _linea.CompraRegSanitarioDesp == 2 ? previa.RegSanitarioDesp : "",
            FechaNac = _linea.CompraFechaNac == 2 ? previa.FechaNac : null,
            FechaSac = _linea.CompraFechaSac == 2 ? previa.FechaSac : null,
            EstibaOk = _linea.CompraEstiba == 2 && previa.EstibaOk,
            TempOk = _linea.CompraTemperatura == 2 && previa.TempOk
        };
    }

    // El operario aceptó la fecha de caducidad corta: se repite el alta con la excepción marcada.
    private async Task ContinuarCadCortaAsync()
    {
        _cadCortaAceptada = true;
        _confirmarCadCorta = false;
        await AnadirAsync();
    }

    private async Task AnadirAsync()
    {
        if (_anadiendo || _linea is null || _gamaElegida is null || _cantidad == 0) return;

        // Tope duro de R3 (999.999) y aviso de sanidad a partir de 10.000: una lectura
        // del escáner caída en el campo cantidad no debe acabar grabada, pero una
        // recepción legítima grande sí puede confirmarse en un segundo toque.
        if (Math.Abs(_cantidad) >= 999999) { MostrarError($"Cantidad {_cantidad} superior al máximo (999.999)."); return; }
        if (Math.Abs(_cantidad) >= 10000 && !_cantGrandeAceptada)
        {
            _cantGrandeAceptada = true;
            _tipoAviso = "aviso";
            _aviso = $"Cantidad {Cantidad(_cantidad, _linea.Prod.DecimalesEnCant)}: ¿seguro que no es una lectura del escáner? Pulsa «Añadir» de nuevo para confirmar.";
            return;
        }

        // Sin cargo exige una anotación de línea, como R3 (Bsincargo → FormInputBoxCombo).
        if (_sinCargo && _comentarioLinea.Length == 0)
        { MostrarError("Mercancía sin cargo: elige una anotación de línea (comentario) antes de añadir."); return; }

        // --- Trazabilidad cárnica según el perfil de compra (crotal, países, sanitarios…) ---
        if (ValidarTrazabilidad() is { } errorTraza) { MostrarError(errorTraza); return; }

        // --- Lote ya recibido: la cantidad es el TOTAL del lote; confirmación en dos toques
        // ("¿Cantidad Total Correcta?" de R3). ---
        if (_lineaLote > 0 && !_totalLoteAceptado)
        {
            _totalLoteAceptado = true;
            _tipoAviso = "aviso";
            _aviso = $"El lote ya tenía {Cantidad(_cantAntLote, _linea.Prod.DecimalesEnCant)}. ¿Cantidad TOTAL correcta: {Cantidad(_cantidad, _linea.Prod.DecimalesEnCant)}? Pulsa «Añadir» de nuevo para confirmar.";
            return;
        }

        // --- Fecha de caducidad (productos que la controlan) ---
        if (PideFechaCad && _fechaCaducidad is null)
        { MostrarError("Introduce la fecha de caducidad del producto."); return; }
        if (_linea.Prod.DiasCaducidad > 0)
        {
            if (_fechaCaducidad is null) { MostrarError("Introduce la fecha de caducidad del producto."); return; }

            // Caducado: bloqueo salvo devolución (cantidad negativa), igual que R3/R4.
            if (_fechaCaducidad.Value.Date < DateTime.Today && _cantidad > 0)
            {
                MostrarError($"Producto caducado ({_fechaCaducidad:dd/MM/yy}): no se puede recepcionar. Solo se permite en devoluciones (cantidad negativa).");
                return;
            }

            // Caducidad corta: pide confirmación explícita UNA vez. Sin comentario automático
            // (decisión 15/07/26: se retiró también de R3).
            if (_fechaCaducidad.Value.Date >= DateTime.Today
                && (_fechaCaducidad.Value.Date - DateTime.Today).TotalDays < _linea.Prod.DiasCaducidad
                && !_cadCortaAceptada)
            {
                _confirmarCadCorta = true;
                return;
            }
        }

        // --- Precio abierto: si se tecleó, valida el rango de R3 (0,10–999) ---
        decimal pnc = (decimal)_linea.PNC;
        if (_linea.PrecioAbierto && _numPedidoContra == 0 && _precioAbierto is not null)
        {
            if (_precioAbierto < 0.1m || _precioAbierto > 999m)
            {
                MostrarError("Precio de compra fuera de parámetros (0,10–999 €).");
                return;
            }
            pnc = _precioAbierto.Value;
        }

        // Cajas coherentes con la cantidad final: si se editó la cantidad a mano, _cajas
        // se quedó con el valor anterior. Se deriva de la cantidad (negativa = devolución).
        _cajas = (short)(Math.Sign(_cantidad) * Math.Max(1, (int)Math.Ceiling(Math.Abs(_cantidad) / UnidsCaja)));

        _anadiendo = true;
        _aviso = "";
        try
        {
            var alta = new AlbLinInsertDTO
            {
                Fecha = _fecha,
                CodProv = _gamaElegida.CodProv,
                CodAlm = Sesion.Usuario!.Almacen.CodAlm,
                Cant = _cantidad,
                // Sin cargo = tipo de línea atípico 4 (no se factura), como R3.
                TipoLinAtipico = _sinCargo ? (byte)4 : _linea.TipoLinAtipico,
                Cajas = _cajas,
                PTarifa = (decimal)_linea.PTarifa,
                NumPedido = _numPedidoContra,
                DtosComercialesTexto = _linea.DtosComercialesTexto ?? "",
                Iva = _linea.Prod.Iva,
                Reg = false,
                CodEan = _eanEscaneado,
                NumAlbaran = _numAlbaran,
                CodGama = _gamaElegida.Gama.CodGama,
                CodProd = _linea.Prod.CodProd,
                PrecioNetoComercial = pnc,
                CodUsuario = Sesion.Usuario.CodUsuario,
                UnidsCaja = UnidsCaja,
                DtosComerciales = (decimal)_linea.DtosComerciales,
                NumAlbProv = _numAlbProv.Trim(),
                TipoPrecio = _linea.TipoPrecio,
                PncFecha = _linea.PncFecha,
                // Trazabilidad: caducidad y lote capturados; si el producto tiene perfil de
                // trazabilidad se construye el JSON de Datos con el contrato de R3
                // (DatosToJson); si no, passthrough del Get como hasta ahora.
                FechaCaducidad = _fechaCaducidad,
                NumLoteProv = _loteProv.Trim(),
                Datos = ConstruirDatos(),
                // Lote ya recibido: se reemplaza esa línea con el total (semántica R3).
                Linea = _lineaLote
            };
            var respuesta = await Albaranes.PostLineaAsync(alta);
            if (!respuesta.Ok || respuesta.Datos is null) { MostrarError(respuesta.Error); return; }

            _numAlbaran = respuesta.Datos.NumDoc;

            // Comentario de línea adjuntado: se graba contra la línea recién creada
            // (mismo orden que R3: insert de línea + Comentario.InsertBD). Mejor esfuerzo.
            if (_comentarioLinea.Length > 0)
            {
                await Comentarios.PostAsync(2, _fecha, _numAlbaran, respuesta.Datos.LineaDoc,
                    Sesion.Usuario.CodUsuario, _comentarioLinea);
                _comentarioLinea = "";
                _selectorComentLinea?.Reset();
            }

            _lineasAnadidas++;
            _tipoAviso = "exito";
            _aviso = $"{_linea.Prod.DescProd}: {Cantidad(_cantidad, _linea.Prod.DecimalesEnCant)} añadido al albarán {_numAlbaran}.";
            LimpiarTrazabilidad();
            _linea = null;
            _codigo = "";
            _fechaCaducidad = null;
            _loteProv = "";
            _precioAbierto = null;
            _sinCargo = false;
            _cadCortaAceptada = false;
            _lineaLote = 0;
            _cantAntLote = 0;
            _totalLoteAceptado = false;
            _cantGrandeAceptada = false;
            _ = RefrescarLineasAsync();
        }
        finally
        {
            _anadiendo = false;
            StateHasChanged();
            await JS.InvokeVoidAsync("r5.seleccionar", "busquedaRecepcion");
        }
    }

    // Refresca el panel de líneas sin bloquear el siguiente escaneo (ApiWeb no lanza).
    private async Task RefrescarLineasAsync()
    {
        if (_numAlbaran <= 0) return;
        _cargandoLineas = true;
        var r = await Albaranes.GetLineasAsync(_numAlbaran, _fecha);
        if (r.Ok && r.Datos is not null) _lineasDoc = r.Datos;
        _cargandoLineas = false;
        StateHasChanged();
    }

    private bool _pidiendoLink;
    private string _linkTexto = "";
    private string _textoDescuadre = "";
    // Nivel de exigencia del link (ConfEmpresa de R3): 0 no se pide, 1 opcional, 2 obligatorio.
    private byte _nivelLink = 2;

    // El link es válido según el nivel: obligatorio → EAN13/14 con dígito de control;
    // opcional → también vale vacío o «0»; sin configurar → siempre válido.
    private bool LinkValido => _nivelLink switch
    {
        0 => true,
        1 => _linkTexto.Trim() is "" or "0" || CodigoBarras.ValidaEan13_14(_linkTexto),
        _ => CodigoBarras.ValidaEan13_14(_linkTexto)
    };

    private long LinkNumero => long.TryParse(_linkTexto.Trim(), out long l) ? l : 0;

    // Registrar la recepción: irreversible desde la app (genera la entrada en RW).
    // El link del documento se pide según la configuración de la empresa y, si la
    // gama tiene controles, el cuadre de los totales del papel contra lo grabado.
    private async Task RegistrarAsync()
    {
        if (_registrando || _numAlbaran <= 0 || FaltanControles || !LinkValido) return;
        long link = LinkNumero;

        _registrando = true;
        if (!_descuadreAvisado) _aviso = "";
        try
        {
            // Cuadre contra los totales reales del documento (los calcula el servidor).
            if (!_descuadreAvisado && _gamaElegida is not null
                && (_gamaElegida.Gama.ControlCant || _gamaElegida.Gama.ControlImporte))
            {
                var cab = await Albaranes.GetCabeceraAsync(_numAlbaran, _fecha);
                if (cab.Ok && cab.Datos is not null)
                {
                    var descuadres = new List<string>();
                    if (_gamaElegida.Gama.ControlCant && _ctrlCant is not null
                        && Math.Abs(_ctrlCant.Value - cab.Datos.CantTotal) > 0.5m)
                    {
                        descuadres.Add($"cantidad: papel {_ctrlCant} vs sistema {cab.Datos.CantTotal}");
                    }
                    if (_gamaElegida.Gama.ControlImporte && _ctrlImporte is not null)
                    {
                        // Mismo orden de preferencia que R3: total factura > neto factura > neto comercial.
                        decimal impDoc = cab.Datos.ImpTotalFact != 0 ? cab.Datos.ImpTotalFact
                            : cab.Datos.ImpNetoFact != 0 ? cab.Datos.ImpNetoFact : cab.Datos.ImpNetoComercial;
                        if (Math.Abs(_ctrlImporte.Value - impDoc) > 0.5m)
                            descuadres.Add($"importe: papel {Moneda(_ctrlImporte.Value)} vs sistema {Moneda(impDoc)}");
                    }
                    if (descuadres.Count > 0)
                    {
                        // Primer aviso: no registra. El siguiente submit ("Registrar igualmente") sí.
                        _descuadreAvisado = true;
                        _textoDescuadre = string.Join(" * ", descuadres);
                        _tipoAviso = "aviso";
                        _aviso = $"El albarán NO CUADRA ({string.Join(" · ", descuadres)}). Revisa las líneas o pulsa «Registrar igualmente».";
                        return;
                    }
                }
            }

            // Descuadre aceptado: queda constancia como comentario de cabecera, igual que
            // R3 (ComTxt en Registrar). Mejor esfuerzo: no bloquea el registro si falla.
            if (_descuadreAvisado && _textoDescuadre.Length > 0)
            {
                await Comentarios.PostAsync(3, _fecha, _numAlbaran, 0,
                    Sesion.Usuario!.CodUsuario, $"Registrado con descuadre: {_textoDescuadre}");
                _textoDescuadre = "";
            }

            var respuesta = await Albaranes.RegistrarAsync(_numAlbaran, _fecha, Sesion.Usuario!.CodUsuario, link);
            if (!respuesta.Ok) { MostrarError(respuesta.Error); return; }

            Nav.NavigateTo($"/recepcionAlb/{_fecha:yyyy-MM-dd}/{_numAlbaran}");
        }
        finally
        {
            _registrando = false;
        }
    }

    private void MostrarError(string mensaje)
    {
        _tipoAviso = "error";
        _aviso = mensaje;
    }

    // Al salir con un albarán pendiente con líneas, R3 ofrece registrarlo ("¿Registrar
    // Albarán?"): el primer toque avisa y abre la opción; el segundo sale igualmente.
    private bool _salidaAvisada;

    private void Volver()
    {
        if (!_salidaAvisada && _numAlbaran > 0 && _lineasAnadidas > 0 && !_pidiendoLink)
        {
            _salidaAvisada = true;
            _tipoAviso = "aviso";
            _aviso = "El albarán queda PENDIENTE de registrar. Puedes registrarlo ahora con «Registrar recepción» o pulsar «← Albaranes» de nuevo para salir sin registrar.";
            return;
        }
        Nav.NavigateTo("/recepcionAlb");
    }
}
