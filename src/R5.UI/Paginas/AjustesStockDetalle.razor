@* Detalle de ajuste: líneas agrupadas con cantidad, precio de coste y lote. Consulta. *@
@page "/ajustesStock/{FechaRuta}/{NumAjuste:int}"
@inject AjusteService Ajustes
@inject SesionUsuario Sesion
@inject NavigationManager Nav

<GuardiaModulo CodMenu="5">
<div class="r5-columna">

    <div class="r5-fila" style="flex-wrap: wrap;">
        <button class="r5-btn r5-btn--secundario" @onclick="Volver">← Ajustes</button>
        <h2>Ajuste @NumAjuste · @(Fecha(_fecha))</h2>
        @if (Reg is not null)
        {
            <span class="r5-badge @(_registrado ? "r5-badge--cerrado" : "r5-badge--abierto")">
                @(_registrado ? "Registrado" : "Pendiente")
            </span>
        }
        @if (Reg == 0 && !_registrado)
        {
            <div class="r5-fila" style="margin-left:auto">
                <button class="r5-btn r5-btn--primario" @onclick="AbrirRegistrarAsync"
                        disabled="@(_registrando || _cargando || _lineas.Count == 0 || _error.Length > 0)">
                    Registrar ajuste
                </button>
            </div>
        }
    </div>

    @if (_verificandoRegistro)
    {
        @* Control de R3: para registrar hay que teclear el importe aproximado del ajuste
           y debe coincidir (en euros enteros) con el importe real del documento. *@
        <form class="r5-tarjeta r5-columna r5-ancho-form" @onsubmit="RegistrarVerificadoAsync">
            <h3>Registrar ajuste @NumAjuste</h3>
            <p class="r5-texto-suave r5-texto-sm">
                Verificación anti-error: teclea el importe aproximado del ajuste (en euros, sin decimales).
                Mueve stock y coste; no se puede deshacer.
            </p>
            <div class="r5-campo" style="max-width: 240px;">
                <label for="importeVerifDet">Importe aproximado €</label>
                <input id="importeVerifDet" class="r5-input r5-input--numero" type="number" inputmode="numeric" step="1"
                       @bind="_importeTecleado" disabled="@_registrando" />
            </div>
            <div class="r5-fila">
                <button type="submit" class="r5-btn r5-btn--primario" disabled="@(_registrando || _importeTecleado is null)">
                    @(_registrando ? "Registrando…" : "Confirmar registro")
                </button>
                <button type="button" class="r5-btn r5-btn--fantasma" @onclick="() => _verificandoRegistro = false">Cancelar</button>
            </div>
        </form>
    }

    <Aviso Tipo="@_tipoAviso" Mensaje="@_aviso" />

    @if (_fecha is null)
    {
        <Aviso Mensaje="La fecha del ajuste no es válida." />
    }
    else if (_cargando)
    {
        <Cargando Texto="Cargando líneas…" />
    }
    else if (!string.IsNullOrEmpty(_error))
    {
        <Aviso Mensaje="@_error" />
    }
    else if (_lineas.Count == 0)
    {
        <div class="r5-cargando">
            <Icono Nombre="ajustes-stock" Clase="r5-modulo__icono" />
            <span>El ajuste no tiene líneas.</span>
        </div>
    }
    else
    {
        <div class="r5-tarjeta r5-tabla-scroll">
            <table class="r5-tabla">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th class="num">Cantidad</th>
                        <th class="num">Precio coste</th>
                        <th class="num">Lote</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var linea in _lineas)
                    {
                        <tr @key="linea.Linea">
                            <td>
                                <div class="r5-doc__principal">
                                    <span>@linea.Prod.DescProd</span>
                                    <span class="r5-doc__detalle">@linea.Prod.CodProd</span>
                                </div>
                            </td>
                            <td class="num">@Cantidad(linea.Cant, linea.Prod.DecimalesEnCant)</td>
                            <td class="num">@Moneda(linea.PrecioCoste)</td>
                            <td class="num">@(linea.Lote > 0 ? linea.Lote.ToString() : "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <p class="r5-texto-suave r5-texto-sm">@_lineas.Count líneas.</p>
    }
</div>
</GuardiaModulo>

@code {
    [Parameter] public string FechaRuta { get; set; } = "";
    [Parameter] public int NumAjuste { get; set; }

    /// <summary>Estado desde la bandeja (0=pendiente, 1=registrado); null en deep-link = solo consulta.</summary>
    [Parameter, SupplyParameterFromQuery(Name = "reg")] public int? Reg { get; set; }

    private DateTime? _fecha;
    private bool _cargando = true;
    private string _error = "";
    private List<AjusteLin> _lineas = new();

    private bool _registrado;
    private bool _registrando;
    private string _aviso = "";
    private string _tipoAviso = "exito";

    // --- Registro con cotejo de importe (paridad R3: BAjusteReg_Click) ---
    private bool _verificandoRegistro;
    private int? _importeTecleado;
    private decimal _importeDoc;

    // Abre la verificación con el importe REAL del documento leído del servidor.
    private async Task AbrirRegistrarAsync()
    {
        if (_registrando || _fecha is null || !Sesion.Autenticado) return;
        _registrando = true;
        _aviso = "";
        try
        {
            var cab = await Ajustes.GetCabeceraAsync(NumAjuste, _fecha.Value);
            if (!cab.Ok || cab.Datos is null)
            {
                _tipoAviso = "error";
                _aviso = cab.Error;
                return;
            }
            _importeDoc = cab.Datos.ImporteCoste;
            _importeTecleado = null;
            _verificandoRegistro = true;
        }
        finally
        {
            _registrando = false;
        }
    }

    // Registra el ajuste pendiente: mueve stock/coste en RW (irreversible). El importe
    // tecleado debe coincidir con el del documento en euros enteros (control de R3).
    private async Task RegistrarVerificadoAsync()
    {
        if (_registrando || _fecha is null || !Sesion.Autenticado || _importeTecleado is null) return;

        if (_importeTecleado.Value != (int)Math.Round(_importeDoc, MidpointRounding.AwayFromZero))
        {
            _tipoAviso = "error";
            _aviso = $"El importe no coincide (has tecleado {_importeTecleado} €). Revisa las líneas del ajuste antes de registrar.";
            return;
        }

        _registrando = true;
        _aviso = "";
        try
        {
            var respuesta = await Ajustes.RegistrarAsync(NumAjuste, _fecha.Value, Sesion.Usuario!.CodUsuario);
            if (!respuesta.Ok)
            {
                _tipoAviso = "error";
                _aviso = respuesta.Error;
                return;
            }
            _registrado = true;
            _verificandoRegistro = false;
            _tipoAviso = "exito";
            _aviso = $"Ajuste {NumAjuste} registrado.";
        }
        finally
        {
            _registrando = false;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (!Sesion.Autenticado) return;
        _registrado = Reg == 1;

        if (!DateTime.TryParseExact(FechaRuta, "yyyy-MM-dd", null,
            System.Globalization.DateTimeStyles.None, out var fecha))
        {
            _fecha = null;
            _cargando = false;
            return;
        }
        _fecha = fecha;

        try
        {
            // Cabecera + líneas en paralelo. La cabecera del servidor manda sobre el ?reg=
            // de la bandeja: el deep-link sin query también muestra estado y acción correctos.
            var tCab = Ajustes.GetCabeceraAsync(NumAjuste, fecha);
            var tLin = Ajustes.GetLineasAsync(NumAjuste, fecha);
            await Task.WhenAll(tCab, tLin);

            if (tCab.Result.Ok && tCab.Result.Datos is { NumAjuste: > 0 } cab)
            {
                Reg = cab.Reg ? 1 : 0;
                _registrado = cab.Reg;
            }

            if (!tLin.Result.Ok)
            {
                _error = tLin.Result.Error;
                return;
            }
            _lineas = tLin.Result.Datos ?? new();
        }
        finally
        {
            _cargando = false;
        }
    }

    private void Volver() => Nav.NavigateTo("/ajustesStock");
}
