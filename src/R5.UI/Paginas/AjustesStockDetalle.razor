@* Detalle de ajuste: líneas agrupadas con cantidad, precio de coste y lote. Consulta. *@
@page "/ajustesStock/{FechaRuta}/{NumAjuste:int}"
@inject AjusteService Ajustes
@inject SesionUsuario Sesion
@inject NavigationManager Nav

<GuardiaModulo CodMenu="5">
<div class="r5-columna">

    <div class="r5-fila">
        <button class="r5-btn r5-btn--secundario" @onclick="Volver">← Ajustes</button>
        <h2>Ajuste @NumAjuste · @(_fecha?.ToString("dd/MM/yyyy"))</h2>
    </div>

    @if (_fecha is null)
    {
        <Aviso Mensaje="La fecha del ajuste no es válida." />
    }
    else if (_cargando)
    {
        <Cargando Texto="Cargando líneas…" />
    }
    else if (!string.IsNullOrEmpty(_error))
    {
        <Aviso Mensaje="@_error" />
    }
    else if (_lineas.Count == 0)
    {
        <div class="r5-cargando">
            <Icono Nombre="ajustes-stock" Clase="r5-modulo__icono" />
            <span>El ajuste no tiene líneas.</span>
        </div>
    }
    else
    {
        <div class="r5-tarjeta">
            <table class="r5-tabla">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th class="num">Cantidad</th>
                        <th class="num">Precio coste</th>
                        <th class="num">Lote</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var linea in _lineas)
                    {
                        <tr @key="linea.Linea">
                            <td>
                                <div class="r5-doc__principal">
                                    <span>@linea.Prod.DescProd</span>
                                    <span class="r5-doc__detalle">@linea.Prod.CodProd</span>
                                </div>
                            </td>
                            <td class="num">@Cantidad(linea.Cant, linea.Prod.DecimalesEnCant)</td>
                            <td class="num">@Moneda(linea.PrecioCoste)</td>
                            <td class="num">@(linea.Lote > 0 ? linea.Lote.ToString() : "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <p class="r5-texto-suave r5-texto-sm">@_lineas.Count líneas.</p>
    }
</div>
</GuardiaModulo>

@code {
    [Parameter] public string FechaRuta { get; set; } = "";
    [Parameter] public int NumAjuste { get; set; }

    private DateTime? _fecha;
    private bool _cargando = true;
    private string _error = "";
    private List<AjusteLin> _lineas = new();

    protected override async Task OnInitializedAsync()
    {
        if (!Sesion.Autenticado) return;

        if (!DateTime.TryParseExact(FechaRuta, "yyyy-MM-dd", null,
            System.Globalization.DateTimeStyles.None, out var fecha))
        {
            _fecha = null;
            _cargando = false;
            return;
        }
        _fecha = fecha;

        try
        {
            var respuesta = await Ajustes.GetLineasAsync(NumAjuste, fecha);
            if (!respuesta.Ok)
            {
                _error = respuesta.Error;
                return;
            }
            _lineas = respuesta.Datos ?? new();
        }
        finally
        {
            _cargando = false;
        }
    }

    private void Volver() => Nav.NavigateTo("/ajustesStock");
}
