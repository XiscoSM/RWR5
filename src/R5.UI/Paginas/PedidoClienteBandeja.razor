@* Pedido de Cliente a Central (módulo 17): un mostrador toma nota del pedido de un
   cliente y un central lo prepara. Dos perspectivas SIEMPRE disponibles (el estado
   habilita, no el tipo de almacén): "Pedidos" (mostrador: listado con buscador por
   cliente/teléfono/nº) y "Preparar" (bandeja del preparador a nivel de línea, con
   ámbito A-preparar/Mis-pedidos y atrasados en rojo). *@
@page "/pedidoCliente"
@implements IDisposable
@inject PedidoClienteService Pedidos
@inject SesionUsuario Sesion
@inject NavigationManager Nav
@inject IJSRuntime JS

<GuardiaModulo CodMenu="17">
<div class="r5-columna">

    <div class="r5-fila" style="flex-wrap: wrap;">
        <div class="r5-segmento">
            <button class="@(!_verBandeja ? "activo" : "")" @onclick="() => CambiarVistaAsync(false)" disabled="@_cargando">
                Pedidos @(_noDisponibles > 0 ? $"⚠{_noDisponibles} no disp." : "")
            </button>
            <button class="@(_verBandeja ? "activo" : "")" @onclick="() => CambiarVistaAsync(true)" disabled="@_cargando">Preparar @(_atrasadas > 0 ? $"⚠{_atrasadas}" : "")</button>
        </div>
        <button class="r5-btn r5-btn--fantasma" @onclick="CargarAsync" disabled="@_cargando">Actualizar</button>
        @if (!_verBandeja)
        {
            <button class="r5-btn r5-btn--primario" style="margin-left:auto"
                    @onclick='() => Nav.NavigateTo("/pedidoCliente/alta")'>
                + Nuevo pedido
            </button>
        }
    </div>

    @if (!_verBandeja)
    {
        <div class="r5-tarjeta r5-fila" style="flex-wrap: wrap; align-items: flex-end;">
            @* Filtro por los 6 estados reales del documento (combo Estado de R3). *@
            <div class="r5-campo" style="min-width: 190px;">
                <label for="estadoDocFiltro">Estado</label>
                <select id="estadoDocFiltro" class="r5-select" @bind="_estadoFiltro" @bind:after="CargarAsync">
                    <option value="-1">Todos</option>
                    <option value="100">En curso (1-3)</option>
                    <option value="0">Abierto</option>
                    <option value="1">Enviado</option>
                    <option value="2">En preparación</option>
                    <option value="3">En reparto</option>
                    <option value="4">Entregado</option>
                    <option value="5">Anulado</option>
                </select>
            </div>
            @* Toggle "ver otras tiendas" (almFiltro -1 de R3). *@
            <label class="r5-fila" style="gap: var(--esp-2); cursor: pointer; align-self: flex-end; padding-bottom: 8px;">
                <input type="checkbox" @bind="_todasTiendas" @bind:after="CargarAsync" disabled="@_cargando" />
                <span>Ver otras tiendas</span>
            </label>
            <form class="r5-buscador" style="flex:1; min-width: 260px;" @onsubmit="BuscarAsync">
                <input id="busquedaPedCli" class="r5-input" type="text"
                       placeholder="Cliente, teléfono o nº de pedido"
                       @bind="_busqueda" @bind:event="oninput" disabled="@_cargando" />
                <button type="submit" class="r5-btn r5-btn--secundario" disabled="@_cargando">Buscar</button>
            </form>
        </div>

        <Aviso Mensaje="@_error" OnReintentar="CargarAsync" Reintentando="_cargando" />

        @if (_cargando)
        {
            <Cargando Texto="Cargando pedidos…" />
        }
        else if (_pedidos.Count == 0 && _error.Length == 0)
        {
            <div class="r5-cargando">
                <Icono Nombre="pedido-central" Clase="r5-modulo__icono" />
                <span>No hay pedidos de cliente con este filtro.</span>
                <button class="r5-btn r5-btn--primario" @onclick='() => Nav.NavigateTo("/pedidoCliente/alta")'>+ Nuevo pedido</button>
            </div>
        }
        else
        {
            <ListaPaginada Items="_pedidos" Context="p">
                <Fila>
                    @* Resaltado de R3: entrega de HOY en negrita, vencida en rojo. *@
                    <button @key="p.Pedido" class="r5-doc" @onclick="() => Abrir(p.Pedido)"
                            style="@EstiloEntrega(p)">
                        <Icono Nombre="usuario" Clase="r5-modulo__icono" />
                        <span class="r5-doc__principal">
                            <span class="r5-doc__titulo">@(p.NombreCliente.Length > 0 ? p.NombreCliente : $"Pedido {p.Pedido}")</span>
                            <span class="r5-doc__detalle">
                                Nº @p.Pedido · @FormatearTel(p.Telefono)
                                @(p.FechaHoraEntrega is null ? "" : $" · entrega {p.FechaHoraEntrega:dd/MM HH:mm}")
                                @(p.Fecha is null ? "" : $" · creado {p.Fecha:dd/MM}")
                            </span>
                        </span>
                        <span class="r5-doc__derecha">
                            @if (p.NumEntregadas > 0 && p.Lineas > 0)
                            {
                                <span class="r5-chip r5-chip--suave">@p.NumEntregadas de @p.Lineas</span>
                            }
                            <span class="r5-badge @(p.Abierto ? "r5-badge--abierto" : p.Vivo ? "r5-badge--neutro" : "r5-badge--cerrado")">
                                @p.DescEstado
                            </span>
                        </span>
                    </button>
                </Fila>
            </ListaPaginada>
        }
    }
    else
    {
        <div class="r5-tarjeta r5-fila" style="flex-wrap: wrap; align-items: flex-end;">
            <div class="r5-segmento">
                <button class="@(_ambito == 0 ? "activo" : "")" @onclick="() => CambiarAmbitoAsync(0)" disabled="@_cargando">A preparar</button>
                <button class="@(_ambito == 1 ? "activo" : "")" @onclick="() => CambiarAmbitoAsync(1)" disabled="@_cargando">Mis pedidos</button>
            </div>
            @* Combo Entrega de R3: Todas / Hoy / Hasta mañana / Próximos 7 días. *@
            <div class="r5-campo" style="min-width: 170px;">
                <label for="entregaFiltro">Entrega</label>
                <select id="entregaFiltro" class="r5-select" @bind="_entregaFiltro" @bind:after="CargarAsync">
                    <option value="0">Todas</option>
                    <option value="1">Hoy</option>
                    <option value="2">Hasta mañana</option>
                    <option value="7">Próximos 7 días</option>
                </select>
            </div>
            @* Filtro de estado de línea (combo Estado de R3). *@
            <div class="r5-campo" style="min-width: 170px;">
                <label for="estadoLinFiltro">Estado</label>
                <select id="estadoLinFiltro" class="r5-select" @bind="_estadoLinFiltro" @bind:after="CargarAsync">
                    <option value="-1">En curso</option>
                    <option value="0">Pendiente</option>
                    <option value="1">En preparación</option>
                    <option value="2">En reparto</option>
                    <option value="3">Entregado</option>
                    <option value="4">No disponible</option>
                </select>
            </div>
            <span class="r5-texto-suave r5-texto-sm" style="padding-bottom: 8px;">
                @(_ambito == 0 ? "Líneas que este almacén debe preparar." : "Líneas de los pedidos que tomó este almacén.")
            </span>
        </div>

        <Aviso Mensaje="@_error" OnReintentar="CargarAsync" Reintentando="_cargando" />

        @if (_cargando)
        {
            <Cargando Texto="Cargando bandeja…" />
        }
        else if (_lineas.Count == 0 && _error.Length == 0)
        {
            <div class="r5-cargando">
                <Icono Nombre="ok" Clase="r5-modulo__icono" />
                <span>Nada pendiente de preparar. Buen trabajo.</span>
            </div>
        }
        else
        {
            <div class="r5-tarjeta r5-tabla-scroll">
                <table class="r5-tabla">
                    <thead><tr><th>Entrega</th><th>Producto</th><th class="num">Cant.</th><th>Cliente</th><th>Pedido</th><th>Estado</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var l in _lineas)
                        {
                            <tr @key="@($"{l.Pedido}-{l.Linea}")">
                                <td style="@(l.Atrasada ? "color: var(--c-error); font-weight: 600;" : EsHoy(l.FechaHoraEntrega) ? "font-weight: 700;" : "")">
                                    @l.FechaHoraEntrega?.ToString("dd/MM HH:mm")@(l.Atrasada ? " · ATRASADO" : "")
                                </td>
                                <td>@l.DescProd</td>
                                <td class="num">@Cantidad(l.Cant, l.DecimalesEnCant)</td>
                                <td>@l.NombreCliente</td>
                                <td><button class="r5-btn r5-btn--fantasma r5-btn--sm" @onclick="() => Abrir(l.Pedido)">@l.Pedido</button></td>
                                <td><span class="r5-badge r5-badge--neutro">@l.DescEstado</span></td>
                                <td class="num">
                                    @foreach (var (texto, estado, peligro) in AccionesLinea(l, _ambito))
                                    {
                                        @* Confirmación en dos toques (los Sí/No de R3): el primer toque arma
                                           la acción y el botón pregunta; el segundo la ejecuta. *@
                                        <button class="r5-btn r5-btn--sm @(peligro ? "r5-btn--peligro" : Armada(l, estado) ? "r5-btn--primario" : "r5-btn--secundario")"
                                                disabled="@_operando" @onclick="() => OperarAsync(l, estado)">
                                            @(Armada(l, estado) ? "¿Seguro?" : texto)
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
</div>
</GuardiaModulo>

@code {
    private bool _verBandeja;
    private bool _cargando = true;
    private bool _operando;
    private string _error = "";
    private int _estadoFiltro = -1;   // -1 todos; 100 = "en curso" (1..3, filtrado en cliente)
    private string _busqueda = "";
    private int _ambito;              // 0 A preparar, 1 Mis pedidos
    private int _entregaFiltro = 7;   // 0 todas, 1 hoy, 2 hasta mañana, 7 próximos 7 días
    private int _estadoLinFiltro = -1;
    private bool _todasTiendas;
    private int _atrasadas;
    private int _noDisponibles;       // productos de MIS pedidos marcados No disponible (aviso R3)

    private List<PedidoClienteCab> _pedidos = new();
    private List<PedidoClienteLin> _lineas = new();

    // Acción armada pendiente de confirmar (dos toques).
    private (int Pedido, int Linea, byte Estado)? _armada;
    private bool Armada(PedidoClienteLin l, byte estado)
        => _armada is { } a && a.Pedido == l.Pedido && a.Linea == l.Linea && a.Estado == estado;

    // Refresco automático cada 90 s cuando no hay operación en curso (tmrAuto de R3).
    private readonly System.Threading.PeriodicTimer _timer = new(TimeSpan.FromSeconds(90));

    protected override async Task OnInitializedAsync()
    {
        // El tipo de almacén solo decide la pantalla inicial (como R3): almacén → bandeja.
        _verBandeja = Sesion.Usuario?.Almacen.Tipo != 0;
        await CargarAsync();
        _ = RefrescoAutomaticoAsync();
    }

    private async Task RefrescoAutomaticoAsync()
    {
        try
        {
            while (await _timer.WaitForNextTickAsync())
            {
                if (_cargando || _operando || _armada is not null) continue;
                await InvokeAsync(CargarAsync);
            }
        }
        catch (OperationCanceledException) { /* la página se cerró */ }
    }

    public void Dispose() => _timer.Dispose();

    private Task CambiarVistaAsync(bool bandeja)
    {
        if (_verBandeja == bandeja) return Task.CompletedTask;
        _verBandeja = bandeja;
        _armada = null;
        return CargarAsync();
    }

    private Task CambiarAmbitoAsync(int ambito)
    {
        if (_ambito == ambito) return Task.CompletedTask;
        _ambito = ambito;
        _armada = null;
        return CargarAsync();
    }

    private Task BuscarAsync() => CargarAsync();

    private async Task CargarAsync()
    {
        if (!Sesion.Autenticado) return;
        _cargando = true;
        _error = "";
        try
        {
            short alm = Sesion.Usuario!.Almacen.CodAlm;
            if (_verBandeja)
            {
                // Rango de entrega según el combo (R3): lo atrasado siempre entra
                // porque no se acota la fecha de inicio.
                DateTime? hasta = _entregaFiltro switch
                {
                    1 => DateTime.Today.AddDays(1).AddSeconds(-1),
                    2 => DateTime.Today.AddDays(2).AddSeconds(-1),
                    7 => DateTime.Today.AddDays(7),
                    _ => null
                };
                var r = await Pedidos.GetBandejaAsync(alm, _ambito, null, hasta, _estadoLinFiltro);
                if (!r.Ok) { _error = r.Error; _lineas = new(); return; }
                _lineas = (r.Datos ?? new())
                    .OrderBy(l => l.FechaHoraEntrega ?? DateTime.MaxValue)
                    .ThenBy(l => l.DescProd).ToList();
                _atrasadas = _lineas.Count(l => l.Atrasada);
            }
            else
            {
                string b = _busqueda.Trim();
                string cliente = "";
                long telefono = 0;
                // Nº de pedido tecleado → ir directo a la ficha (el "ir a pedido" de R3).
                if (b.Length is > 0 and < 8 && int.TryParse(b, out int num) && num > 0)
                {
                    var cab = await Pedidos.GetCabAsync(num);
                    if (cab.Ok && cab.Datos is { Pedido: > 0 }) { Abrir(num); return; }
                }
                if (b.Length >= 8 && long.TryParse(b, out long tel)) telefono = tel;
                else cliente = b;

                // "Ver otras tiendas" = almacén -1 (todas), como R3.
                short almFiltro = _todasTiendas ? (short)-1 : alm;
                var r = await Pedidos.GetListaAsync(almFiltro, _estadoFiltro is -1 or 100 ? -1 : _estadoFiltro,
                    cliente, telefono);
                if (!r.Ok) { _error = r.Error; _pedidos = new(); return; }
                _pedidos = r.Datos ?? new();
                if (_estadoFiltro == 100)
                    _pedidos = _pedidos.Where(p => p.EstadoDoc is >= 1 and <= 3).ToList();

                // Contadores de avisos para las pestañas (menú de R3): atrasadas del
                // preparador y "no disponible" en MIS pedidos (aviso al mostrador).
                var bandeja = await Pedidos.GetBandejaAsync(alm, 0, null, DateTime.Today.AddDays(7));
                if (bandeja.Ok) _atrasadas = (bandeja.Datos ?? new()).Count(l => l.Atrasada);
                // Solo cuentan los pedidos VIVOS (ni entregados ni anulados), como R3
                // c2ae4c6: se cruza la línea no-disp con el estado real del documento.
                var misNoDisp = await Pedidos.GetBandejaAsync(alm, 1, null, null, 4);
                if (misNoDisp.Ok)
                {
                    var vivos = await Pedidos.GetListaAsync(alm, -1);
                    var setVivos = new HashSet<int>((vivos.Datos ?? new())
                        .Where(p => p.Vivo).Select(p => p.Pedido));
                    _noDisponibles = (misNoDisp.Datos ?? new()).Count(l => setVivos.Contains(l.Pedido));
                }
            }
        }
        finally
        {
            _cargando = false;
            StateHasChanged();
        }
    }

    // Acciones por estado de línea, transiciones EXACTAS de R3 (17_PedidoClienteCentral
    // 1181/2164): Pendiente→Preparar|No disp; Preparación y Reparto→Entregar|Reabrir;
    // No disp→Reabrir. En "Mis pedidos" el mostrador solo entrega (R3 oculta el resto).
    private static IEnumerable<(string Texto, byte Estado, bool Peligro)> AccionesLinea(PedidoClienteLin l, int ambito)
    {
        if (ambito == 1)
        {
            if (l.Estado is 1 or 2) yield return ("Entregar", 3, false);
            yield break;
        }
        switch (l.Estado)
        {
            case 0: yield return ("Preparar", 1, false); yield return ("No disp.", 4, true); break;
            case 1: yield return ("Entregar", 3, false); yield return ("Reabrir", 0, false); break;
            case 2: yield return ("Entregar", 3, false); yield return ("Reabrir", 0, false); break;
            case 4: yield return ("Reabrir", 0, false); break;
        }
    }

    private async Task OperarAsync(PedidoClienteLin l, byte estado)
    {
        if (_operando) return;

        // Entregar, No disponible y Reabrir piden confirmación (Sí/No de R3): el
        // primer toque arma; Preparar ejecuta directo, como R3.
        if (estado is 3 or 4 or 0 && !Armada(l, estado))
        {
            _armada = (l.Pedido, l.Linea, estado);
            return;
        }
        _armada = null;

        _operando = true;
        _error = "";
        try
        {
            var r = await Pedidos.CambiarEstadoLineaAsync(l.Pedido, l.Linea, estado);
            if (!r.Ok) { _error = r.Error; return; }
        }
        finally
        {
            _operando = false;
        }
        await CargarAsync();
    }

    private void Abrir(int pedido) => Nav.NavigateTo($"/pedidoCliente/{pedido}");

    private static bool EsHoy(DateTime? f) => f is not null && f.Value.Date == DateTime.Today;

    private static string EstiloEntrega(PedidoClienteCab p)
    {
        if (p.FechaHoraEntrega is null || !p.Vivo) return "";
        if (p.FechaHoraEntrega < DateTime.Now) return "border-left: 4px solid var(--c-error);";
        return EsHoy(p.FechaHoraEntrega) ? "border-left: 4px solid var(--c-primario);" : "";
    }

    private static string FormatearTel(long tel)
        => tel <= 0 ? "sin teléfono" : System.Text.RegularExpressions.Regex.Replace(tel.ToString(), @"(\d{3})(?=\d)", "$1 ");
}
