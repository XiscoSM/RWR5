@* IFA Central de Compras (módulo 35 de R3) — fase 1: SOLO CONSULTAS.
   Pedidos: líneas en IFA desde una fecha, agrupadas por nº de pedido.
   Recepciones: líneas recibidas en un rango, con totales por pedido.
   (Los envíos de carga/mantenimiento de R3 quedan para una fase 2.) *@
@page "/ifa"
@inject IfaService ServicioIfa
@inject SesionUsuario Sesion

<GuardiaModulo CodMenu="35">
<div class="r5-columna">

    <div class="r5-fila">
        <div class="r5-segmento">
            <button class="@(!_verRecepciones ? "activo" : "")" aria-pressed="@(!_verRecepciones)" @onclick="() => CambiarVista(false)" disabled="@_cargando">Pedidos</button>
            <button class="@(_verRecepciones ? "activo" : "")" aria-pressed="@_verRecepciones" @onclick="() => CambiarVista(true)" disabled="@_cargando">Recepciones</button>
        </div>
        <button class="r5-btn r5-btn--secundario" style="margin-left:auto"
                @onclick="() => _verEnvios = !_verEnvios" disabled="@_enviando">
            @(_verEnvios ? "Ocultar envíos" : "Envíos a IFA")
        </button>
    </div>

    @if (_verEnvios)
    {
        @* Envíos transaccionales (fase 2, port de R3): ESCRIBEN en el IFA real. El bucle
           por días replica el While de R3: desde la fecha elegida hasta anteayer. *@
        <div class="r5-tarjeta r5-columna">
            <h3 style="margin:0">Envíos a IFA (escriben en la central de compras)</h3>
            <div class="r5-fila" style="flex-wrap: wrap; align-items: flex-end;">
                <div class="r5-campo" style="min-width: 220px;">
                    <label for="tipoEnvio">Tipo de envío</label>
                    <select id="tipoEnvio" class="r5-select" @onchange='e => _tipoEnvio = e.Value?.ToString() ?? "P"' disabled="@_enviando">
                        <option value="P">Carga de pedidos</option>
                        <option value="PM">Pedidos modificados (mantenimiento)</option>
                        <option value="R">Carga de recepciones</option>
                        <option value="RM">Recepciones modificadas (mantenimiento)</option>
                    </select>
                </div>
                <div class="r5-campo" style="min-width: 190px;">
                    <label for="fechaEnvio">Fecha de datos (desde)</label>
                    <input id="fechaEnvio" class="r5-input" type="date" @bind="_fechaEnvio" disabled="@_enviando" />
                </div>
                <BotonConfirmar Texto="Enviar a IFA"
                                Pregunta="@($"¿Enviar a IFA ({DescTipoEnvio}) desde el {_fechaEnvio:dd/MM/yyyy} hasta anteayer? ESCRIBE en la central de compras real; no se puede deshacer.")"
                                TextoOcupado="Enviando…" Ocupado="@_enviando"
                                Deshabilitado="@(_fechaEnvio >= DateTime.Today || _fechaEnvio < DateTime.Today.AddDays(-300))"
                                OnConfirmar="EnviarAsync" />
            </div>
            <span class="r5-texto-suave r5-texto-sm">
                La fecha debe ser anterior a hoy (máx. 300 días atrás). Se envía día a día, como en R3.
            </span>
            @if (_logEnvio.Count > 0)
            {
                <div class="r5-tabla-scroll" style="max-height: 260px;">
                    <table class="r5-tabla">
                        <tbody>
                            @foreach (var (linea, i) in _logEnvio.Select((l, i) => (l, i)))
                            {
                                <tr @key="i"><td style="@(linea.StartsWith("✗") ? "color: var(--c-error);" : "")">@linea</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }

    <div class="r5-tarjeta r5-columna">
        <div class="r5-fila" style="flex-wrap: wrap; align-items: flex-end;">
            <div class="r5-campo" style="min-width: 190px;">
                <label for="ifaDesde">@(_verRecepciones ? "Recepción desde" : "Pedido desde")</label>
                <input id="ifaDesde" class="r5-input" type="date" @bind="_fechaDesde" disabled="@_cargando" />
            </div>
            @if (_verRecepciones)
            {
                <div class="r5-campo" style="min-width: 190px;">
                    <label for="ifaHasta">Hasta</label>
                    <input id="ifaHasta" class="r5-input" type="date" @bind="_fechaHasta" disabled="@_cargando" />
                </div>
            }
            <button class="r5-btn r5-btn--primario" @onclick="ConsultarAsync" disabled="@_cargando">
                @(_cargando ? "Consultando…" : "Consultar en IFA")
            </button>
        </div>
        <span class="r5-texto-suave r5-texto-sm">Consulta de solo lectura contra la API de la central de compras IFA.</span>
    </div>

    <Aviso Tipo="@_tipoAviso" Mensaje="@_aviso" />

    @if (_cargando)
    {
        <Cargando Texto="Consultando en IFA…" />
    }
    else if (!_verRecepciones && _pedidosAgrupados.Count > 0)
    {
        <div class="r5-tarjeta r5-columna">
            <div class="r5-fila" style="align-items:baseline">
                <h3 style="margin:0">Pedidos en IFA</h3>
                <span class="r5-chip r5-chip--suave">@_pedidosAgrupados.Count pedidos · @_totalLineasPedidos líneas</span>
            </div>
            <div class="r5-tabla-scroll">
                <table class="r5-tabla">
                    <thead><tr><th>Pedido</th><th>Fecha</th><th>Proveedor</th><th>Destino</th><th class="num">Líneas</th><th class="num">Cantidad</th></tr></thead>
                    <tbody>
                        @foreach (var grupo in _pedidosAgrupados)
                        {
                            <tr @key="grupo.Pedido">
                                <td>@grupo.Pedido</td>
                                <td>@grupo.Fecha</td>
                                <td>@grupo.Proveedor</td>
                                <td>@grupo.Destino</td>
                                <td class="num">@grupo.Lineas</td>
                                <td class="num">@grupo.Cantidad</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else if (_verRecepciones && _recepcionesAgrupadas.Count > 0)
    {
        <div class="r5-tarjeta r5-columna">
            <div class="r5-fila" style="align-items:baseline">
                <h3 style="margin:0">Recepciones en IFA</h3>
                <span class="r5-chip r5-chip--suave">@_recepcionesAgrupadas.Count recepciones · @_totalLineasRecepciones líneas · @_totalCantidadRecibida uds</span>
            </div>
            <div class="r5-tabla-scroll">
                <table class="r5-tabla">
                    <thead><tr><th>Pedido</th><th>Fecha recepción</th><th>Proveedor</th><th>Destino</th><th class="num">Líneas</th><th class="num">Cant. recibida</th></tr></thead>
                    <tbody>
                        @foreach (var grupo in _recepcionesAgrupadas)
                        {
                            <tr @key="grupo.Pedido">
                                <td>@grupo.Pedido</td>
                                <td>@grupo.Fecha</td>
                                <td>@grupo.Proveedor</td>
                                <td>@grupo.Destino</td>
                                <td class="num">@grupo.Lineas</td>
                                <td class="num">@grupo.Cantidad</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else if (_consultado)
    {
        <div class="r5-cargando">
            <Icono Nombre="ifa" Clase="r5-modulo__icono" />
            <span>Sin resultados en IFA para ese periodo.</span>
        </div>
    }
</div>
</GuardiaModulo>

@code {
    private bool _verRecepciones;
    private bool _cargando;
    private bool _consultado;
    private string _aviso = "";
    private string _tipoAviso = "error";

    private DateTime _fechaDesde = DateTime.Today.AddDays(-2);
    private DateTime _fechaHasta = DateTime.Today;

    private sealed record GrupoIfa(string Pedido, string Fecha, string Proveedor, string Destino, int Lineas, double Cantidad);

    private List<GrupoIfa> _pedidosAgrupados = new();
    private List<GrupoIfa> _recepcionesAgrupadas = new();
    private int _totalLineasPedidos;
    private int _totalLineasRecepciones;
    private double _totalCantidadRecibida;

    private void CambiarVista(bool recepciones)
    {
        if (_verRecepciones == recepciones) return;
        _verRecepciones = recepciones;
        _aviso = "";
        _consultado = false;
    }

    // ---- Envíos transaccionales (fase 2, port del While por días de R3) ----
    private bool _verEnvios;
    private bool _enviando;
    private string _tipoEnvio = "P";
    private DateTime _fechaEnvio = DateTime.Today.AddDays(-2);
    private List<string> _logEnvio = new();

    private string DescTipoEnvio => _tipoEnvio switch
    {
        "PM" => "pedidos modificados",
        "R" => "carga de recepciones",
        "RM" => "recepciones modificadas",
        _ => "carga de pedidos"
    };

    // Bucle día a día desde la fecha elegida hasta anteayer (mismas cotas que R3:
    // anterior a hoy, máximo 300 días atrás), con log de resultado por día.
    private async Task EnviarAsync()
    {
        if (_enviando) return;
        if (_fechaEnvio >= DateTime.Today || _fechaEnvio < DateTime.Today.AddDays(-300))
        {
            MostrarError("La fecha debe ser anterior a hoy y no más de 300 días atrás.");
            return;
        }

        _enviando = true;
        _aviso = "";
        _logEnvio = new();
        try
        {
            DateTime fecha = _fechaEnvio.Date;
            while (fecha < DateTime.Today.AddDays(-1))
            {
                var r = _tipoEnvio switch
                {
                    "PM" => await ServicioIfa.EnviarPedidosModificadosAsync(fecha),
                    "R" => await ServicioIfa.EnviarRecepcionesAsync(fecha),
                    "RM" => await ServicioIfa.EnviarRecepcionesModificadasAsync(fecha),
                    _ => await ServicioIfa.EnviarPedidosAsync(fecha)
                };
                if (!r.Ok || r.Datos is null)
                {
                    _logEnvio.Add($"✗ {fecha:dd/MM/yyyy}: {r.Error}");
                }
                else
                {
                    var d = r.Datos;
                    bool ok = string.Equals(d.Respuesta, "OK", StringComparison.OrdinalIgnoreCase);
                    _logEnvio.Add($"{(ok ? "✓" : "✗")} {fecha:dd/MM/yyyy}: {d.Respuesta} · {d.Lineas} líneas{(ok ? "" : $" · {d.Descripcion}")}");
                    if (!ok) _logEnvio.Add("✗ ****** REVISAR ******");
                    foreach (var e in d.Errores) _logEnvio.Add($"✗   {e}");
                }
                fecha = fecha.AddDays(1);
                StateHasChanged();
            }
            _tipoAviso = "exito";
            _aviso = $"Envío de {DescTipoEnvio} terminado: revisa el log por fechas.";
        }
        finally
        {
            _enviando = false;
        }
    }

    private async Task ConsultarAsync()
    {
        if (_cargando) return;
        if (_verRecepciones && _fechaDesde > _fechaHasta)
        {
            MostrarError("La fecha de inicio no puede ser posterior a la de fin.");
            return;
        }

        _cargando = true;
        _aviso = "";
        _consultado = false;
        try
        {
            if (!_verRecepciones)
            {
                var respuesta = await ServicioIfa.GetPedidosAsync(_fechaDesde);
                if (!respuesta.Ok) { MostrarError(respuesta.Error); return; }

                var lineas = respuesta.Datos ?? new();
                _totalLineasPedidos = lineas.Count;
                _pedidosAgrupados = lineas
                    .GroupBy(l => l.Pedido)
                    .Select(g => new GrupoIfa(g.Key, g.First().FechaPedido, g.First().Proveedor,
                        g.First().PuntoDestino, g.Count(), Math.Round(g.Sum(l => l.Cantidad), 2)))
                    .ToList();
            }
            else
            {
                var respuesta = await ServicioIfa.GetRecepcionesAsync(_fechaDesde, _fechaHasta);
                if (!respuesta.Ok) { MostrarError(respuesta.Error); return; }

                var lineas = respuesta.Datos ?? new();
                _totalLineasRecepciones = lineas.Count;
                _totalCantidadRecibida = Math.Round(lineas.Sum(l => l.CantidadRecibida), 2);
                _recepcionesAgrupadas = lineas
                    .GroupBy(l => l.Pedido)
                    .Select(g => new GrupoIfa(g.Key, g.First().FechaRecepcion, g.First().Proveedor,
                        g.First().PuntoDestino, g.Count(), Math.Round(g.Sum(l => l.CantidadRecibida), 2)))
                    .ToList();
            }
            _consultado = true;
        }
        finally
        {
            _cargando = false;
        }
    }

    private void MostrarError(string mensaje)
    {
        _tipoAviso = "error";
        _aviso = mensaje;
    }
}
