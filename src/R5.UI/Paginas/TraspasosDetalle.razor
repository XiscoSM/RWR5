@* Detalle de traspaso: líneas con cantidades pedidas vs enviadas e importe. Consulta. *@
@page "/traspasos/{FechaRuta}/{NumTraspaso:int}"
@inject TraspasoService Traspasos
@inject ReportService Reports
@inject IVisorArchivos Visor
@inject SesionUsuario Sesion
@inject NavigationManager Nav

<GuardiaModulo CodMenu="11">
<div class="r5-columna">

    <div class="r5-fila" style="flex-wrap: wrap;">
        <button class="r5-btn r5-btn--secundario" @onclick="Volver">← Traspasos</button>
        <h2>Traspaso @NumTraspaso · @(Fecha(_fecha))</h2>
        @if (Reg is not null)
        {
            <span class="r5-badge @(_registrado ? "r5-badge--cerrado" : "r5-badge--abierto")">
                @(_registrado ? "Registrado" : "Pendiente")
            </span>
        }
        <div class="r5-fila" style="margin-left:auto">
            @* PDF es acción secundaria; la primaria del detalle de un pendiente es registrarlo. *@
            <button class="r5-btn r5-btn--secundario" @onclick="AbrirPdfAsync"
                    disabled="@(_generandoPdf || _fecha is null)">
                <Icono Nombre="informes" Clase="r5-barra__icono" />
                @(_generandoPdf ? "Generando…" : "PDF")
            </button>
            @* Variante de R3: informe detallado con costes (report 52). *@
            <button class="r5-btn r5-btn--fantasma" @onclick="() => AbrirPdfVarianteAsync(true)"
                    disabled="@(_generandoPdf || _fecha is null)" title="Informe detallado con costes">
                PDF costes
            </button>
            @if (Reg == 0 && !_registrado)
            {
                @* Retomar: vuelve al alta con este traspaso cargado para seguir añadiendo. *@
                <button class="r5-btn r5-btn--secundario" disabled="@(_cargando || _fecha is null)"
                        @onclick='() => Nav.NavigateTo($"/traspasos/alta/{FechaRuta}/{NumTraspaso}")'>
                    + Añadir líneas
                </button>
                <BotonConfirmar Texto="Registrar traspaso"
                                Pregunta="@($"¿Registrar el traspaso {NumTraspaso} con {_lineas.Count} líneas? Mueve el stock y no se puede deshacer.")"
                                TextoOcupado="Registrando…" Ocupado="@_registrando"
                                Deshabilitado="@(_cargando || _lineas.Count == 0 || _error.Length > 0)"
                                OnConfirmar="RegistrarAsync" />
            }
        </div>
    </div>

    <Aviso Tipo="@_tipoAviso" Mensaje="@_aviso" />
    <Aviso Mensaje="@_errorPdf" />

    @if (_fecha is null)
    {
        <Aviso Mensaje="La fecha del traspaso no es válida." />
    }
    else if (_cargando)
    {
        <Cargando Texto="Cargando líneas…" />
    }
    else if (!string.IsNullOrEmpty(_error))
    {
        <Aviso Mensaje="@_error" />
    }
    else if (_lineas.Count == 0)
    {
        <div class="r5-cargando">
            <Icono Nombre="traspasos" Clase="r5-modulo__icono" />
            <span>El traspaso no tiene líneas.</span>
        </div>
    }
    else
    {
        <div class="r5-tarjeta r5-tabla-scroll">
            <table class="r5-tabla">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th class="num">Cajas</th>
                        <th class="num">Cantidad</th>
                        <th class="num">Cajas env.</th>
                        <th class="num">Cant. env.</th>
                        <th class="num">Importe</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var linea in _lineas)
                    {
                        <tr @key="linea.Linea">
                            <td>
                                <div class="r5-doc__principal">
                                    <span>@linea.Prod.DescProd</span>
                                    <span class="r5-doc__detalle">@linea.Prod.CodProd</span>
                                </div>
                            </td>
                            <td class="num">@linea.Cajas</td>
                            <td class="num">@Cantidad(linea.Cant, linea.Prod.DecimalesEnCant)</td>
                            <td class="num">@linea.CajasEnv</td>
                            <td class="num">@Cantidad(linea.CantEnv, linea.Prod.DecimalesEnCant)</td>
                            <td class="num">@Moneda(linea.Importe)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <p class="r5-texto-suave r5-texto-sm">@_lineas.Count líneas.</p>
    }
</div>
</GuardiaModulo>

@code {
    [Parameter] public string FechaRuta { get; set; } = "";
    [Parameter] public int NumTraspaso { get; set; }

    /// <summary>Estado desde la bandeja (0=pendiente, 1=registrado); null en deep-link = solo consulta.</summary>
    [Parameter, SupplyParameterFromQuery(Name = "reg")] public int? Reg { get; set; }

    private DateTime? _fecha;
    private bool _cargando = true;
    private string _error = "";
    private List<TraspasoLin> _lineas = new();

    private bool _registrado;
    private bool _registrando;
    private string _aviso = "";
    private string _tipoAviso = "exito";

    // Registrar el traspaso pendiente: mueve stock en RW (irreversible).
    private async Task RegistrarAsync()
    {
        if (_registrando || _fecha is null || !Sesion.Autenticado) return;

        _registrando = true;
        _aviso = "";
        try
        {
            var respuesta = await Traspasos.RegistrarAsync(NumTraspaso, _fecha.Value, Sesion.Usuario!.CodUsuario);
            if (!respuesta.Ok)
            {
                _tipoAviso = "error";
                _aviso = respuesta.Error;
                return;
            }
            _registrado = true;
            _tipoAviso = "exito";
            _aviso = $"Traspaso {NumTraspaso} registrado.";
        }
        finally
        {
            _registrando = false;
        }
    }

    private bool _generandoPdf;
    private string _errorPdf = "";

    // El PDF se renderiza en el servidor con el mismo .rdlc de R3; aquí solo se abre.
    private async Task AbrirPdfAsync() => await AbrirPdfVarianteAsync(false);

    // detallado=true → informe detallado con costes (variante del RDLC de R3).
    private async Task AbrirPdfVarianteAsync(bool detallado)
    {
        if (_generandoPdf || _fecha is null) return;

        _generandoPdf = true;
        _errorPdf = "";
        try
        {
            var respuesta = await Reports.GetTraspasoPdfAsync(NumTraspaso, _fecha.Value,
                verCostes: detallado, detallado: detallado);
            if (!respuesta.Ok || respuesta.Datos is null)
            {
                _errorPdf = respuesta.Error;
                return;
            }
            await Visor.AbrirAsync($"Traspaso_{NumTraspaso}{(detallado ? "_detallado" : "")}.pdf", respuesta.Datos);
        }
        catch (Exception ex)
        {
            _errorPdf = "No se pudo abrir el PDF: " + ex.Message;
        }
        finally
        {
            _generandoPdf = false;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (!Sesion.Autenticado) return;
        _registrado = Reg == 1;

        if (!DateTime.TryParseExact(FechaRuta, "yyyy-MM-dd", null,
            System.Globalization.DateTimeStyles.None, out var fecha))
        {
            _fecha = null;
            _cargando = false;
            return;
        }
        _fecha = fecha;

        try
        {
            var respuesta = await Traspasos.GetLineasAsync(NumTraspaso, fecha);
            if (!respuesta.Ok)
            {
                _error = respuesta.Error;
                return;
            }
            _lineas = respuesta.Datos ?? new();
        }
        finally
        {
            _cargando = false;
        }
    }

    private void Volver() => Nav.NavigateTo("/traspasos");
}
