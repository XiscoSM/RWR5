@* Login dual (canon R3 feat/m17-usabilidad): la vía habitual es EMPLEADO + PIN (el PIN
   se valida en el servidor y la sesión devuelta es la del RW_Usuario asignado); la vía
   alternativa "Usuario Pda" es nº de usuario RW + contraseña. En ambos casos la SESIÓN
   es siempre un RW_Usuario — el empleado queda ligado como sujeto de RRHH.
   Campos grandes centrados, Enter valida. Sin URL de API o sin enrolar no se entra. *@
@page "/login"
@layout LayoutVacio
@inject UsuarioService Usuarios
@inject SesionUsuario Sesion
@inject ConfiguracionApp Config
@inject RepositorioConfiguracion RepoConfig
@inject CredencialesApi Credenciales
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="r5-login">
    <div class="r5-login__tarjeta">
        <div class="r5-login__cabecera">
            <div class="r5-login__icono"><span>R5</span></div>
            <span class="r5-login__env">@Config.Entorno · Terminal @Config.NumTerminal</span>
        </div>

        <div class="r5-login__cuerpo">
            @if (!Credenciales.Enrolado)
            {
                <Aviso Tipo="info" Mensaje="Dispositivo sin enrolar. Configura la conexión en Ajustes antes de entrar." />
            }

            @if (_modoEmpleado)
            {
                <form @onsubmit="EntrarEmpleadoAsync">
                    <div class="r5-columna">
                        <div class="r5-campo">
                            <label for="numPersonal">Nº personal (empleado)</label>
                            <input id="numPersonal" class="r5-input r5-input--numero" type="text" inputmode="numeric"
                                   @bind="_empleado" @bind:event="oninput" autofocus disabled="@_validando" />
                        </div>

                        <div class="r5-campo">
                            <label for="pin">PIN secreto (4 dígitos)</label>
                            <input id="pin" class="r5-input r5-input--numero" type="password" inputmode="numeric" maxlength="4"
                                   @bind="_pin" @bind:event="oninput" disabled="@_validando" />
                        </div>

                        <Aviso Mensaje="@_error" />

                        <button type="submit" class="r5-btn r5-btn--primario r5-btn--bloque"
                                disabled="@(_validando || !Credenciales.Enrolado || _empleado is null or <= 0 || _pin is null)">
                            @(_validando ? "Validando…" : "Entrar")
                        </button>
                        <button type="button" class="r5-btn r5-btn--fantasma r5-btn--bloque"
                                @onclick="() => CambiarModo(false)" disabled="@_validando">
                            Entrar como Usuario Pda
                        </button>
                    </div>
                </form>
            }
            else
            {
                <form @onsubmit="EntrarUsuarioAsync">
                    <div class="r5-columna">
                        <div class="r5-campo">
                            <label for="usuario">Nº de Usuario Pda</label>
                            <input id="usuario" class="r5-input r5-input--numero" type="text" inputmode="numeric"
                                   @bind="_codUsuario" @bind:event="oninput" autofocus disabled="@_validando" />
                        </div>

                        <div class="r5-campo">
                            <label for="pwd">Contraseña</label>
                            <input id="pwd" class="r5-input r5-input--numero" type="password" inputmode="numeric"
                                   @bind="_pwd" @bind:event="oninput" disabled="@_validando" />
                        </div>

                        <Aviso Mensaje="@_error" />

                        <button type="submit" class="r5-btn r5-btn--primario r5-btn--bloque"
                                disabled="@(_validando || !Credenciales.Enrolado || _codUsuario is null or <= 0 || _pwd is null)">
                            @(_validando ? "Validando…" : "Entrar")
                        </button>
                        <button type="button" class="r5-btn r5-btn--fantasma r5-btn--bloque"
                                @onclick="() => CambiarModo(true)" disabled="@_validando">
                            Entrar con Empleado y PIN
                        </button>
                    </div>
                </form>
            }

            <div class="r5-login__pie">
                <span>v@(VersionApp)</span>
                <button class="r5-btn r5-btn--fantasma" @onclick="@(() => Nav.NavigateTo("/ajustes"))">
                    <Icono Nombre="ajustes" Clase="r5-barra__icono" /> Ajustes
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private bool _modoEmpleado = true;   // vía rápida por defecto (canon R3)
    private int? _empleado;
    private short? _pin;
    private short? _codUsuario;
    private int? _pwd;
    private bool _validando;
    private string _error = "";

    private static string VersionApp =>
        System.Reflection.Assembly.GetEntryAssembly()?.GetName().Version?.ToString(3) ?? "?";

    protected override void OnInitialized()
    {
        // Si ya hay sesión (p. ej. se llegó a /login con el botón atrás), no re-loguear.
        if (Sesion.Autenticado) { Nav.NavigateTo("/inicio", replace: true); return; }
        if (Config.UltimoUsuario > 0) _codUsuario = Config.UltimoUsuario;
        // El terminal recuerda su última vía de entrada.
        _modoEmpleado = Config.LoginPorEmpleado;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Con el usuario Pda precargado, el foco va directo a la contraseña (caso diario).
        if (firstRender && !_modoEmpleado && _codUsuario is > 0)
            await JS.InvokeVoidAsync("r5.seleccionar", "pwd");
    }

    private void CambiarModo(bool empleado)
    {
        _modoEmpleado = empleado;
        _error = "";
    }

    // Vía rápida: Empleado + PIN. El PIN lo valida el servidor contra la ficha central y
    // la sesión llega ya mapeada a su RW_Usuario (LoginEmpleadoPin de R3).
    private async Task EntrarEmpleadoAsync()
    {
        if (_validando || _empleado is null or <= 0 || _pin is null) return;
        _validando = true;
        _error = "";
        try
        {
            var respuesta = await Usuarios.LoginEmpleadoAsync(_empleado.Value, _pin.Value);
            if (!respuesta.Ok || respuesta.Datos is null) { await ErrorLoginAsync(respuesta.Error, "pin"); return; }
            if (respuesta.Datos.CodUsuario <= 0) { await ErrorLoginAsync("Revise usuario y PIN.", "pin"); return; }
            if (respuesta.Datos.Empleado == 0) respuesta.Datos.Empleado = _empleado.Value;
            await AbrirSesionAsync(respuesta.Datos, porEmpleado: true);
        }
        finally
        {
            _validando = false;
        }
    }

    // Vía alternativa: nº de Usuario Pda + contraseña (RW_Pwd), como el usuario de config.
    private async Task EntrarUsuarioAsync()
    {
        if (_validando || _codUsuario is null or <= 0 || _pwd is null) return;
        _validando = true;
        _error = "";
        try
        {
            var respuesta = await Usuarios.LoginAsync(_codUsuario.Value, _pwd.Value);
            if (!respuesta.Ok || respuesta.Datos is null) { await ErrorLoginAsync(respuesta.Error, "pwd"); return; }
            if (respuesta.Datos.CodUsuario <= 0) { await ErrorLoginAsync("Usuario o contraseña incorrectos.", "pwd"); return; }
            await AbrirSesionAsync(respuesta.Datos, porEmpleado: false);
        }
        finally
        {
            _validando = false;
        }
    }

    private async Task AbrirSesionAsync(Usuario usuario, bool porEmpleado)
    {
        // Restricción de red por usuario (Menu_R3:1190): si RW_RedIpUsuario está
        // informado, alguna IP local debe contener ese fragmento de red.
        string redPermitida = usuario.RedIpUsuario?.Trim() ?? "";
        if (redPermitida.Length > 0)
        {
            bool redOk = System.Net.NetworkInformation.NetworkInterface.GetAllNetworkInterfaces()
                .Where(n => n.OperationalStatus == System.Net.NetworkInformation.OperationalStatus.Up)
                .SelectMany(n => n.GetIPProperties().UnicastAddresses)
                .Where(a => a.Address.AddressFamily == System.Net.Sockets.AddressFamily.InterNetwork)
                .Any(a => a.Address.ToString().Contains(redPermitida, StringComparison.OrdinalIgnoreCase));
            if (!redOk)
            {
                await ErrorLoginAsync($"El usuario {usuario.DescUsuario} no puede iniciar en esta dirección de red. Red permitida: {redPermitida}.", porEmpleado ? "pin" : "pwd");
                return;
            }
        }

        usuario.NumTerminal = Config.NumTerminal;
        Sesion.IniciarSesion(usuario);

        Config.UltimoUsuario = usuario.CodUsuario;
        Config.LoginPorEmpleado = porEmpleado;
        RepoConfig.Guardar(Config);

        Nav.NavigateTo("/inicio", replace: true);
    }

    // Tras un login fallido se limpia el secreto y se devuelve el foco a ese campo.
    private async Task ErrorLoginAsync(string mensaje, string campoFoco)
    {
        _error = mensaje.Length > 0 ? mensaje : "No se pudo validar. Revisa los datos.";
        _pin = null;
        _pwd = null;
        _validando = false;
        StateHasChanged();
        await JS.InvokeVoidAsync("r5.seleccionar", campoFoco);
    }
}
