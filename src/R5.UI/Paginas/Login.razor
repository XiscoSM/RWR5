@* Login: el operario entra con código de usuario + contraseña numérica (como en RW).
   Campos grandes centrados, último usuario precargado, Enter valida.
   Acceso directo a Ajustes: sin URL de API o sin enrolar no se puede entrar. *@
@page "/login"
@layout LayoutVacio
@inject UsuarioService Usuarios
@inject SesionUsuario Sesion
@inject ConfiguracionApp Config
@inject RepositorioConfiguracion RepoConfig
@inject CredencialesApi Credenciales
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="r5-login">
    <div class="r5-login__tarjeta">
        <div class="r5-login__marca">
            <span class="nombre">RW R5</span>
            <span class="detalle">@Config.Entorno · Terminal @Config.NumTerminal</span>
        </div>

        @if (!Credenciales.Enrolado)
        {
            <Aviso Tipo="info" Mensaje="Dispositivo sin enrolar. Configura la conexión en Ajustes antes de entrar." />
        }

        <form @onsubmit="EntrarAsync">
            <div class="r5-columna">
                <div class="r5-campo">
                    <label for="usuario">Usuario</label>
                    <input id="usuario" class="r5-input r5-input--numero" type="text" inputmode="numeric"
                           @bind="_codUsuario" @bind:event="oninput" autofocus disabled="@_validando" />
                </div>

                <div class="r5-campo">
                    <label for="pwd">Contraseña</label>
                    <input id="pwd" class="r5-input r5-input--numero" type="password" inputmode="numeric"
                           @bind="_pwd" @bind:event="oninput" disabled="@_validando" />
                </div>

                <Aviso Mensaje="@_error" />

                <button type="submit" class="r5-btn r5-btn--primario r5-btn--bloque"
                        disabled="@(_validando || !Credenciales.Enrolado || _codUsuario is null or <= 0 || _pwd is null)">
                    @(_validando ? "Validando…" : "Entrar")
                </button>
            </div>
        </form>

        <div class="r5-login__pie">
            <span>v@(VersionApp)</span>
            <button class="r5-btn r5-btn--fantasma" @onclick="@(() => Nav.NavigateTo("/ajustes"))">
                <Icono Nombre="ajustes" Clase="r5-barra__icono" /> Ajustes
            </button>
        </div>
    </div>
</div>

@code {
    private short? _codUsuario;
    private int? _pwd;
    private bool _validando;
    private string _error = "";

    private static string VersionApp =>
        System.Reflection.Assembly.GetEntryAssembly()?.GetName().Version?.ToString(3) ?? "?";

    protected override void OnInitialized()
    {
        // Si ya hay sesión (p. ej. se llegó a /login con el botón atrás), no re-loguear.
        if (Sesion.Autenticado) { Nav.NavigateTo("/inicio", replace: true); return; }
        if (Config.UltimoUsuario > 0) _codUsuario = Config.UltimoUsuario;
    }

    // Con el usuario ya precargado, el foco va directo a la contraseña (el caso diario).
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _codUsuario is > 0)
            await JS.InvokeVoidAsync("r5.seleccionar", "pwd");
    }

    private async Task EntrarAsync()
    {
        if (_validando || _codUsuario is null or <= 0 || _pwd is null) return;

        _validando = true;
        _error = "";
        try
        {
            var respuesta = await Usuarios.LoginAsync(_codUsuario.Value, _pwd.Value);
            if (!respuesta.Ok || respuesta.Datos is null)
            {
                await ErrorLoginAsync(respuesta.Error);
                return;
            }
            if (respuesta.Datos.CodUsuario <= 0)
            {
                await ErrorLoginAsync("Usuario o contraseña incorrectos.");
                return;
            }

            respuesta.Datos.NumTerminal = Config.NumTerminal;
            Sesion.IniciarSesion(respuesta.Datos);

            Config.UltimoUsuario = respuesta.Datos.CodUsuario;
            RepoConfig.Guardar(Config);

            Nav.NavigateTo("/inicio", replace: true);
        }
        finally
        {
            _validando = false;
        }
    }

    // Tras un login fallido se limpia la contraseña y se devuelve el foco a ese campo:
    // el operario reintenta sin borrar a mano ni tocar la pantalla.
    private async Task ErrorLoginAsync(string mensaje)
    {
        _error = mensaje;
        _pwd = null;
        _validando = false;
        StateHasChanged();
        await JS.InvokeVoidAsync("r5.seleccionar", "pwd");
    }
}
