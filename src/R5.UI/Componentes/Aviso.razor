@* Aviso inline (error / éxito / info) con icono; se oculta si no hay mensaje.
   Suena al aparecer (error/éxito): confirma la operación sin mirar la pantalla. *@
@inject IJSRuntime JS

@if (!string.IsNullOrWhiteSpace(Mensaje))
{
    <div class="r5-aviso r5-aviso--@Tipo" role="@(Tipo == "error" ? "alert" : "status")">
        <Icono Nombre="@_icono" Clase="r5-aviso__icono" />
        <span>@Mensaje</span>
        @if (OnReintentar.HasDelegate)
        {
            <button class="r5-btn r5-btn--secundario r5-btn--sm" style="margin-left:auto"
                    @onclick="OnReintentar" disabled="@Reintentando">
                @(Reintentando ? "Reintentando…" : "Reintentar")
            </button>
        }
    </div>
}

@code {
    [Parameter] public string Mensaje { get; set; } = "";

    /// <summary>"error", "exito" o "info".</summary>
    [Parameter] public string Tipo { get; set; } = "error";

    /// <summary>Poner a false en avisos pasivos (p. ej. validación de formularios).</summary>
    [Parameter] public bool ConSonido { get; set; } = true;

    /// <summary>Si se asigna, el aviso muestra un botón "Reintentar" (para errores de carga).</summary>
    [Parameter] public EventCallback OnReintentar { get; set; }

    /// <summary>Estado de la reejecución, para deshabilitar el botón mientras corre.</summary>
    [Parameter] public bool Reintentando { get; set; }

    private string _ultimoSonado = "";

    private string _icono => Tipo switch
    {
        "exito" => "ok",
        "info" => "info",
        _ => "error"
    };

    protected override async Task OnParametersSetAsync()
    {
        // Suena solo cuando el mensaje cambia a un valor nuevo no vacío (los re-render
        // con el mismo aviso no repiten el pitido).
        string clave = string.IsNullOrWhiteSpace(Mensaje) ? "" : $"{Tipo}|{Mensaje}";
        if (clave == _ultimoSonado) return;
        _ultimoSonado = clave;

        if (ConSonido && clave.Length > 0 && Tipo is "error" or "exito")
        {
            try { await JS.InvokeVoidAsync("r5.sonido", Tipo); }
            catch { /* prerender o JS no disponible: silencio */ }
        }
    }
}
